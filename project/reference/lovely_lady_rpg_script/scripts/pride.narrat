            if (roll pride_raven_fuck_nasty nasty 20):
                talk nasty talk "You're slightly too weird and confusing for her to consider banging right now. A shame. A real fucking shame."
            else:
                wait 1000
    if (objective_started? writer pride):
        clear_dialog
        talk writer talk "Shall we continue, Ghost?"
        clear_dialog
        play sound footsteps
        "She does not wait for a response."
    jump pride_writer_end_one

pride_writer_end_one:
