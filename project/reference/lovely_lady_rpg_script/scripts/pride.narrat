        "[Buy a slightly too expensive bottle of Dandelion and Burdock: <span class='writtenText'>'Pride flavour'</span>, whatever that means - Two Anglian Pounds]" if (>= $stats.money.value 2):
            add_stat money -2
            play sound coins
            add data.pride.drinksDrunk 1
            choice:
                "It turns out pride flavour is the same as normal flavour."
                "[Drink it sloppy style and do a big burp] \\"EUUURP!\\"":
                    if (objective_started? writer pride):
                        "The Pulp Writer raises an eyebrow."
                        if (roll pride_menu_water_orb orb 20):
                            talk orb talk "She is reminded why she only drinks water."
                        else:
