    set_button button_newspaper true

DEBUG_ending:
    choice:
        "..."
        "Writer present.":
            set data.ending.presentWriter true
            add data.ending.visitors 1
        "Sinner present.":
            set data.ending.presentSinner true
            add data.ending.visitors 1
        "Weapon present.":
            set data.ending.presentWeapon true
            add data.ending.visitors 1
        "Landlady present.":
            set data.ending.presentLandlady true
            add data.ending.visitors 1
        "Friends present.":
            set data.ending.presentWriter true
            set data.ending.presentSinner true
            set data.ending.presentWeapon true
            add data.ending.visitors 3
        "PLAY ENDING":
            if $data.ending.presentBoneman:
                jump ending_boneman
            if $data.ending.presentLandlady:
                jump ending_landlady
            if (|| $data.ending.presentWriter $data.ending.presentSinner $data.ending.presentWeapon):
                jump ending_friends
            else:
                jump ending_alone
    jump DEBUG_ending

DEBUG_pride:
    choice:
        "..."
        "Writer present":
            start_quest writer
            start_objective writer pride
        "Sinner present":
            start_quest sinner
        "Raven present":
            set data.raven.met true
        "Raven happy":
            set data.article_raven true
        "Raven angry":
            set data.raven.interviewBad true
        "All present":
            start_quest writer
            start_objective writer pride
            start_quest sinner
            set data.raven.met true
        "PLAY PRIDE":
            jump pride
    jump DEBUG_pride

skip:
    set doesNothing true

goToGameMap:
    save_prompt
    set data.game_map.inMap false
    jump game_map