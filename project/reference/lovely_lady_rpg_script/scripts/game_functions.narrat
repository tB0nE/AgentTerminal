diseaseCounter:
    add data.ghost.diseases 1
    if (== $data.ghost.diseases 6):
        unlock_achievement disease

DEBUG_populateVariables:
    choice:
        "Set values to..."
        "TRUE:"
            run z_populateVariables true
        "FALSE":
            run z_populateVariables false
    jump game_map

DEBUG_allItems:
    add_item plank 1
    add_item nails 1
    add_item hammer 1

    add_item sillySheep 1
    set data.ghost.investor true

    add_item hrt 1

    add_item cereal 1
    add_item cig 1
    add_item stickers 1

    add_item article 1
    add_item fiction 1

    add_item milk 1
    add_item kipferl 1

    add_item herring 1

    add_item plushShark 1
    add_item plushBird 1
    add_item plushSheep 1

    add_item pennies 1

    jump game_map

DEBUG_allQuests:
    start_quest intro
    start_quest fixHouse
    start_quest sinner
    start_quest crypto
    start_quest landlady
    start_quest cryptids
    start_quest weapon
    start_quest cleanup
    start_quest writer
    start_quest hrt
    start_quest houseSnake
    jump game_map

DEBUG_setDay:
    choice:
        "SET DAY TO..."
        "ONE":
            set_stat day 1
        "TWO":
            set_stat day 2
        "THREE":
            set_stat day 3
        "FOUR":
            set_stat day 4
    jump game_map

DEBUG_setActions:
    choice:
        "SET ACTIONS TO..."
        "1":
            set_stat actions 1
        "2":
            set_stat actions 2
        "3":
            set_stat actions 3
        "4":
            set_stat actions 4
        "5":
            set_stat actions 5
        "6":
            set_stat actions 6
    jump game_map

DEBUG_money:
    set_stat money 999
    jump game_map

DEBUG_allButtons:
    set_button button_home true
    set_button button_intro_weapon true
    set_button button_intro_bluehills true
    set_button button_fixHouse true
    set_button button_church true
    set_button button_park true
    set_button button_memorial true
    set_button button_movie true
    set_button button_raven true
    set_button button_apartment true
    set_button button_archive true
    set_button button_woods true
    set_button button_interview true
    set_button button_article true
    set_button button_writer_one true
    set_button button_fiction true
    set_button button_writer_two true
    set_button button_writer_late true
    set_button button_nkvd true
    set_button button_pharmacy true
    set_button button_keeper true
    set_button button_dealer true
    set_button button_hrt_end true
    set_button button_sheep true
    set_button button_bridge true
    set_button button_eiffel true
    set_button button_landlady true
    set_button button_comet true
    set_button button_cryptids true
    set_button button_shrine true
    set_button button_cave true
    set_button button_pride true
    set_button button_pervert true
    set_button button_houseSnake true
    set_button button_pervert true
