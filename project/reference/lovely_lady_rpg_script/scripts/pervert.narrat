pervert:
    play sound click
    if $data.pervert.metPervert:
        choice:
            "WILLKOMMEN AUS PARDY CIDDY!"
            "[JA SUPER COOL!!!] <span class='prompt'>[[-1 ACTION]]</span>":
                play sound spendAction
                set data.game_map.inMap false
                add_stat actions -1
                run transition_black pervert_tent
                set_screen pervert_00 1
                clear_dialog
                jump pervert_return
            "<span class='prompt'>[[BACK]]</span>":
                jump game_map
    else:
        choice:
            "Seems some Deutsch guy has made Bluehills centre his home. Hopefully He's at least nice?"
            "[JA SUPER COOL!!!] <span class='prompt'>[[-1 ACTION]]</span>":
                play sound spendAction
                set data.game_map.inMap false
                add_stat actions -1
                run transition_black pervert_tent
                set_screen pervert_00 1
                clear_dialog
                jump pervert_intro
            "<span class='prompt'>[[BACK]]</span>":
                jump game_map

pervert_intro:
    clear_dialog
    set data.pervert.metPervert true
    set data.pervert.amount 1
    play music supercool
    "A tall man appears to have set up glamp in the town centre. Despite this being Bluehills town centre, he appears to be having a great time. He spots you gawping at him and calls over."
    clear_dialog
    set_screen pervert_01 1
    choice:
        talk pervert talk "PREDDY LADEH! HALLO!"
        "[Approach the strange man] \\"Um, hello sir. Nice to-\\" [Get clocked]":
            set_screen pervert_04 1
            "He tilts his head, some instinct has kicked in. He's clocked you as easily as a clockmaker clocks a clock."
    clear_dialog
    set_screen pervert_02 1
    choice:
        talk pervert talk "Oh ja, du ist tranzsezual? Das ist super cool!!! Very <span class='writtenText'>'progress'</span>! Genau!"
        "[Nod] \\"You've got me dead to rights sir, I'm tranzezual and I wear a beret.\\" [Point at your beret].":
            set_screen pervert_04 1
            talk pervert talk "Ja ich liebe deine Baskenmütze! Vury <span class='writtenText'>'cohnteh'</span>!"
        "[Lie] \\"I'm cis.\\"":
            set_screen pervert_01 1
            talk pervert talk "Ahaha! Oh you'z tranzezual chiks are too much! Vury funny all oz youz! I think maybe being a tranzezual makes du <span class='writtenText'>'x-tra'</span> fonneh! Super cool!"
    set_screen pervert_08 1
    choice:
        talk pervert talk "Ken ich azk deinen namen, mein liddel maus, und how long are youz? Are ve talkeeng bratvurst oder veisevurst iz you ged my dreft?"
        "\\"Ghost. Uh. Between one to... let's say five inches? Look I don't know man I haven't checked.\\"":
            set_screen pervert_07 1
            talk pervert talk "Woaw! Super cool!"
        "\\"Ghost.\\" [Lie] \\"About ten inches.\\"":
            set_screen pervert_03 1
            talk pervert talk "YOWZERZ!!! SUPER COOL! GENAU!!!! VURY <span class='writtenText'>'WOMENS SUFFRAGE'</span>! SUPER TOLL!!! YOUZ COULD TURNEN MEIN INSIDEZ INTO EIN PREZEL MIT ZAT BABEY!!!"
            clear_dialog
            talk nasty talk "You lying bitch."
    jump pervert_menu

pervert_return:
    play music supercool
    add data.pervert.amount 1
    talk pervert talk "Goazt! Wilkommen back meine friende! Super cool to see you! Av your tets got begger or are you'z just appy to see mich bounce bouce! I joke I joke!"
    jump pervert_menu
    
pervert_menu:
    set_screen pervert_00 1
    clear_dialog
    if (<= $data.pervert.talkCount 0):
        talk pervert talk "Anyvay! No more questions ja! Genau! Let'z focuz on geddin crazeh! Does you av any popper, bitte?"
        clear_dialog
        talk orb talk "He's bored of talking now. We should probably leave."
        clear_dialog
        set_screen pervert_08 1
        choice:
            "Frankfurt Pervert grins at you, mouthing the words to a song about having a trans woman sit on your face. Occasionly he points at you and wiggles his eyebrows."
            "\\"I think I must have used my last popper the other day, sorry. Uh. I need to go. <span class='prompt'>[[CONTINUE]]</span>":
                play sound spendAction
                set_screen pervert_03 1
                talk pervert talk "Zo zoon? Nicht sehr gut! But Goazt darling I'll be ere iz ezer du wannst pardy again! Super!"
                jump goToGameMap
    else:
        choice:
            talk pervert talk "So vat shall we chad abowt, Goazt? Die ladies? Das pardy we call life? I can alzo ozzers you financal advize, ich werk en <span class='writtenText'>'international finance'</span>, et'z preddy cool, ja?"
            "\\"Die ladies, bitte.\\"" if (&& (== $data.pervert.talkWomen false) (> $data.pervert.talkCount 0)):
                jump pervert_women
            "\\"Some life advice could be really useful, I feel like I'm in a bit of a tatters right now, truth be told.\\"" if (&& (== $data.pervert.talkLife false) (> $data.pervert.talkCount 0)):
                jump pervert_life
            "\\"I could really use some financial advice.\\"" if (&& (== $data.pervert.talkMoney false) (> $data.pervert.talkCount 0)):
                jump pervert_money
            "\\"Tell me about yourself, sir.\\"" if (&& (== $data.pervert.talkSelf false) (> $data.pervert.talkCount 0)):
                jump pervert_self

pervert_women:
    add data.pervert.talkCount -1
    set data.pervert.talkWomen true
    set_screen pervert_02 1
    choice:
        talk pervert talk "Du vanst talken abouz die chikz! Ja super cool!!! I knoz all abowt doze! Tell mich Goazt, which chik az das apfel of deine eye?"
        "\\"A woman who is kind of my boss is quite pretty in a dilapidated shed kind of way and I'd like to kiss and or sleep with her.\\"" if (&& (== (quest_started? writer) true) (!= (objective_started? writer pride) true) (!= $data.gamemap.writerLate true)):
            set_screen pervert_04 1
            talk pervert talk "Oh ja, ich slept with mein boss during das var. Preddy keenky fellow das kaiser! It'z preddy fun und nuzing can go wrong from et! I'd maken sure you get deine wurk finished in zeit, Goazt! I zink dat chikz like zat are vury domineering und vill nicht like if you don't do az you are told! But if you do... sexeh timez!!!!!!!"
        "\\"I met this tall scary woman at the Cathedral and she's a real freak, big divination card fan. What do we reckon?\\"" if (&& (quest_started? sinner) (!= (objective_completed? sinner archive) true) (!= (objective_started? sinner woods) true)):
            set_screen pervert_04 1
            talk pervert talk "Ein Catedral! Woaw! Super cool! Vury <span class='writtenText'>'naughty nunnery'</span>! She soundz like a preddy crazy chik! Diese cards sound super cool! Ozten ich dink das secret to getting into a gurlz pantiez iz to azk about her interestz ja? Even if it'z zomthing nicht sehr cool und super boring!"
        "\\"I'm hoping to spend time with this weird writer woman but I don't know how to see her again before our walk and if I don't see her again before our walk I might have to kill myself?" if (&& (== (objective_started? writer pride) true) (!= (quest_completed? writer) true)):
            set_screen pervert_04 1
            talk pervert talk "Oh? She vants to gew to za parade I ezpect!"
            clear_dialog
            set_screen pervert_08 1
            "He leans towards you, a smirk plastered across his face, but an entirely genuine one."
            clear_dialog
            talk pervert talk "Diese typez of chikz wit der artzeh sadnezz alwayz zey wants to pretend dat zey are too gute fur ein pardy but alwayz zey show oop und get eaten ownt under das dining table ja! Bedder go find her I zink!"
        "\\"I've been talking to this tall lady who wants to find a cave to like, self obliterate because of guilt or something? How do I make her like me.\\"" if (&& (== (quest_started? sinner) true) (!= (quest_succeeded? sinner) true) (== (objective_completed? sinner archive) true) (!= (objective_completed? sinner woods) true)):
            set_screen pervert_01 1
            talk pervert talk "Soundz to mich like youz gotz yourselz ein craaaaazy chik! Und nicht in un cool pady vey! Mein advice? She needs to live im der moment! Pardy like it's 1916! Ged a liddel crazy und hit up maybe mein telegram! I joke! I joke! She ist your chik unless you're into dat ja!"
            clear_dialog
            set_screen pervert_03 1
            "He pauses to apply some cologne."
            if (roll pervert_women_cologone_lovely lovely 20):
                talk lovely talk "<span class='writtenText'>'L'eau d'panty'</span>. Wouldn't be caught dead in it myself!"
                talk nasty talk "Eauuuuuugh..."
            clear_dialog
            set_screen pervert_07 1
            talk pervert talk "Wat she vants ist nicht sehr toll! Not vury cool! Ein decleration of bankruptcy for der soul, ja? Don't encourage her! Get her to live a liddel! After all she's here im Bluehillz! Pardy ciddy!"
            clear_dialog
            "An elderly couple stroll past. One of them smells like burlap."
        "\\"I really pissed off this massive dyke and I think she might kill me? Thoughts?\\"" if (== $data.raven.badEnd true):
            set_screen pervert_04 1
            talk pervert talk "WOAW! SUPER SEXEH! Alwayz I zink dat if you're scaredey scardey of ein chik it is good to get ein side chik to defend you! Try nicht to be alone!"
            set_screen pervert_06 1
            talk pervert talk "It's when you're at your most vulnerable."
            talk pervert talk "Like Ekkehardt. Ekk in the wire..."
            talk pervert talk "Alles verheddert... Alles durcheinander..."
            clear_dialog
            "His brow creases, lips tremble."
            clear_dialog
            talk pervert talk "Es tut mir wirklich leid, Ekk."
            clear_dialog
            "He stares into the distance for about two minutes before hip thrusting."
            clear_dialog
            set_screen pervert_03 1
            talk pervert talk "SO JA! Keep ein ladey around und you'll be pretty <span class='writtenText'>'Secure Perimeter'</span>, ja!"
        "\\"Are there any girls who were cut from this game for scoping reasons I could be hitting up?\\"":
            set_screen pervert_04 1
            talk pervert talk "Ja if youz waunt to be seeing nerdy chikz it is alweyz ein gut idea to hiz up za library ja? I write down famouz quotez from literature fur use on any chikz wiz glasses. Preddy clever!"
        "\\"I have a bit of a Landlady problem. She's a <span class='writtenText'>chik</span>, I guess.\\"" if (&& (== (quest_started? landlady) true) (!= (quest_completed? landlady) true)):
            set_screen pervert_08 1
            choice:
                talk pervert talk "WOAW! You vant to bang deine Landlaydeh!? Preddy keenky!"
                "\\"No! No! I don't! I want advice on making her leave me alone!\\"":
                    set_screen pervert_03 1
                    talk pervert talk "Du ist real <span class='writtenText'>'frekeh frekeh'</span>, Goazt! Genau!"
        "\\"Some non specific advice, please.\\"":
            set_screen pervert_04 1
            choice:
                talk pervert talk "Ja I sumtimez wunder eef I'm ein lezbien because I find die Mädels super sezzy ja?"
                "[Nod] \\"Truth.\\"":
                    set_screen pervert_07 1
                    talk pervert talk "Genau!"
                "\\"That wasn't very helpful.\\"":
                    set_screen pervert_05 1
                    talk pervert talk "MAGST DU PARDY MACHEN!?"
    jump pervert_menu

pervert_money:
    add data.pervert.talkCount -1
    set data.pervert.talkMoney true
    set_screen pervert_04 1
    add data.pervert.moneyTalks 1
    talk pervert talk "Oh ja, dolla ist super important, naturalich! Always I em saying zat you can't pay for noze candey to snort offoza dikgurlz cock wizout capital! Ja babey!"
    clear_dialog
    set_screen pervert_02 1
    "Frankfurt Pervert eyes you smuttily (the only way he can). He's deep in thought."
    clear_dialog
    set_screen pervert_07 1
    talk pervert talk "Okay Ja! Ich habe ein zuggeztion fur dich!"
    if (== $stats.day.value 2):
        set_screen pervert_01 1
        clear_dialog 
        talk pervert talk "Mine Alpina neighbours have un myth about a liddel snake zat gives dolla dolla dolla! Sehr toll!!! Vury <span class='writtenText'>'international finance'</span>! Das liddel serpent loavs to eat Kipfel und Milch, und ein stark friendzip mit das liddel serpent can pay dividends acroz das tax year, vury cool!!!"
    elseif (== $stats.day.value 3):
        set_screen pervert_01 1
        clear_dialog
        talk pervert talk "Ich saw in das newspaper dat itz pozzibul to vin BIG dolla by feeling up za crosswurd correctly. Preddy cool!!! I'm a pardier nod ein encyclopedia, not mein scene! You look preddy clevur though, maybe you can do it, ja!"
        if (roll pervert_money_clever_orb orb 20):
            talk orb talk "Correction to the above claim: Ghost is not 'preddy clevur'."
    elseif (== $stats.day.value 4):
        set_screen pervert_01 1
        clear_dialog
        if (>= $data.pervert.moneyTalks 3):
            choice:
                talk pervert talk "Goazt! Always you iz talking about dolla! What's on deine mind!"
                "\\"Hormones are really really expensive and I'm not very good at financial.\\"":
                    set_screen pervert_03 1
                    talk pervert talk "No vey! Du ist on whore moans? Das is cuhhhhrazey! I thought youz were one of those dikgirlz who ist just naturalich sexeh! I'd hate to see diese rose vilt, here!"
                    clear_dialog
                    add_stat money 50
                    unlock_achievement pervert
                    play sound coins
                    choice:
                        "Frankfurt Pervert slicks back his hair and pulls some money from his underwear. You take it from him. It's warm and a stray pube gives Saint Dawnsight a little moustache."
                        "\\"Wow! So much dolla!? And for me!?\\" [Wipe away a tear] \\"What a nice man...\\"":
                            set_screen pervert_08 1
                            talk pervert talk "Ja kein problem mein Fruend!!! Just promes you von't get za surgery OK? Always I think it iz like eef ein church lozt itz steeple ja? Eef we'ze dancing I vant it bawnsing!"
                            clear_dialog
                            talk lovely talk "I had surgery to make mine smaller."
                "\\"Rent has me acting silly.\\"":
                    set_screen pervert_03 1
                    choice:
                        talk pervert talk "Das ist sehr sad! Eef you lose deine haus Ich habe ein spare room. Ve could be roommates! Vurry <span class='writtenText'>'euro sex comedy'</span>!"
                        "[Non committal nod] \\"I'll consider it.\\"":
                            set_screen pervert_05 1
                            talk pervert talk "Genau!!!!"
                "\\"I'm thinking about getting into international finance.":
                    set_screen pervert_05 1
                    talk pervert talk "Oh ja!!! Go to Frankfurt skewel of internal finance! It'z ZUPER cool! If du had gone a few yearz back ich could az socked du off under za desk ja!"
        else:
            set_screen pervert_05 1
            talk pervert talk "Ja im Frankfurt we haz ein liddel moddo. <span class='writtenText'>'Poken das landmine und ein coin vill be mein. Poken das landmine ein more zeit und ich will explodieren.'</span>. Preddy cool advice ja!?"  
    jump pervert_menu

pervert_life:
    add data.pervert.talkCount -1
    set data.pervert.talkLife true
    set_screen pervert_03 1
    talk pervert talk "Du vanst life advice ja!? Pretty cool!"
    if (== $stats.day.value 2):
        clear_dialog
        set_screen pervert_01 1
        choice:
            talk pervert talk "Peobol always they are zaying <span class='writtenText'>'Nein nein nein! Don't az fun und pardy times! Iz bad fur dich to like ein liddel spahnkeng! Et urtz!'</span> But babey, pain is just a pardy in dein nerves! Ja! Eef it urtz oder ist scareh to do somezink it does nich mean iz bad to do et! Go kiss das scarry chik! Go play wiz zat landen minen! Az fun you knowz!"
            "[Nod] \\"I ate a cigarette the other day and it made my throat hurt a lot but it was kind of good and I'd do it again now that I think about it, so I get what you're saying.\\"" $data.ghost.deepthroatedCig:
                set_screen pervert_08 1
                talk pervert talk "Ja ich got preddy terrebul throad pain azer ich vent down on ein dikgurl! Ich did nicht realize sie hatte ein ten inch wurst! Very <span class='writtenText'>'womens suffrage'</span>! Super cool!"
            "[Nod] \\"Very true sir.\\"":
                run skip
    elseif (== $stats.day.value 3):
        clear_dialog
        set_screen pervert_02 1
        choice:
            talk pervert talk "Wissen Sie vas AGP means, Goazt?"
            "[Stick your hand up in the air excitedly] \\"It's the thing I was formally diagnosed with! Ain't this just my day!\\"" if $data.global.diagnosis_agp:
                set_screen pervert_03 1
                talk pervert talk "Oh nein nein!"
            "[Shake your head]":
                run skip
        set_screen pervert_05 1
        talk pervert talk "Etz advice for picking up za ladiiiiiiies! 'Always Go PARDY PARDY PARDY!' Super cool advice! Genau! Das parade tomorrow ist going to be a great place to meetz up wiz chikz und chikz wiz dikz! You should go und see ooh du meetz ja! Maybez you ezen bomps een to mich! Super cool! Vill du be topless fur za pardy ich wunder?!"
    elseif (== $stats.day.value 4):
        clear_dialog
        set_screen pervert_02 1
        talk pervert talk "Goazt I sink zeres many singz dat dikgurlz know zat all of us do not fizure out yet ja? Be who you are und zon't let neinbody tell you, man! Live dein own life and pardy! Just ein liddel think I az. Preddy <span class='writtenText'>'philosophy'</span>, ja?"
        clear_dialog
        "Frankurt Pervert frowns, and unprompted, continues."
        clear_dialog
        set_screen pervert_06 1
        talk pervert talk "Ja ah'm vurry vorried about tvink death. Ich hope zey find ein cure preddy soon."
    clear_dialog
    jump pervert_menu

pervert_self:
    add data.pervert.talkCount -1
    set data.pervert.talkSelf true
    set_screen pervert_03 1
    talk pervert talk "Wad!!!!!! Liddel yong mich? You'z so adorazul fur asking! Vurry cool! Wad ein flirt! I'm joking I'm joking!"
    if (== $data.pervert.self 0):
        set data.pervert.self 1
        if (roll pervert_self_joking_nasty nasty 20):
            talk nasty talk "He's only joking if you didn't find that sexy. This fucker is smart! We should copy him, we'd never feel shame again!" 
        clear_dialog
        set_screen pervert_00 1
        "Frankfurt Pervert slicks back his hair and flicks our his hand with a flourish. His hips gyrate to an imaginary beat."
        clear_dialog
        set_screen pervert_05 1
        choice:
            talk pervert talk "Em just a slick pardy luver frum Frankfurt wiz a degree en <span class='writtenText'>'international finance'</span>! E goddit fur mich az a liddel prezent avter za war, a liddel <span class='writtenText'>'T.L.C'</span> you know?"
            "[Squint] \\"You don't look very much like a soldier\\"":
                set_screen pervert_07 1
                choice:
                    talk pervert talk "Ja ich vaz een charge of accounting on ze panzer. Waz preddy fun Du weisst? \\"Sorry boyssss, eets zeit fur stoppen sie firing! We've gone ozer our efficency quota!\\" Prozerly eet iz why we lost ze war but ay whatezer you know I had fun you know?"
                    "[Point] \\"You lost the war. That's pretty embarrassing.\\"":
                        set_screen pervert_05 1
                        talk pervert talk "Ja but iz OK. I can be ay beet of a bottum when ich wantz to be so waz kind of foon to be a P.Oh.Double Yew, ja? Preedy keenky, though when zey beat mich with der rifle..."
                        set_screen pervert_06 1
                        talk pervert talk "Das was nicht sehr cool you know?"
                        clear_dialog
                        if (roll pervert_self_pow_orb orb 40):
                            talk orb talk "In his mind the war was a <span class='writtenText'>'twenzy-four hour pardy! Ja! Super cool!!!'</span>. The artillery fire was the <span class='writtenText'>'Svankeh beat!!!'</span>. He was not popular with his comrades."
                            if (roll pervert_self_pow_nasty nasty 20):
                                talk nasty talk "Except the particularly horny ones. The war was one big orgy, I reckon."
                                talk lovely talk "So disrespectful to our war dead! Our war herons! Tsk!"
    elseif (== $data.pervert.self 1):
        set data.pervert.self 2
        set_screen pervert_02 1
        choice:
            talk pervert talk "Ja zese radikal sufraggetes sayzat dikgurlz were raised wit boy prizalige but ich alwvays could tell who was eine futur dikgirl back im school. Alvays we were zrowing da inflated sheep bladder at zem during recess. Very funny at za time! But nich sehr toll diese days! Now ich atone by gizing zem 'boller head'."
            "[Nod] \\"Okay. Thank you for sharing.\\"":
                set_screen pervert_08 1
                talk pervert talk "Ja nein problem! Let me know iz you need mich to atone, genau?"
    elseif (== $data.pervert.self 2):
        set_screen pervert_06 1
        clear_dialog
        talk pervert talk "Goazt, I az killed ein lod of people during za var."
        talk pervert talk "So maney felled by meine panzer crew. So maney lives lozt. Fur was?"
        talk pervert talk "Endzeit."
        talk pervert talk "Weltuntergang."
        clear_dialog
        "He falls silent. Tall. Stoic even."
        wait 4000
        clear_dialog
        set_screen pervert_07 1
        talk pervert talk "Alles klar! Das wast deine past! Iz pardy zeit now! Super cool, ja!?"
    clear_dialog
    jump pervert_menu