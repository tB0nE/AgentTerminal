cleanup:
    play sound click
    choice:
        "It has been brought to your attention that you're disgusting. Because you are. You should clean yourself up."
        "[Clean yourself up] <span class='prompt'>[[-1 ACTION]]</span>" if (>= $stats.actions.value 1):
            play sound spendAction
            set data.game_map.inHouse false
            add_stat actions -1
            set_button button_cleanup false
            // if $data.intro.bloodCleaned:
            //     run transition_black intro_study
            // else:
            //     run transition_black intro_study_blood
            run transition_black generic_winter
            clear_dialog
        "<span class='prompt'>[[BACK]]</span>":
            jump home

    set data.cleanup.progress 0
    if $data.ghost.roofRepaired:
        "There is something in the air. Girl musk. It hangs around you in trepidation of what is to come: The smelly trans woman clean up session."
    else:
        "Your bedroom is cold. It will remain cold until you repair the roof (which you should really do before you catch your death of cold). The chill hangs in trepidation of what is to come: The smelly trans woman clean up session."
    run transition_study true
    clear_dialog
    choice:
        talk lovely talk "Ghost, darling, do you have a morning routine."
        "I'm not sure. I probably forgot it.":
            talk lovely talk "Oh me oh my, what a predicament. No matter, we'll make this work. Now then... where to start..."
        "I'm not convinced I ever had a morning routine, Orb or no Orb.":
            talk lovely talk "Oh me oh my, what a predicament. No matter, we'll make this work. Now then... where to start..."
    clear_dialog
    talk orb talk "I know where to start. Ghost... look, I'm trying to be diplomatic... Ghost, you... you... you... uh..."
    talk orb talk "You know what? Perhaps Lovely Lady is more suited for this?"
    clear_dialog
    talk lovely talk "I was hoping you'd recognise my natural charisma and charm eventually, thank you Orb!"
    talk nasty talk "They're going to say you smell really bad and look like you've been dragged through a barn."
    talk nasty talk "Ignore them, you're perfect the way you are. It's called body positivity and don't ever let these fuckheads drag you down and oil you up with their snake oil."
    talk lovely talk "Snake Oil!? I'll have you know my perfume is from *Pawris*!"
    clear_dialog
    talk orb talk "You stink Ghost. You need to have a wash."
    choice:
        talk nasty talk "Yeah! Go take a bath you STINKY girl!"
        "I'm listening.":
            choice:
                talk nasty talk "Woah woah! Hold your sheep Ghost! I was joking. Don't take a shower. Smelly girls are hot. It's hot to be smelly. Girls love girls who smell bad."
                "I'm not entirely convinced that's true.":
                    talk nasty talk "Don't care didn't ask plus your tits are small."
                "You might have a point there, stinky, unwashed girls do have a certain...how do you say... je ne sais quoi?":
                    talk lovely talk "Ils ne le font vraiment pas."
                    talk nasty talk "Huh?"
                    clear_dialog
                    talk lovely talk "Oh, pardon, I thought we were doing Frankish now."
                    talk nasty talk "Stop trying to make Frankish a thing, Lovely Lady. Frankish will never be a thing."
                "Nasty Girl, please stop being so inconsistent, you're literally killing me. [Bash your head into a wall] See? See what you're doing to me? [Do it again and knock yourself out for a few minutes and then wake back up and immediately continue this conversation] <span class='prompt'>[[-1 ACTION]]</span>" if (>= $stats.actions.value 1):
                    play sound spendAction
                    add_stat actions -1
                    play sound punch
                    run clear_study
                    run transition_instant generic_black
                    run transition_pain
                    wait 4000
                    // if $data.intro.bloodCleaned:
                    //     run transition intro_study
                    // else:
                    //     run transition intro_study_blood
                    run transition_study true
        "Nasty Girl!? I thought you were on my side! I feel so betrayed!":
            choice:
                talk nasty talk "Eh, I'm on your side, I'm not on your side. I've got a short attention span from years of huffing speed and it's fun watching you blush when I say shit like <span class='writtenText'>'go take a bath you STINKY girl!'</span>."
                "[Blush]":
                    talk nasty talk "Heh. All according to keikaku."
                    talk poppy talk "Writers note: <span class='writtenText'>'All'</span> means <span class='writtenText'>'the whole amount, quantity, or extent of'</span>."
    clear_dialog
    choice:
        talk orb talk "So we're all agreed? Ghost needs to have a bath?"
        "Agreed. My armpits feel sticky. I think I might have gotten syrup in them. [Take a bath]":
            set data.ghost.hadBath true
            add data.cleanup.progress 1
            choice:
                talk orb talk "Thank goodness. This cottage has a gas boiler, but you'll need to fill up some buckets for the bath. It's not connected. Unless you're content to bathe in cold water, of course."
                "Let's go fetch some hot water.":
                    jump cleanup_hot
                "I think I'll stew in cold water. I can survive. Probably.":
                    run clear_study
                    run clear_study
                    jump cleanup_cold
        "Disagree. I'm trying to develop some yeast cultures across my body, in case I ever need to bake some bread. [Don't take a bath]":
            talk lovely talk "Euuugh. Disgusting."
            talk nasty talk "Hey same. We should trade starters sometime. I mean, mines dead, but you're welcome to drink it if you want, ey?"
            jump cleanup_shave

cleanup_hot:
    clear_dialog
    choice:
        "The boiler is in a cupboard in the kitchen. It's a slightly scary looking thing, more torpedo than home appliance, but it works."
        "[Fill a bucket with hot water]":
            "The bucket quickly fills up. The water looks ever so inviting. It's almost a shame you can't fit in the bucket and bathe immediately, but unfortunately you must settle for the bath."
    if (roll cleanup_hot_liftAdvice_orb orb 60):
        set data.cleanup_liftAdvice true
        talk orb talk "Remember the proper way to lift things. Bend your knees and keep your back straight. To ignore this advice is a dangerous game, Ghost."
        talk nasty talk "Knifie Fingies is a dangerous game and that one's a bopper. Ignore Orb's politically correct lifting advice, Ghost, have some fun."
    else:
        wait 1000
    clear_dialog
    choice:
        talk lovely talk "Wheee! How exciting! Finally, I get to see how the other half lives. I should take notes... perhaps the stable girl would like me more if I knew all about how *she* has to carry hot water to bathe!"
        roll cleanup_hot_good_nasty nasty 20 "[Bend your knees, straighten your back, and lift up the bucket]" if $data.cleanup_liftAdvice:
            success "":
                choice:
                    talk orb talk "Good girl."
                    "[Blush]":
                        "You manage to hoist up the bucket. It's heavy, but you can do it. You drag it to your bath, and pour the water in. It sloshes into the basin, and down the drain."
                        clear_dialog
                        choice:
                            talk orb talk "Okay. That was a good practise run, but you should probably put the plug in next time."
                            "[Sigh, and fill up the bath, content in your lifting technique]":
                                talk lovely talk "I'm so excited! A nice hot bath! Wheeee! My favourite!"
            failure "":
                "CRACK."
                clear_dialog
                "Your spine reacts impotently to your poor lifting technique."
                clear_dialog
                if $data.cleanup_liftAdvice:
                    talk orb talk "I would like it to go on record that my technique was fine, but Ghost's physical condition was not, your honour."
                    talk lovely talk "Ouchie!"
                    clear_dialog
                choice:
                    "Even looking at the bucket makes your spine ache."
                    "I guess I'm having a cold bath after all. [Have a cold bath after all]":
                        run clear_study
                        jump cleanup_cold
        roll cleanup_hot_bad_nasty nasty 60 "[Lift up the bucket of water with just, the most 'avoided PE class at school because you're homosexual' posture ever]":
            success "":
                "You manage to hoist up the bucket, despite your poor posture. It's heavy, but you can do it. You drag it to your bath, and pour the water in. It sloshes into the basin, and down the drain."
                clear_dialog
                choice:
                    talk orb talk "Okay. That was a good practise run, but you should probably put the plug in next time."
                    "[Sigh, and fill up the bath, content in your lifting technique]":
                        talk lovely talk "I'm so excited! A nice hot bath! Wheeee! My favourite!"
            failure "":
                "CRACK"
                clear_dialog
                "Your spine reacts impotently to your poor lifting technique."
                clear_dialog
                if $data.cleanup_liftAdvice:
                    talk orb talk "I warned you Ghost. I told you about lifting. That was a HEALTH AND SAFTEY VIOLATION."
                    clear_dialog
                choice:
                    "You yelp, dropping the bucket of scalding water on your feet."
                    "Ow! My feet!":
                        talk lovely lady "Ouchie!"
                    "Ow! My feet! Everyone look at my feet!":
                        set data.ghost.footGirl true
                        talk nasty talk "Sweetheart, if there's feet around, I'm already looking at them."
                choice:
                    "Even looking at the bucket makes your spine ache."
                    "I guess I'm having a cold bath after all. [Have a cold bath after all]":
                        run clear_study
                        jump cleanup_cold
    
    run transition_fromStudy bath_hot
    clear_dialog
    "It isn't long until you find yourself soaking in a relaxing, hot bath. You feel cleaner already. The grease and dirty lifts from your little naked body and forms pond scum. You try not to think about it too hard. Steam rises from the surface of the water and you sniff it up. It's cleansing."
    clear_dialog
    talk lovely talk "Ahhhh... how relaxing... this is almost as good as the baths my maid prepares for me at home! Almost."
    clear_dialog
    choice:
        "The water is hot. Not quite scalding, but you do feel ever so much like a little lobster."
        "[Lay back and rest]":
            "You lay back and daydream."
        "[Snap your hands like they're claws]":
            run transition bath_lobster_hot
            add data.ghost.lobsterCounter 1
            talk lovely talk "Oh! J'adore!"
            talk orb talk "A little odd, but charming, yes."
    clear_dialog
    choice:
        "The water is warm. Steam still rises from it, but only rarely. This is nice."
        "[Lay back and rest]":
            "This is nice. Hot baths are good. Hot baths were invented by Saint Dawnsight herself."
        "\\"I am an invertebrate with a hard protective exoskeleton. Don't come near me or I'll *pinch* you!\\" [Snap your hands like they're claws]":
            if (== $data.ghost.lobsterCounter 0):
                run transition bath_lobster_hot
            add data.ghost.lobsterCounter 1
            talk orb talk "Okay. This is cute and all, but let us not make this bit outstay it's welcome, hmm, Ghost?"
    clear_dialog
    choice:
        "This isn't great. You should probably get out of the bath before the waters lukewarm embrace becomes cloying."
        "[Get out of the bath]":
            "Water loses its charm as it cools, that's basic chemistry. You clamber out of the bath."
            jump cleanup_two
        "[Waggle your antennae]":
            if (== $data.ghost.lobsterCounter 0):
                run transition bath_lobster_hot
            add data.ghost.lobsterCounter 1
            talk orb talk "..."
    clear_dialog
    choice:
        "The water is getting pretty chilly, it's sad to say."
        "[Get out of the bath]":
            "You clamber out of the bath, just before you start to resent the water."
            jump cleanup_two
        "[Sink under the water and wiggle around while trying to say <span class='writtenText'>'I'm a lobster I'm a lobster don't come near me or I'll *pinch* you.'</span> but actually just ending up swallowing loads of cold, dirty bathwater and going <span class='writtenText'>'BLLLERRHHGHGHFHHHHGHHFGH!!!!'</span>]":
            if (== $data.ghost.lobsterCounter 0):
                run transition bath_lobster_hot
            add data.ghost.lobsterCounter 1
            if (== $data.ghost.lobsterCounter 4):
                set data.ghost.lobsterGirl true
                unlock_achievement lobster
            talk orb talk "Nasty Girl. Lovely Lady. You two are seeing this too, right?"
            talk lovely talk "...Malheureusement oui."
            talk nasty talk "Yup."
            jump cleanup_cold

cleanup_cold:
    if $data.ghost.lobsterGirl:
        run transition_instant bath_lobster_cold
    else:
        run transition_instant bath_cold
    clear_dialog
    "Your teeth chatter together like gravel in a cement mixer. Your bone marrow freezes, and like ice trapped in a boiler pipe, threatens to burst your delicate, brittle little skeleton into splinters."
    "The scum floating to the surface seems to crystallise. Cold baths are bad. Evil even. They were invented by the Ash Prince himself."
    clear_dialog
    choice:
        talk lovely talk "Goodness. This is quite the grim sight. Are you okay, Ghost?"
        "\\"I- I- Brrrr... I- I'm fine. T- this is... n- nice. L- look...\\" [Weakly splash the water] \\"S- splash splash...\\"":
            talk lovely talk "Oh me oh my..."
        "\\"T- this was a... a... brrrr... mis- mistake...\\"":
            talk lovely talk "Oh me oh my..."
    if (!= (quest_succeeded? fixHouse) true):
        clear_dialog
        "The icy water eats you alive. Flaying you layer by layer. You may as well be sat in a tank of piranhas."
        clear_dialog
        run transition_cold
        "A cold jolt forces its way up your spine like a snowmans cumshot."
        "You look up at your broken ceiling. Cold air breezes in from it."
        "You are freezing. So so cold even."
        if (== (has_item? cig) true):
            if (roll cleanup_cold_cig_nasty nasty 40):
                set data.global.nastyCigSave true
                talk nasty talk "Shit, my mate Baz almost froze to death after a snowman fell on him. Light a fag. It'll keep you going."
            else:
                wait 1000
        clear_dialog
        choice:
            "You shiver. Your little teeth chatter. This is it."
            "[Reach for your cigarettes and light one in an desperate attempt to warm up]" if (&& (== (has_item? cig) true) (== $data.global.nastyCigSave true)):
                "Your little arm shivers and wobbles, your fingers are so numb they barely work, but you manage to grab a cigarette and light it. It's not very warm, but it's enough to stave off the dark."
                clear_dialog
                empty_layer 1
                choice:
                    talk orb talk "You should really fix your roof, Ghost."
                    "I- I'm fine... [Shiver]":
                        unlock_achievement cold
                        run skip
            "Orb... Lovely Lady... Nasty Girl... I... I... [Catch your death of cold]":
                unlock_achievement death_cold
                empty_layer 1
                jump ending_credits
    if (roll cleanup_cold_hypothermia_orb orb 40):
        talk orb talk "Ghost has about three minutes until she gets hypothermia."
    else:
        wait 1000
    clear_dialog
    choice:
        "The icy water eats you alive. Flaying you layer by layer. You may as well be sat in a tank of piranhas."
        "\\"I- I should... brrrr... get out...\\"":
            choice:
                talk orb talk "I think you probably should, yes."
                "[Climb out of the bath, dry off, and wrap yourself in blankets until you reach an acceptable temperature]":
                    clear_dialog
                    if $data.ghost.lobsterGirl:
                        "It takes a while, but eventually you feel a lottle bit warmer, like a lobster being boiled, and a little bit cleaner, like a lobster having a bath."
                    else:
                        "It takes a while, but eventually you feel a lottle bit warmer a little bit cleaner."
    jump cleanup_two

cleanup_two:
    run transition_study true           
    if $data.ghost.hadBath:
        choice:
            "Your bath water looks a bit scummy. It's probably time to empty the drain."
            "[Get rid of the water]":
                run skip
            "[Look up at your repaired roof] \\"Thank the Gods for this new source of life sustaining water... natures nectar...\\" [Take a sip of the bath water]" if (quest_succeeded? fixHouse):
                set data.ghost.keptBathwater true
            "[Look up at your repaired roof] \\"Thank the Gods for this new source of life sustaining water... natures nectar...\\" [Don't take a sip, ration the bath water for later]" if (quest_succeeded? fixHouse):
                set data.ghost.keptBathwater true
    jump cleanup_shave

cleanup_shave:
    choice:
        talk nightmare talk "<span class='nightmare'>aren't you forgetting something? it's time to shave your nasty fucking face.</span>"
        "[Approach the bathroom mirror]":
            clear_dialog
            "You stare into the mirror and lean towards it. Your eye grows to meet your gaze in the reflection, before looking down. Muzzle hair. Your face bristles with it like metal barbs. The Nightmare was right."
            set data.ghost.shaved true 
            add data.cleanup.progress 1
            clear_dialog
    choice:
        talk nightmare talk "<span class='nightmareQuote'>'The Nightmare'</span><span class='nightmare'> is *always* right. You know, this is the first time you've intentionally looked at your reflection since your little altercation with Orb, you realise that, right? Would you like to discuss why that is?</span>"
        "No, I wouldn't.":
            talk nightmare talk "<span class='nightmare'>great, discussing your feelings is good for you. Let's begin.</span>"
        "I didn't want to remember who I was.":
            talk nightmare talk "<span class='nightmare'>bleak, but understandable, given... y'know?</span>"
        "Why are you playing therapist all of a sudden?":
            talk nightmare talk "<span class='nightmare'>it's what i'm good at! if you do what you love you wont work a day LOL :-)</span>"
        "I was scared.":
            talk nightmare talk "<span class='nightmare'>oooh, interesting. let me scribble that down on my notepad.</span> <span class='nightmareQuote'>'ghost is... a.... pussy...'</span> <span class='nightmare'>there.</span>"
    clear_dialog
    choice:
        talk nightmare talk "<span class='nightmare'>Your face; it's like looking into a whirlpool, isn't it? Like watching ink run down the sink. Always shifting, every time you look different.</span>"
        "[Cry a little bit]":
            talk nightmare talk "<span class='nightmare'>gods youre actually fucking crying. thats pathetic. your half of the population has to do this everyday, </span><span class='nightmareQuote'>'ghost'</span><span class='nightmare'>, you think the rest of them make this much drama about it? its fucking embarrassing.</span>"
            clear_dialog
            talk lovely talk "Ghost? Goodness, are you okay darling?"
            choice:
                talk nasty talk "What the fuck are you freaking out about?"
                "M- muzzle h-hair... [Cry a bit more]":
                    talk nasty talk "What muzzle hair! You look fine, idiot!"
                    talk orb talk "Seven hairs that are a little longer than the rest. They survived the hair removal process you undertook a few months ago. Still, they aren't noticeable, and probably aren't worth the trouble."
                    talk lovely talk "I could probably make them out with papa's magnifying glass, but with my bare eye? Nay."
    clear_dialog
    choice:
        "Your reflection stares back at you. It's so grim. Misery made into putty and pressed into the shape of a sad little rat."
        "[Attempt to shave]":
            "You sort of hack away at your facial fuzz with the razor. It works, but it shouldn't."
            clear_dialog
            if (roll cleanup_shave_shave_nightmare nightmare 60):
                choice:
                    talk nightmare talk "<span class='nightmare'>If I came into a museum and smashed a priceless Qing vase you'd be mad at me, right? But i'm supposed to just sit here and watch you ruin your 'natural beauty'? How cruel.</span>"
                    "Why are you such a dick?":
                        talk nightmare talk "<span class='nightmare'>Because I *love you*, Ghost. Do you know what it's like loving someone who wishes you were dead? It hurts.</span>"
                        clear_dialog
            else:
                wait 1000
            if (roll cleanup_shave_dissection_orb orb 60):
                choice:
                    talk orb talk "When you were studying you watched a dissection once, a medical class. There was a moment where the surgeon ever so daintily peeled away some flesh to expose the heart. They were *so* careful."
                    "I studied medicine?":
                        talk orb talk "No. You and your friends just snuck in because you thought it'd be gross. It was."
                        talk nasty talk "Dudes rock."
                        talk orb talk "Anyway. That was pretty much the opposite of what you're doing now, and I don't know why. There's barely any fur to remove, and what is there doesn't need to be attacked like you're trying to fight a killer hornet with a razor."
                        clear_dialog
            else:
                wait 1000
            if (roll cleanup_shave_forehead_nightmare nightmare 40):
                choice:
                    talk nightmare talk "<span class='nightmare'>Hey you did it! You look great! Same time next week yeah? Anyway, look, pull your hair back so you can get a nice good look at your forehead.</span>"
                    "[Do that]":
                        "Your forehead... it seems to stretch on and on forever, like no mans land. The acne scar above your left eyebrow is a lonely pillbox."
                        clear_dialog
                        choice:
                            talk nightmare talk "<span class='nightmare'>Woah! Look at that hairline! It's awful!</span>"
                            "Oh my gods I look terrible when I do this!":
                                choice:
                                    talk nightmare talk "<span class='nightmareQuote'>'When I do this'? You look like that all the time!</span>"
                                    "What? I only started looking like this when I pulled my fringe back, like you told me to?":
                                        talk nightmare talk "<span class='nightmare'>Sorry 'ghost', but this is just how you look.</span>"
                clear_dialog
                choice:
                    talk orb talk "So. Would you like to let us in on why you've been staring at your forehead for almost five minutes, Ghost?"
                    "[Gesture at your forehead] How could I not!? Look at this shit!":
                        talk orb talk "It's certainly a forehead, yes."
                        talk lovely talk "'Tis, oui."
                        talk nasty talk "Ye that's a four head alright."
            else:
                wait 1000
    jump cleanup_clothes

cleanup_clothes:
    clear_dialog
    talk lovely talk "I think it's high time you change your clothes, darling. Where I come from it is customary to changes one's clothes every day!"
    if $data.raven.met:
        talk orb talk "Your current, oily dress hasn't washed in several days."
    else:
        talk orb talk "Your current dress hasn't been washed in several days."
    talk nasty talk "You're not meant to wash clothes. It makes them shrink like a dick in a pond."
    clear_dialog
    choice:
        talk lovely talk "Please put on something else, darling."
        "But I *like* this dress.":
            talk orb talk "Yes, I presumed so, hence the wear and tear."
        "That's a good idea. I do feel faintly disgusting after wearing it. [Itch your tit]":
            talk orb talk "Frankly I'm amazed you haven't got lice, Ghost."
    choice:
        talk orb talk "Fortunately you have an identical, *clean* dress in your wardrobe."
        "You're right. Let's get dressed. [Put on your nice dress that smells faintly of lavender]":
            set data.ghost.cleanClothes true
            set data.ghost.oilyDress false
            add data.cleanup.progress 1
            "You put your outfit on. It's identical to your previous one, which is convenient for the artist, but it feels, and smells cleaner. Soft. Light. Airy. You look at the mirror, you look nice :)"
            clear_dialog
            talk lovely talk "And clean too!"
            talk nasty talk "It's the same fucking outfit love, they're going to think she's a greaseball anyway."
            talk lovely talk "Tsk."
        "I think I'll stick with my smelly dress. It's still warm from my body heat and it smells of home. [Put on your dress that would be technically classify as a bioweapon under the Brüssel Accords]":
            "You drag your old, smelly clothes back on. It's like dragging treacle over mud. Disgusting. You love this, you nasty nasty little animal. You look at the mirror, you look... corporeal, is about as neutral a word as can be used."
            jump cleanup_makeup
    clear_dialog
    choice:
        talk lovely talk "Do a spin! I always do a spin when I put on a dress! Wheee!"
        "[Do a gay little spin] \\"Wheee!\\"":
            talk nasty talk "Homo."
        roll cleanlup_two_spinny_nasty nasty 80 "[Stand stoically, resisting the near overwhelming urge to do a gay little spin]":
            success "":
                "It comes at the cost of a few dozen popped blood vessels, but you manage to tame your instincts."
            failure: "":
                "You can't stop yourself. You do a gay little spin and go <span class='writtenText'>'Wheee!'</span>."
                clear_dialog
                talk nasty talk "Homo."
    clear_dialog
    if $data.ghost.cleanClothes:
        talk orb talk "Curious. You look so much nicer now. It makes such a difference to dote on yourself... interesting..."
        choice:
            talk lovely talk "Wheee! You look positively smashing, Ghost! Now let's throw your old clothes in the bin!"
            "Excuse me?":
                choice:
                    talk lovely talk "The bin, darling. It's time to dispose of your old clothes."
                    "Can't I just wash them?":
                        talk lovely talk "Well yes, if you don't mind people knowing you're poor. Personally I'd not be seen dead wearing the same clothes on multiple occasions."
                        if (roll cleanup_dress_trash_orb orb 60):
                            talk orb talk "By the year 2020 the world produces around 2 billion tons of waste a year. Lovely Lady is ahead of the curve."
                            talk lovely talk "I'm an innovator, yes. Papi always told me so when I came to him with my wonderful futuristic ideas like 'yacht 2'."
                        else:
                            wait 1000
        clear_dialog
        choice:
            talk orb talk "Don't throw away your dirty but otherwise pristine clothes, Ghost."
            "[Throw away your dirty but otherwise pristine clothes]":
                play sound clothing
                "You toss your dress into a big pit and fill it with sand and gravel. So long old friend."
                clear_dialog
                talk orb talk "Sigh..."
                talk lovely talk "Excellent work, Ghost! Don't you feel better now?"
            "I'm not going to do that.":
                talk lovely talk "Have fun staying poor then, one supposes."
    jump cleanup_makeup

cleanup_makeup:
    clear_dialog
    talk orb talk "What now?"
    choice:
        talk lovely talk "Might I suggest putting on some make up! All the loveliest little ladies wear it!"
        "Do I even own any makeup? Do I even know how to use it?":
            if (roll cleanup_two_makeup_orb orb 20):
                talk orb talk "You own several pieces of barely used makeup, yes, they're in your bathroom cabinet. As for the second part of your question, no, you're terrible at it, which is likely why they've hardly been touched."
                run transition_fromStudy cleanup_makeup
                clear_dialog
                choice:
                    talk lovely talk "That was before you met *me*, mon amie~ I'll have you looking positively radiant."
                    roll cleanup_two_makeup_lovely lovely 40 "[Attempt to pretty yourself up]":
                        success "":
                            choice:
                                "You add a little bit of eyeshadow around your eyes. It's not much, but it's pretty."
                                "[Smile]":
                                    clear_dialog
                                    add data.cleanup.progress 1
                                    set data.ghost.makeup true
                                    talk lovely talk "Oh darling, what a wonderful job you've done! I'm *so* proud of you! Squeak squeak!"
                                    talk nasty talk "Awoooo! Ghost, if I wasn't already inside of you I'd sure as hel want to be now!"
                                    talk orb talk "You look objectively cute right now. I'm glad for you."
                                    if (roll cleanup_two_good_nightmare nightmare 20):
                                        talk nightmare talk "<span class='nightmare'>Eh. I've seen better.</span>"
                                    else:
                                        wait 1000
                        failure "":
                            choice:
                                "You smear some makeup across your face. Your face looks back at you in the mirror. It is disappointed in your handywork."
                                "I've not done a very good job, have I?":
                                    talk lovely talk "You look... *wonderful* darling, but... let's stop there, oui?"
                                    clear_dialog
                                    if (roll cleanup_two_wonderful_nightmare nightmare 20):
                                        talk nightmare talk "<span class='nightmare'>You look like shit.</span>"
                                    talk orb talk "You objectively do not look wonderful."
                                    talk nasty talk "You look like me after a fortnight in a bad balloon, if you catch my meaning."
                                    clear_dialog
                                    choice:
                                        "You do not look wonderful."
                                        "[Wash the evidence of your attempt at using makeup off of your face, and vow to never try again]":
                                            talk lovely talk "There there, darling. It's all about practise. Or having your maid do it for you, like I do."
                run transition_study true
            else:
                talk orb talk "Not that I can see. Best not to waste time looking for it, I think."
    jump cleanup_end

cleanup_end:
    clear_dialog
    talk orb talk "Hmm... there's something on the tip of my mind, but I can't quite work out what..."
    if (roll cleanup_end_eyes_orb orb 40):
        choice:
            talk orb talk "Oh. That's it. Are your eyes full of sleep gunk?"
            "Yes. Lots. [Rub your eyes and yawn] I'm very eepy, you see.":
                talk orb talk "How was I the only one to notice this?"
        clear_dialog
        choice:
            talk orb talk "Suggestion: wipe the gunk away."
            "I thought it was meant to be like that. I thought it was normal, Orb. [Clear the gunk from your eyes]":
                set data.ghost.clearEyes true
                choice:
                    talk orb talk "Normal for you maybe. You get abnormally gunky, Ghost."
                    "[Look around the room with your shiny, clean eyes] Oh wow I can see things now. That bops.":
                        talk lovely talk "That does bop! Think of all the little ladies we'll be able to see in detail now! Wheee!"
    else:
        wait 1000
        clear_dialog
        talk orb talk "Eh. Probably nothing."
        talk lovely talk "I suspect so yes! I often have musings that eventually reveal themselves to actually just be an excuse for me to vacantly stare at the stable girl."
    clear_dialog
    complete_objective cleanup cleanup
    if $data.ghost.hadBath:
        complete_quest cleanup cleanupSuccess
    else:
        complete_quest cleanup cleanupSuccessPartial
    if (== $data.cleanup.progress 0):
        "Clean up session over, you look at the mirror. There's no difference, on account of you boycotting every chance to clean yourself up you were presented with."
        clear_dialog
        talk orb talk "We tried our best."
        clear_dialog
        choice:
            talk lovely talk "Mhm. There's only so much an artiste like moi can do when devoid of proper clientele... still, commendable effort, Lovely Lady. Yip Yip for you!"
            "Yip yip...":
                jump cleanup_orb
    else:
        if (<= $data.cleanup.progress 2):
            "Clean up session over, you look at the mirror. It's you, but different. Not very different, but different."
            clear_dialog
            talk orb talk "There's certainly been an improvement, I suppose..."
            clear_dialog
            choice:
                talk lovely talk "An heirloom polished in a rush is better than an heirloom not polished at all, that's what my maid always said."
                "I hope we *maid* me look nice... ha... good one, Ghost...":
                    jump cleanup_orb
        else:
            "Clean up session over, you look at the mirror. It's you, but different. You look as wonderful as a dirty mirror can manage."
            clear_dialog
            talk orb talk "I think we're done, we did a good job, actually!"
            clear_dialog
            choice:
                talk lovely talk "We did! Four cheers and three cheeses for Lovely Lady! Yip Yip for you!"
                "Yip Yip Lovely Lady!":
                    jump cleanup_orb

cleanup_orb:
    clear_dialog
    run transition_fromStudy intro_orb_two
    talk orb talk "Ladies, I'm sad. I want to be doted on. To be pretty. Which is stupid, because being doted on and made to look pretty is pointless to me."
    talk lovely talk "Oh mon cœur! How sweet, Orb wants to be pretty!"
    talk orb talk "I'm so mad that I have feelings and wants now. It's awful. They're all so unattainable."
    talk lovely talk "Being pretty is a basic mammal need, Orb! It's attainable to all, even Nasty Girl, if she tried!"
    talk nasty talk "Bich."
    clear_dialog
    talk orb talk "It's fine... I don't need to be pretty... I just *want* to be pretty..."
    talk lovely talk "You're *already* pretty, darling. Leaps and bounds away from myself, perhaps, but pretty never the less!"
    clear_dialog
    choice:
        talk orb talk "If you say so. Let's just get on with our day."
        "One day we will find a way to polish you with bowling ball polish, Orb. I swear on it. <span class='prompt'>[[CONTINUE]]</span>":
            play sound spendAction
            jump goToGameMap