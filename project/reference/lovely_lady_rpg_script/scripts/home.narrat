home:
    if $data.game_map.inMap:
        set data.game_map.inMap false
        run hideButtons greyed
    clear_dialog
    if (!= $data.game_map.inHouse true):
        set data.game_map.inHouse true
        run hideButtons hidden
        if (quest_succeeded? fixHouse):
            run transition_black game_map_home_fixed
        else:
            run transition_black game_map_home
    run game_prompts

home_loadButtons:
// HRTEND //
    if (has_item? hrt):
        if $data.game_map.inPrompts:
            set_button button_hrt_end greyed
        else:
            set_button button_hrt_end true

// FIXHOUSE //
    if (&& (objective_started? fixHouse fixHouse) (has_item? nails) (has_item? hammer) (has_item? plank)):
        if $data.game_map.inPrompts:
            set_button button_fixHouse greyed
        else:
            set_button button_fixHouse true

// CLEANUP //
    if (&& (quest_started? cleanup) (!= (quest_completed? cleanup) true)):
        if $data.game_map.inPrompts:
            set_button button_cleanup greyed
        else:
            set_button button_cleanup true

// ARTICLE
    if (&& (objective_started? writer article) (== $stats.day.value 2) (!= (objective_completed? writer article) true)):
        if $data.game_map.inPrompts:
            set_button button_article greyed
        else:
            set_button button_article true

// FICTION
    if (&& (objective_started? writer fiction) (!= (objective_completed? writer fiction) true) (|| (== $stats.day.value 2) (== $stats.day.value 3))):
        if $data.game_map.inPrompts:
            set_button button_fiction greyed
        else:
            set_button button_fiction true

// NEWSPAPER //
    if (!= $data.newspaper.readToday true):
        if $data.game_map.inPrompts:
            set_button button_newspaper greyed
        else:
            set_button button_newspaper true

// RADIO //
    if (!= $data.global.radioDone true):
        if $data.game_map.inPrompts:
            set_button button_radio greyed
        else:
            set_button button_radio true

// SLEEP //
    if $data.game_map.inPrompts:
        set_button button_sleep greyed
    else:
        set_button button_sleep true

// WASTETIME //
    if $data.game_map.inPrompts:
        set_button button_wasteTime greyed
    else:
        set_button button_wasteTime true

// RETURN //
    if $data.game_map.inPrompts:
        set_button button_return greyed
    else:
        set_button button_return true
        
home_wasteTime:
    play sound click
    choice:
        "Is it really wise to waste time, when you are so so busy and the days are so so short?"
        "It is. [Waste some time] <span class='prompt'>[[-1 ACTION]]</span>":
            play sound spendAction
            add_stat actions -1
            choice:
                "You waste away some time, doing nothing worth Poppy writing about. You, dear sweet reader, can decide what Ghost was up to."
                "<span class='prompt'>[[CONTINUE]]</span>":
                    play sound spendAction
                    jump home
        "<span class='prompt'>[[BACK]]</span>":
            jump home

home_sleep:
    play sound click
    choice:
        "Is it really time to go to sleep? It feels like you barely had time to wake up..."
        "[Go to sleep] <span class='prompt'>[[End the day]]</span>":
            play sound spendAction
            choice:
                "Certain events may no longer be available when you wake up. Stories, friendships, self-actualisation: All can be lost to the cloying embrace of unconsciousness. Sleep is a curse laid on mammals by a cruel god. One day can ruin your life. You deserve better, but these facts will never change. Also, your bed *might* have lice in it. Are you *sure* you wish to sleep?"
                "<span class='prompt'>[[End the day]]</span>":
                    play sound spendAction
                    jump dream
                "<span class='prompt'>[[BACK]]</span>":
                    jump home
        "<span class='prompt'>[[BACK]]</span>":
            jump home