game_prompts:
    set data.game_map.inPrompts true
    clear_dialog

    if (&& (== $data.global.visitedMemorial true) (== $data.global.visitedMovieTheater true) (== $data.global.visitedPark true) (== $data.global.prideAttended true) (!= $data.gamemap.touristAchievment true)):
        set data.global.touristAchievment true
        unlock_achievement tourist

// INTRO //
    // TUTORIAL PROMPT //
    if (!= $data.gamemap.tutorialDone true):
        set data.gamemap.tutorialDone true
        talk poppy talk "Hello! It's me! Poppy!" 
        talk poppy talk "This is the map screen, isn't it pretty? I think Mia did a very good job! Don't you?"
        clear_dialog
        set data.gamemap.mia (text_field "Do you think Mia did a good job with the map screen art?")
        if (|| (== $data.gamemap.mia "yes") (== $data.gamemap.mia "Yes") (== $data.gamemap.mia "YES")):
            talk poppy talk "Great! I'm glad we agree!"
        elseif (== $data.gamemap.mia ""):
            talk poppy talk "Pah, the 'strong silent' type, are we? How amusing."
        else:
            if (|| (== $data.gamemap.mia "no") (== $data.gamemap.mia "No") (== $data.gamemap.mia "NO")):
                talk poppy talk "R- really? That's a crying shame..."
                talk poppy talk "I'll see if I can do something about that, hold tight!"
                clear_dialog
                run transition miacomic
                wait 8000
                run transition game_map
            else:
                talk poppy talk "I didn't quite catch that, but I assume you agree with me!"
        clear_dialog
        talk poppy talk "Anyway, while it's a bit empty right now, the map screen will show you all of the places Ghost can go to!"
        talk poppy talk "Each is displayed with a cute little icon, which you can click on to read a short description of what Ghost plans on getting up to there, as well as how many <span class='prompt'>ACTIONS</span> it will cost."
        talk poppy talk "You can always change your mind, so don't be afraid to click around and decide what you want to do without experiencing the terror of commitment!"
        clear_dialog
        talk poppy talk "Additionally, when Ghost's cottage becomes available on the map, you can use it to access some additional <span class='prompt'>ACTIONS</span>, including the ability to waste time or go to sleep early, so make sure you check that out later!"
        clear_dialog
        talk poppy talk "Okay, bye again!"
        clear_dialog

// SLEEP PROMPT
    if (== $stats.actions.value 0):
        set data.game_map.inMap false
        set data.game_map.inHouse false
        run transition_instant dealer_sky
        "Your eyelids grow heavy. Weighed down by six actions worth of sleepy dust. The <span class='goldItalic'>golden light</span> calls for you."
        clear_dialog
        set data.game_map.inPrompts false
        jump dream

// HRT //
    // NKVD PROMPT
    if (&& (== $stats.day.value 2) (!= $data.global.gicAttended true) (== $stats.actions.value 3) (!= $data.gamemap.nkvdPromptOne true)):
        set data.gamemap.nkvdPromptOne true
        talk orb talk "This is probably your last chance to get to your GIC appointment on time. It's do or die, Ghost."
    if (&& (== $stats.day.value 2) (!= $data.global.gicAttended true) (< $stats.actions.value 3) (!= $data.gamemap.nkvdPromptTwo true)):
        set data.gamemap.nkvdPromptTwo true
        choice:
            talk orb talk "That's it, you've missed your GIC appointment. Sorry Ghost."
            "Oh crackers! Well that's me told.":
                clear_dialog
                wait 1000
    // NKVD (ALT) PROMPT
    if (&& (== $stats.day.value 3) (!= (objective_started? hrt pharmacy) true) (!= (objective_started? hrt private) true) (!= $data.global.diagnosis_iv true) (!= $data.gamemap.privatePrompt true)):
        set data.gamemap.privatePrompt true
        choice:
            talk orb talk "A thought occurs. While you may have bungled your chance to get hormones yesterday, there is another path we could take... a path shrouded in darkness and evil."
            "There is?":
                talk orb talk "There is a private clinic in Bluehills. One with no waiting list, somehow. They're open during the day, but close early evening, so let's not dilly dally for too long."
                talk nasty talk "Orb said <span class='writtenText'>'dilly dally'</span>."
                talk orb talk "One thing I'm *less* sure about is *if* we can afford it..."
                if (roll game_map_nkvdAltPromp_nightmare nightmare 20):
                    talk nightmare talk "<span class='nightmare'>That's a big *big* if for a workshy creep like you,</span> <span class='nightmareQuote'>'ghost'.</span>"
                    clear_dialog
                talk nasty talk "Orb said <span class='writtenText'>'dilly dally'</span>."
        start_objective hrt private
        clear_dialog
        wait 1000
        //run hideButtons hidden
        set data.game_map.inPrompts false
        run game_map_loadButtons
    // PHARMACY PROMPT
    if (&& (objective_started? hrt pharmacy) (!= (objective_completed? hrt pharmacy) true) (>= $stats.day.value $data.global.hrt_nextStageDay) (!= $data.gamemap.pharmacyAltPromptDone true)):
        set data.gamemap.pharmacyAltPromptDone true
        talk orb talk "Your prescription should be available at the chemist's by now. 'Should' being a slightly hazy word when the healthcare system is involved."
        clear_dialog
        wait 1000
    // PHARMACY PROMPT (ALT)
    if (&& (objective_started? hrt pharmacyReturn) (!= (objective_completed? hrt pharmacyReturn) true) (>= $stats.day.value $data.global.hrt_nextStageDay) (!= $data.gamemap.pharmacyAltPromptDone true)):
        set data.gamemap.pharmacyAltPromptDone true
        talk orb talk "Your prescription should be available at the chemist's by now. For real, this time."
        clear_dialog
        wait 1000
    // DEALER PROMPT
    if (&& (!= (objective_started? hrt dealer) true) (!= (has_item? hrt) true) (== $stats.day.value 4) (!= $data.gamemap.dealerPrompt true)):
        if (roll game_map_dealerPrompt_orb orb 90):
            set data.gamemap.dealerPrompt true
            choice:
                talk orb talk "Gah!"
                "Oh no! Orb just had a seizure! Oh well there's other orbs...":
                    choice:
                        talk orb talk "Light bolt lightning! Like a searchlight! A vision! Lunden Road! Tonight! She will be there! Shining bright! Lady Moonshine! The one who holds the oestrogen! La sua luce santa cammina tra noi, noi la seguiamo e il chiaro di luna ci segue auuuuuugh!!!"
                        "Holy crackers, that seems like something I should check out!":
                            start_objective hrt dealer
                            talk orb talk "Non riesco a smettere di parlare italiano! Aiuto!"
            clear_dialog
            wait 1000
        else:
            wait 1000
            clear_dialog
            wait 1000
    // DEALER PROMPT (ALT)
    if (&& (objective_started? hrt dealer) (<= $stats.actions.value 2) (!= $data.gamemap.dealerPromptAlt true)):
        set data.gamemap.dealerPromptAlt true
        if $data.dealer.stickers:
            talk orb talk "Lunden Road. Tonight. She will be there. Lady Moonshine. Bring stickers."
        else:
            if (|| $data.dealer.priceGuessed $data.dealer.priceKnown):
                if $data.dealer.priceKnown:
                    talk orb talk "Lunden Road. Tonight. She will be there. Lady Moonshine. Bring thirty five pounds."
                else:
                    talk orb talk "Lunden Road. Tonight. She will be there. Lady Moonshine. Bring.... I don't know, like thirty pounds?"
            else:
                talk orb talk "Lunden Road. Tonight. She will be there. Lady Moonshine."
        clear_dialog
        wait 1000

// SINNER //
    // APARTMENT PROMPT
    if (&& (quest_started? sinner) (objective_started? sinner apartment) (<= $stats.actions.value 1) (!= $data.gamemap.apartmentPrompt true)):
        set data.gamemap.apartmentPrompt true
        talk orb talk "The Sinner is at her apartment now. If you want to see her you best not dilly dally."
        talk nasty talk "Orb said <span class='writtenText'>'dilly dally'</span>."
        clear_dialog
        wait 1000
    // ARCHIVE PROMPT
    if (&& (objective_started? sinner archive) (== $stats.day.value 3) (!= $data.gamemap.sinnerArchivePromptDone true)):
        set data.gamemap.sinnerArchivePromptDone true
        talk orb talk "The Sinner is waiting for your outside the town archive as part of her scheme to find salvation."
        clear_dialog
        wait 1000
    // WOODS PROMPT
    if (&& (objective_started? sinner woods) (== $stats.actions.value 6) (== $stats.day.value 4) (!= $data.gamemap.sinnerWoodsPromptDone true)):
        set data.gamemap.sinnerWoodsPromptDone true
        talk orb talk "The Sinner is waiting for you outside the woods, if you plan on walking with her you shouldn't wait too long. Her patience is thin today."
        clear_dialog
        wait 1000
    // WOODS PROMPT TWO
    if (&& (objective_started? sinner woods) (== $stats.actions.value 5) (== $stats.day.value 4) (!= $data.gamemap.sinnerWoodsPromptTwoDone true)):
        set data.gamemap.sinnerWoodsPromptTwoDone true
        talk orb talk "The Sinner is still waiting for you outside the woods, if you plan on walking with her this is your last chance before she gives up on you."
        clear_dialog
        wait 1000
// WRITER //


// WEAPON //


// CRYPTO //


// COMET //
    // COMET PROMPT (ONE)
    if (&& (<= $stats.actions.value 4) (== $stats.day.value 3) (!= $data.gamemap.cometPrompt true)):
        set data.gamemap.cometPrompt true
        talk orb talk "Apologies for the abrupt interjection, but there's going to be a comet passing over tonight."
        talk orb talk "We should go watch it. It'll be nice and clear in the fields outside the glow of the city."
        //start_quest comet
        clear_dialog
        wait 1000
    // COMET PROMPT (TWO)
    if (&& (== $stats.actions.value 1) (== $stats.day.value 3) (!= $data.gamemap.cometPromptAlt true)):
        set data.gamemap.cometPromptAlt true
        talk orb talk "Hey, if you want to go see that comet, which you obviously do, now's the time."
        clear_dialog
        wait 1000

// DAWNSIGHT //
    // CHURCH PROMPT
    if (&& (!= (quest_started? church) true) (== $stats.actions.value 6) (== $stats.day.value 2) (!= $data.gamemap.cathedralOpenPrompt true)):
        set data.gamemap.cathedralOpenPrompt true
        play sound bells
        "The bells of Bluehills cathedral chime in the distance. Mass is in session this morning. You find yourself strangely compelled by the sound. By the stirring of <span class='goldItalic'>something</span>."
        start_quest church
        clear_dialog
        wait 1000
    if (&& (!= (objective_completed? church church) true) (== $stats.actions.value 3) (== $stats.day.value 2) (!= $data.gamemap.cathedralClosingPrompt true)):
        set data.gamemap.cathedralClosingPrompt true
        play sound bells
        talk orb talk "The Cathedral is open most of the day, but it'll be closing once it gets dark, which is... soon. If you want to do whatever it is you wanted to do there, you should go now."
        clear_dialog
        talk nasty talk "There's someone worth talking to there today only. Let's go see her."
        talk lovely talk "Her holiness is there, and indeed everywhere *every* day, Nasty Girl."
        talk nasty talk "Not what I was talking about. Hot bitches DOWN TO FUCK."
        clear_dialog
        talk orb talk "...The cathedral is closing for the day very soon, Ghost."
        clear_dialog
        wait 1000

// LANDLADY // 
    // CRYPTO LANDLADY PROMPTS
    if (&& $data.ghost.investor (quest_started? landlady) (!= (quest_succeeded? landlady) true) (!= $data.global.nastyNFP true)):
        set data.global.nastyNFP true
        talk nasty talk "Hold up gang. I have an idea forming."
        talk lovely talk "Oh? Do tell!"
        talk nasty talk "Shhhh! Give me a moment, I need to get my thinking hat on."
        talk lovely talk "..."
        choice:
            talk orb talk "..."
            "...":
                if (roll game_map_nastyNFP_nightmare nightmare 20):
                    choice:
                        talk nightmare talk "<span class='nightmare'>Hey Ghost, your body type is 'brick'.</span>"
                        "Shh. Nasty Girl's thinking.":
                            talk nightmare talk "<span class='nightmare'>fuck me. that makes a change.</span>"
                            clear_dialog
        talk lovely talk "..."
        clear_dialog
        talk nasty talk "So, obviously Ghost got scammed into investing in sheepshit, right? Well, there's only one thing you can do when you've been scammed, and that's find someone even stupider than you, and scam *them*." 
        talk orb talk "What are you suggesting?"
        choice:
            talk nasty talk "Let's scam your landlady into accepting Ghost's 'investment' in lieu of cash."
            "I do really want to retain my investment, but I *do* also really need to pay my rent... [Shake your head] A valid, if tragic suggestion, Nasty Girl.":
                talk nasty talk "You're welcome Ghost. This is why you should ignore all the horrible things Lovely Lady says about me."
            "But I'll be a millionaire any day now, I just know it.":
                talk lovely talk "Wheeee! Oh how wonderful it will be to sip some nice champagne!"
            "Non-committal response.":
                talk nasty talk "Whatever. It's a good idea. *My* good idea."
        clear_dialog
        wait 1000
    // LANDLADY PROMPT
    if (&& (quest_started? landlady) (!= (quest_succeeded? landlady) true) (<= $stats.actions.value 2) (!= $data.gamemap.landladyPromptDone true)):
        set data.gamemap.landladyPromptDone true
        set data.landlady.rentPriceText (numbverter $data.landlady.rentPrice)
        talk orb talk "Your Landlady is home now. Or rather, Your Landlady is <span class='writtenText'>'not busy'</span>, now. If you plan on paying your rent you should head over to Little Donking with %{$data.landlady.rentPriceText} pounds."
        if $data.global.nastyNFP:
            talk nasty talk "Or just fakkin scam her."
        clear_dialog
        wait 1000

// BLUEHILLS //
    // PRIDE PROMPT ONE
    if (&& (== $stats.day.value 4) (!= $data.gamemap.pridePrompt true)):
        set data.gamemap.pridePrompt true
        talk orb talk "That Pride Parade is today, if you're interested. Probably going to be a lot of people there, maybe some you know?"
        clear_dialog
        wait 1000
    // HOUSESNAKE PROMPT
    if (&& (!= $data.houseSnake.fed true) (!= (objective_started? houseSnake boneman) true) (quest_started? houseSnake) (== $data.houseSnake.active true) (!= $data.gamemap.houseSnakePromptDone true)):
        clear_dialog
        set data.gamemap.houseSnakePromptDone true
        play sound hiss
        "Somewhere distant, a hungry hissssss."
        clear_dialog
        wait 1000

// SHOP //
    // SHOP_FLIRT PROMPT
    if (&& (>= $data.shop.boughtItems 8) (== $stats.day.value 4) (== $stats.actions.value 6)):
        choice:
            talk nasty talk "Hey, so, before we get going... the shopkeeper, the nice lady who runs the shop. She's into us, right?"
            "What makes you say that?":
                talk nasty talk "Um, hello? Have you seen how much stuff we've bought off of her? Chicks did it when you trade currency for goods."
                talk lovely talk "She's right, little ladies love the laissez-faire market!"
                choice:
                    talk nasty talk "Exactly. She is *so* into us."
                    "You're godsdamn right she is. Probably. Have we spoken?":
                        talk nasty talk "When you feel as strongly about boning as you two do you don't *need* words. There's a mutual, telly parthic understanding, ain't there?"
                    "I don't think so, no. I don't think she's ever even spoken to us, somehow.":
                        talk nasty talk "Well she totally is. It's obvious. We should go ask her out for a drink."
        clear_dialog
        if $data.ghost.deepthroatedCigTwice:
            talk orb talk "She watched you eat two whole cigarettes. I do not think she's going to want to fuck you, Ghost."
            talk nasty talk "Orb, sweet'art, that's *why* she wants to fuck us."
        else:
            if $data.ghost.deepthroatedCig:
                talk orb talk "She watched you a cigarette. I do not think she's going to want to fuck you, Ghost."
                talk nasty talk "Orb, sweet'art, that's *why* she wants to fuck us."
        start_quest shopkeeper
        start_objective shopkeeper flirt
        clear_dialog
        wait 1000
    // SHOP HAMMER PROMPT
    if (&& (== $stats.day.value 4) (!= $data.gamemap.hammerPrompt true) (!= (quest_succeeded? fixHouse) true) (!= (has_item? hammer) true)):
        set data.gamemap.hammerPrompt true
        if (quest_started? shopkeeper):
            talk orb talk "Well, either way, the shop just received a new shipment of hammers, if you're still needing to get that roof fixed, which you should before you catch your death of cold, so perhaps we should pay the shopkeeper a visit anyway?"
        else:
            talk orb talk "The shop in town just received a new shipment of hammers, if you're still needing to get that roof fixed, which you should before you catch your death of cold."
        clear_dialog
        wait 1000

// HOME //
    // FIXHOUSE PROMPT
    if (&& (has_item? hammer) (has_item? nails) (has_item? plank) (!= $data.gamemap.fixHousePrompt true)):
        set data.gamemap.fixHousePrompt true
        talk orb talk "We've got everything we need to fix that hole in your roof. We should probably do it sooner rather than later, lest you catch your death of cold."
        clear_dialog
        wait 1000
    clear_dialog

    set data.game_map.inPrompts false