article:
    play sound click
    choice:
        "Your job requires you to write a short article about a war hero."
        "[Write a patriotic article for Weird Tails magazine] <span class='prompt'>[[-1 ACTION]]</span>" if (>= $stats.actions.value 1):
            play sound spendAction
            set data.game_map.inHouse false
            add_stat actions -1
            set_button button_article false
            run transition_black typewriter
            clear_dialog
        "<span class='prompt'>[[BACK]]</span>":
            jump home

    jump article_menu

article_menu:
    clear_dialog
    choice:
        "Your typewriter stares at you with it's little, whiny keys. 'Press us mommy', they plead."
        "[Write a story about The Raven]" if (|| $data.article.ravenTennenburgStory $data.article.ravenCivilianStory $data.article.ravenPosterStory $data.article.ravenWuppetsStory):
            jump article_raven
        "[Write a story about The Weapon]" if (objective_completed? writer interview):
            jump article_weapon
        "[Fuck it. Literally just make up a guy]" if $data.article.makeUpAGuy:
            jump article_guy
        "[Get Orb to tell you about a war hero]":
            jump article_hero
        "[Write a crowd pleasing article about Wazzok the Warsheep]" if $data.ghost.sawWazzok:
            jump article_wazzok
    
article_raven:
    if $data.raven.badEnd:
        talk orb talk "So, it's important to note that The Raven explicitly told you *not* to write about her or she'd end you."
        talk orb talk "It's also important to note that she could bench press a train, and you're as brittle as a frozen puddle."
        clear_dialog
        choice:
            talk orb talk "Please consider all of this before you go any further."
            "The Raven's story about Tennenburg is too good not to tell. Besides, if she kills me, it'd be hot." if $data.article.ravenTennenburgStory:
                choice:
                    talk orb talk "Then on your head be it, Ghost."
                    "[Write an article recounting The Raven's story]":
                        play sound typewriter
                        add data.article.points 10
                        set data.raven.interviewBad true
                        jump article_end
            "The Raven's saving that Frankish civilian was pretty heroic. It's too good not to tell. Besides, if she kills me, it'd be hot." if $data.article.ravenCivilianStory:
                choice:
                    talk orb talk "Then on your head be it, Ghost."
                    "[Write an article recounting The Raven's story]":
                        play sound typewriter
                        add data.article.points 10
                        set data.raven.interviewBad true
                        jump article_end
            "I think The Raven wants more people to be aware she was the 'petroleum poster lady'. [Nod] She's just shy is all. Besides, if she kills me, it'd be hot." if $data.article.ravenPosterStory:
                choice:
                    talk orb talk "Then on your head be it, Ghost."
                    "[Write an article recounting The Raven's story]":
                        play sound typewriter
                        add data.article.points 10
                        set data.raven.interviewBad true
                        jump article_end
            "Extra extra! Local dyke 'might' watch the new Wuppets movie so she can imagine pissing on Judy Baps! Read all about it!" if $data.article.ravenWuppetsStory:
                choice:
                    talk orb talk "Ghost. I need you to imagine you're looking me in the eye. Are you imagining?"
                    "Yes.":
                        talk orb talk "Do not write that. Do not hand that to The Pulp Writer. You will ruin everything."
                    "Yes [Lie]":
                        talk orb talk "Fuck you. I know you aren't imagining. Whatever. I don't care. Not my problem. Ruin your career."
                    "No":
                        talk orb talk "Fuck you. Whatever. I don't care. Not my problem. Ruin your career."
                clear_dialog
                choice:
                    talk orb talk "So. Are you going to write something else?"
                    "Let's consider another option methinks."
                        jump article_menu
                    "No :)":
                        play sound typewriter
                        add data.article.points -10
                        jump article_end
            "You might be right. Let's consider another option methinks.":
                jump article_menu
    else:
        choice:
            talk orb talk "What are you thinking, Ghost?"
            "I'm going to write about how she saved that civilian." if $data.article.ravenCivilianStory:
                choice:
                    talk orb talk "Let's get to it, then."
                    "[Write an article recounting The Raven's story]":
                        play sound typewriter
                        add data.article.points 10
                        set data.article.raven true
                        jump article_end
            "I'm going to (respectfully) write about her role in the battle of Tennenburg." if $data.article.ravenTennenburgStory:
                choice:
                    talk orb talk "Tread carefully, Ghost."
                    "[Write an article recounting the Raven's story]":
                        play sound typewriter
                        add data.article.points 10
                        set data.article.raven true
                        jump article_end
            "I'm going to write about her role as the petroleum poster lady. I think she wants more people to know about that, she's just shy is all." if $data.article.ravenPosterStory:
                choice:
                    talk orb talk "Tread carefully, Ghost."
                    "[Write an article recounting the Raven's story]":
                        play sound typewriter
                        add data.article.points 10
                        set data.article.raven true
                        jump article_end
            "Extra extra! Local dyke 'might' watch the new Wuppets movie so she can imagine pissing on Judy Baps! Read all about it!" if $data.article.ravenWuppetsStory:
                choice:
                    talk orb talk "Ghost. I need you to imagine you're looking me in the eye. Are you imagining?"
                    "Yes.":
                        talk orb talk "Do not write that. Do not hand that to The Pulp Writer. You will ruin everything."
                    "Yes [Lie]":
                        talk orb talk "Fuck you. I know you aren't imagining. Whatever. I don't care. Not my problem. Ruin your career."
                    "No":
                        talk orb talk "Fuck you. Whatever. I don't care. Not my problem. Ruin your career."
                clear_dialog
                choice:
                    talk orb talk "So. Are you going to write something else?"
                    "Let's consider another option methinks."
                        jump article_menu
                    "No :)":
                        play sound typewriter
                        add data.article.points -10
                        jump article_end
            "Let's consider another option methinks.":
                jump article_menu

article_weapon:
    choice:
        talk orb talk "The Weapon doesn't have a particularly heroic story, but I suppose shooting a bunch of people means they're good enough for what we need."
        "Let's do it.":
            choice:
                talk orb talk "Let's get to it, then."
                "[Write an article recounting The Weapon's sharpshooting skills winning the day for our boys]":
                    play sound typewriter
                    add data.article.points 10
                    jump article_end
        "Let's consider another option methinks.":
            jump article_menu

article_guy:
    choice:
        talk orb talk "Okay so, cards on the table, this is a terrible idea. Are you sure you want to do this?"
        "Yes. I stand by my terrible decision.":
            talk orb talk "Then on your head be it, Ghost."
        "You might be right. Let's consider another option methinks.":
            jump article_menu
    set data.global.makeUpAGuy true
    clear_dialog
    talk nasty talk "I'm so fucking excited I'm practically fucking vibrating."
    talk nasty talk "Actually, that could be the methylphenidate I just boofed."
    clear_dialog
    talk orb talk "First thing's first, we need a name for our made-up war hero."
    choice:
        talk nasty talk "Nasty Girl."
        "'Nasty Girl', sounds good.":
            set data.article.badName true
            set data.article.nameNasty true
            talk nasty talk "Hel fucking yes."
        "You want me to call our made-up war hero 'Nasty Girl'? That isn't a name.":
            talk nasty talk "It's *my* name, dipshit."
            talk orb talk "No one is called Nasty Girl in real life, Nasty Girl. It isn't a name."
            choice:
                talk nasty talk "Nasty Girl."
                "We'll call our made-up war hero 'Nasty Girl'.":
                    set data.article.badName true
                    set data.article.nameNasty true
                    talk nasty talk "Yessssss!"
                "Maybe something else.":
                    choice:
                        talk lovely talk "Something like... like... Lovely Lady!"
                        "'Lovely Lady' it is.":
                            set data.article.badName true
                            set data.article.nameLovely true
                            talk lovely talk "Wheeeee! Exciting! What were you talking about?"
                            talk nasty talk "What the fuck is your problem, Ghost?"
                        "Where you not just listening to our discussion about whether 'Nasty Girl' was a real name?":
                            choice:
                                talk lovely talk "No, apologies, mon amie, I was fielding a telephone call from Papi. Why?"
                                "How about calling our made-up war hero 'Ghost'? I'm going to write that.":
                                    set data.article.badName true
                                    set data.article.nameGhost true
                                    talk orb talk "Saints alive, Ghost, this is just the same problem again. It's like you're trying to hurt me."
                                    if (roll article_guy_vanity_nightmare nightmare 20):
                                        talk nightmare talk "<span class='nightmare'>Vanity is a sin, </span><span class='nightmareQuote'>'ghost'</span><span class='nightmare'>, doubly so when you have very little worth being vain about. Besides, she should have been called </span><span class='nightmareQuote'>'The Nightmare'</span><span class='nightmare'>.</span>"
                                    else:
                                        wait 1000
                                "How about calling our made-up war hero 'Belinda'?":
                                    add data.article.points 1
                                    talk orb talk "Fine. Good enough. Whatever. Let's actually get writing now, yes?"
    play sound typewriter
    clear_dialog
    talk orb talk "Personality. What was she like. How would her friends and comrades describe her?"
    talk nasty talk "Mean, but in a sexy way. She makes girls swallow her spit."
    talk lovely talk "She's really into flower pressing. She has a whole book full of pressed flowers. Sometimes she takes them out the book and eats them, so she can remember all the places she has been to."
    clear_dialog
    choice:
        talk orb talk "Okay. Those are some nice suggestions. Can I suggest writing something normal instead?"
        "[Write about how she makes girls swallow her spit]":
            play sound typewriter
            add data.article.points -1
            talk nasty talk "Hel yeah."
            talk lovely talk "Ugh! Disgusting! That is soooooo disgusting Ghost! You're messed up! That's so gross! Euugh I can't... I can't even imagine... euuugh! Everyone this is *so* gross!"
        "[Write about whatever the fuck Lovely Lady was talking about]":
            play sound typewriter
            add data.article.points 1
            talk lovely talk "Wheeee!"
            talk nasty talk "Congratulations; you've written a character even duller than Lovely Lady."
        "[Write about how she is <span class='writtenText'>'nice'</span> and <span class='writtenText'>'friendly'</span> and <span class='writtenText'>'has a nice and friendly smile'</span>]":
            play sound typewriter
            add data.article.points 1
            talk lovely talk "How lovely! She sounds like a *very* nice lady!"
            talk nasty talk "She sounds boring."
            talk orb talk "She sounds believable, which is all she needs to be."
        "[Write about how she got amnesia after being hit by a space orb]":
            play sound typewriter
            add data.article.points -2
            talk nasty talk "Write what you know eh Ghost?"
    clear_dialog
    talk orb talk "Next, how many enemy combatants did she take down?"
    choice:
        talk nasty talk "A thousand. No! Wait! A *million!"
        "That's wild. [Write that down]":
            play sound typewriter
            add data.article.points -2
            talk orb talk "Your made up guy was personally responsible for 1/30 deaths during the war. Okay Ghost. Whatever. "
        "A million might be a little much. [Write down a thousand]":
            play sound typewriter
            add data.article.points -1
            talk orb talk "We... we can maybe get away with that if we say she was in the artillery corps..."
        "A thousand might be a little much, let alone a million. [Write down a hundred]":
            play sound typewriter
            add data.article.points 2
            talk orb talk "An impressive, but not out of the question number."
        "[Write down the number sixty nine and chuckle to yourself]":
            play sound typewriter
            add data.article.points 2
            talk nasty talk "Hahaha. Nice one."
            if (!= $data.article.sixtynine true):
                set data.article.sixtynine true
                talk lovely talk "Hmm? I don't get it."
                if (roll article_guy_69_orb orb 40):
                    talk orb talk "According to the Anglian Dictionary (1928 Edition) Sixty-nine or 69, also known by its French name soixante-neuf (69), is a group of sex positions in which two people align themselves so that each person's mouth is near the other's genitals, each simultaneously performing oral sex on the other. The participants are thus mutually inverted like the numerals 6 and 9 in the number 69 (69), hence the name."
                else:
                    talk orb talk "The fact that both Nasty Girl and Ghost find it funny suggests to me it's some sort of crude sex joke. Ignore them, Lovely Lady."
                clear_dialog
                talk nasty talk "I'll give you a demonstration somewhen, Lovely Lady, if that helps."
                talk lovely talk "..."
    clear_dialog
    talk lovely talk "They fought at the battle of... um... I don't know any battles, actually."
    choice:
        talk orb talk "Keep it generic. Hill sixteen."
        "[Write down <span class='writtenText'>'the battle of bastard mountain'</span>]":
            play sound typewriter
            add data.article.points -2
            talk orb talk "Okay. Fine. Just ignore me then. It's not hurtful or anything."
        "[Write down <span class='writtenText'>'hill sixteen'</span>]":
            play sound typewriter
            add data.article.points 1
            talk orb talk "Thanks."
        "[Write down <span class='writtenText'>'hill sixty nine'</span> and chuckle to yourself]":
            play sound typewriter
            add data.article.points 1
            talk nasty talk "HAHAHAHAHA. Oh Ghost you are too much!"
            if (!= $data.article.sixtynine true):
                set data.article.sixtynine true
                talk lovely talk "Hmm? I don't get it."
                if (roll article_guy_69_orb orb 40):
                    talk orb talk "According to the Anglian Dictionary (1928 Edition) Sixty-nine or 69, also known by its French name soixante-neuf (69), is a group of sex positions in which two people align themselves so that each person's mouth is near the other's genitals, each simultaneously performing oral sex on the other. The participants are thus mutually inverted like the numerals 6 and 9 in the number 69 (69), hence the name."
                else:
                    talk orb talk "The fact that both Nasty Girl and Ghost find it funny suggests to me it's some sort of crude sex joke. Ignore them, Lovely Lady."
                clear_dialog
                talk nasty talk "I'll give you a demonstration somewhen, Lovely Lady, if that helps."
                talk lovely talk "..."
    clear_dialog
    talk orb talk "Let's stop while we're ahead. I think we have enough."
    clear_dialog
    choice:
        talk nasty talk "Add a final quote. Something cool like 'When I march into hel I'll drag those motherfucking Jerries with me on an endless leash AWOOOOOO!'"
        "Good idea Nasty Girl. I'm writing exactly that. [Write exactly that]":
            play sound typewriter
            talk nasty talk "Gods she is so cool."
        "[Write <span class='writtenText'>'I LOVE ANGLIA!!!'</span>]":
            play sound typewriter
            add data.article.points 1
            talk orb talk "That'll play well with middle Anglia, I suppose."
        "[Write something about how <span class='writtenText'>'my friend Ghost is *not* a foot pervert and I'm a troop so you have to respect me and stop saying she does!'</span>]":
            play sound typewriter
            add data.article.points -2
            set data.ghost.footGirl true
            choice:
                talk nasty talk "Oh my gods ahahaha is this a joke."
                "No! I'm being serious! She really said this!":
                    talk orb talk "The character I just watched you make up said that did she? Just admit you're into feet. This is honestly far more embarrassing."
        "[Don't write anything]":
            talk lovely talk "Ah! How dramatique! This is like a Frankish novel..."
    jump article_end

article_hero:
    choice:
        talk orb talk "Okay, I don't want to get your hopes up, but I can try to tell you about a war hero, if you're sure you don't want to try something else."
        roll article_hero_hero_orb orb 60 "Enlighten me, Orb.":
            success "":
                add data.article.points 10
                choice:
                    talk orb talk "I have two. Morgona the Pronkle or Felix Brick."
                    "Tell me about Morgona the Pronkle.":
                        run transition_instant morgona
                        talk orb talk "Morgona the Pronkle was an Anglian infantrywoman who grew famous for her unorthodox use of bayonets, that is to say she attached them to her antlers."
                        talk orb talk "It sounds ridiculous, but she quickly became one of the most decorated soldiers in the Anglian military. They even had to invent a new medal for her, 'The gored heart', after she singleantlerdly took out an entire bunker with her bare... pronks."
                        clear_dialog
                        talk nasty talk "Holy shit she sounds amazing can we go find her I want her to gore us."
                        talk orb talk "Sadly no, she was killed a few months into the Ryneland campaign. Her bayonets glinted too much and caught the eye of a sniper."
                        clear_dialog
                        choice:
                            talk orb talk "A chilling tale that tells us why more deer do not attach bayonets to their antlers, and why they *do* attach leaves or other camouflage to them so they can pretend to be innocent trees instead of a big shiny target."
                            "She took out an entire bunker with just her antlers!?!?":
                                talk orb talk "Well, with the blades attached to them, at least. The second she gored the first opponent the others lost the will to fight back, so gruesome it was."
                                talk orb talk "They were, ironically, like deer caught in floodlights. It was a bloodbath. Fourteen casualties, and Morgona only snapped one of her pronks."
                            "Slow down a second, what the fuck is a <span class='writtenText'>'pronkle'</span>?":
                                talk nasty talk "It's soldier slang for antler, get with the times babushka."
                            "She sounds very impressive.":
                                talk orb talk "She was. The troops loved her. After her death the Anglian military even discontinued use of the 'Antlercracker' type sniper rifle out of respect."
                        clear_dialog
                        choice:
                            talk orb talk "That's about all there is to say. An impressive career."
                            "[Write an article about Morgona the Pronkle]":
                                play sound typewriter
                                jump article_end
                    "Tell me about Felix Brick.":
                        choice:
                            talk orb talk "They landed on the shores of Scandinavia in the night, clambered a hundred foot up a wet, razor-sharp rock face, trekked over a hundred miles in land undercover and blew up an oil refinery."
                            "[Write that down] Uhuh, then what?":
                                play sound typewriter
                                choice:
                                    talk orb talk "Almost got caught, but managed to break their captors spine and flee."
                                    "[Keep writing] Incredible... this is gold... I'll be promoted to editor in no time...":
                                        play sound typewriter
                                        choice:
                                            talk orb talk "Their rescue ship was struck by a torpedo enroute, and so they instead made their way through enemy territory to the fishing village of Glesvær, where they stole a crabbing vessel and made their way Schottland, scuttling a surfaced Imperial U boat in the process."
                                            "You're right, that *is* pretty heroic. [Finish writing your article about Felix Brick]":
                                                play sound typewriter
                                                jump article_end
                                            "So what I could easily have done that too. [Finish writing your article about Felix Brick]":
                                                talk orb talk "No you couldn't have."
                                                play sound typewriter
                                                jump article_end
            failure "":
                set data.article.points -10
                set data.article.orbFuckedUp true
                choice:
                    talk orb talk "Fredrik Potts. Seventh Anglian Rifles Division. Shot down over five hundred Imperial aircraft with a crossbow."
                    "[Write that down] Uhuh, then what?":
                        play sound typewriter
                        choice:
                            talk orb talk "Ate a tank. I think."
                            "[Keep writing] Incredible... this is gold... I'll be promoted to editor in no time...":
                                play sound typewriter
                                choice:
                                    talk orb talk "They then took a 'poison status effect' and began flashing green and died."
                                    "You're right, that *is* pretty heroic. [Finish writing your article about Fredrik Potts]":
                                        play sound typewriter
                                        jump article_end
        "Let's consider another option methinks.":
            jump article_menu

article_wazzok:
    choice:
        talk orb talk "Seems like an easy win. Everyone loves Wazzok, even people who hate the military. She was a real darling."
        "[Write an article about Wazzok the Warsheep]":
            play sound typewriter
            set data.article.points 10
            jump article_end
        "Let's consider another option methinks.":
            jump article_menu

article_end:
    clear_dialog
    add_item article 1
    complete_objective writer article
    complete_objective writer interview
    start_objective writer writerOne
    "Writing is hard work, but you get it done."
    clear_dialog
    choice:
        talk orb talk "We should get this to The Pulp Writer as soon as possible. She gave you her address, right?"
        "<span class='prompt'>[[CONTINUE]]</span>":
            play sound spendAction
            jump goToGameMap