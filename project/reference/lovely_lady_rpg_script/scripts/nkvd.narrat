nkvd:
    play sound click
    if (objective_started? hrt private):
        choice:
            "A private gender clinic. It may be able to help you. For a price."
            "[Try and get an appointment] <span class='prompt'>[[-? ACTIONS]]</span>" if (>= $stats.actions.value 1):
                play sound spendAction
                set data.game_map.inMap false
                set data.nkvd.atPrivateAppt true
                add_stat actions -1
                set_button button_nkvd false
                run transition_black office_reception
                clear_dialog
            "<span class='prompt'>[[BACK]]</span>":
                jump game_map
    else:
        choice:
            "You have an appointment with the Gender Clinic, apparently. No doubt they will be eager and willing to help you attend to your poor, transexual little needs, and won't subject you to a dehumanising medicalisation."
            "[Attend your appointment] <span class='prompt'>[[-? ACTIONS]]</span>" if (>= $stats.actions.value 1):
                play sound spendAction
                set data.game_map.inMap false
                add_stat actions -1
                set_button button_nkvd false
                run transition_black office_reception
                clear_dialog
            "<span class='prompt'>[[BACK]]</span>":
                jump game_map

    play sound bell
    "The receptionist files down one of her nails. She doesn't even glance up as you enter."
    clear_dialog
    if $data.nkvd.atPrivateAppt:
        set data.nkvd.fake 0
        set data.nkvd.agp 0
        set data.nkvd.unfit 0
        if $data.global.gicAttended:
            choice:
                talk orb talk "That... that's The Keeper of the Gate of Venus. She's thirty and likes to paint... wait, are you fucking kidding me? This is just the GIC again!"
                "Oh my gods it's the same woman! [Wave your arms around at the all too familiar surroundings] It's the same fucking place! [Point at the evil door] That's the same evil fucking door!":
                    "The Keeper of the Gate does not seem to notice you silently flailing your arms around in the reception, so engrossed in her nails she is."
                    clear_dialog
                    talk orb talk "This is weird. I don't like this at all."
                    talk nasty talk "This is fucked."
                    talk lovely talk "'Tis rather odd, oui."         
                    clear_dialog
                    choice:
                        talk orb talk "Whatever. We're here. Let's see where this goes. Say hello to the Keeper of the Gate."
                        "[Approach The Keeper of the Gate of Venus] \\"Hello. I was wondering if I could talk to a doctor, or something.\\"":
                            run skip
        else:
            choice:
                talk orb talk "The Keeper of the Gate of Venus. She's thirty and likes to paint flowers."
                "[Approach The Keeper of the Gate of Venus] \\"Hello. I was wondering if I could talk to a doctor, or something.\\"":
                    run skip
        clear_dialog
        "The Keeper of the Gate puts down her nail file and looks up at you. The very beginning of a scowl is etched across her face."
        clear_dialog
        talk gatekeeper talk "Well..."
        if (roll nkvd_angry_orb orb 20):
            talk lovely talk "She's annoyed that you didn't book an appointment and just turned up asking to see a doctor. Which is fair, one supposes."
        else:
            wait 1000
        clear_dialog
        "The Keeper of the Gate flips through her notes. Chicken scratch writing connected by red string. Her record keeping is atrocious, and she seems to have spent most of today absent mindedly drawing sheep overtop of her records."
        clear_dialog
        talk gatekeeper talk "We had a cancellation today, lucky you! Would you like to see the doctor in a few moments?"
        clear_dialog
        choice:
            talk orb talk "This is an event of astronomical luck. The wait would normally be months. Say yes."
            "\\"Yes please.\\"":
                choice:
                    talk gatekeeper talk "Wonderful. The appointment will cost thirty pounds."
                    "\\"Excuse me.\\"":
                        choice:
                            talk gatekeeper talk "I said the appointment will cost thirty pounds. There's also the additional cost of thirty pounds per prescription and ten pounds per month for admin costs, obviously."
                            "\\"Obviously.\\"":
                                "She titters."
                                clear_dialog
                                talk gatekeeper talk "Obviously yes. You wouldn't believe the amount of people we get here expecting our busy busy doctors to see them and provide them lifesaving medicine for free! How silly, do they not know how business work?"
                                clear_dialog
                                "She titters some more."
                    "\\"Sorry I think my ears clogged\\" [Jam a finger in your ear and wiggle it around] \\"It almost sounded like you just said it would cost me thirty pounds to get hormones.\\"":
                        talk gatekeeper talk "No, I said the appointment would cost thirty pounds. The hormones cost an additional thirty pounds per prescription. We also have monthly a admin charge of ten pounds a month."
                        clear_dialog
                        "She rattles off these figures like they aren't extortionate. Like daylight robbery is a normal and accepted element of society."
                clear_dialog
                choice:
                    talk orb talk "That's a total cost of... forty pounds for this appointment. Ouch."
                    "\\"I'll pay.\\" [Pay thirty pounds for the appointment and ten pounds for the nebulous 'admin costs']" if (>= $stats.money.value 40):
                        add_stat money -40
                        play sound coins
                        talk gatekeeper talk "Wonderful. Could I take your name?"
                        jump nkvd_name
                    "\\"No thank you. I'd rather walk down to the canal and throw all my emeralds and pennies into it.\\"":
                        "The Keeper of the Gate titters, amused by what she assumed was a bit."
                        clear_dialog
                        choice:
                            talk gatekeeper talk "Could I take your name?"
                            "\\"I'm off. Bye!\\" [Leave without making an appointment, knowing full well you're not going to get another chance at one for months, if ever] <span class='prompt'>[[CONTINUE]]</span>":
                                play sound spendAction
                                play sound bell
                                complete_objective hrt private
                                jump goToGameMap
    else:
        set data.global.gicAttended true
        choice:
            talk orb talk "The Keeper of the Gate of Venus. She's thirty and likes to paint flowers."
            "[Approach The Keeper of the Gate of Venus] \\"Hello. Apparently I have an appointment here today, or something.\\"":
                "The Keeper of the Gate puts down her nail file and looks up at you."
            "[Approach The Keeper of the Gate of Venus] \\"Hello hormones please thank you. Thankssssss.\\"":
                "The Keeper of the Gate puts down her nail file and looks up at you."
                clear_dialog
                choice:
                    talk gatekeeper talk "Do you have an appointment?"
                    "\\"So I've been told.\\"":
                        run skip
            "[Approach The Keeper of the Gate of Venus and just stand there silently grinning so you look friendly]":
                "The Keeper of the Gate continues filing her nails."
                clear_dialog
                wait 4000
                choice:
                    talk lovely talk "You should probably say hello, she isn't going to look up for a while. She's intent on whittling her nails down to little nubs. Who isn't?" 
                    "\\"Hello. Apparently I have an appointment here today, or something?\\"":
                        "The Keeper of the Gate puts down her nail file and looks up at you."
    clear_dialog
    talk gatekeeper talk "Well..."
    clear_dialog
    "She flips through her notes. Chicken scratch writing connected by red string. Her record keeping is atrocious, and she seems to have spent most of today absent mindedly drawing sheep overtop of her records."
    clear_dialog
    talk gatekeeper talk "Can I take your name?"
    jump nkvd_name

nkvd_name:
    set data.nkvd.metNKVD true
    clear_dialog
    choice:
        talk orb talk "Uh oh."
        "\\"Ghost.\\"":
            set data.ghost.nameGhosty true
            choice:
                talk gatekeeper talk "And your surname?"
                "\\"...Ghosty.\\"":
                    talk gatekeeper talk "Wonderful."
        "\\"I'm not sure, sorry.\\" [Tap your head] \\"Brain broke. Just write <span class='writtenText'>'Ghost'</span>.\\"":
            talk gatekeeper talk "I'll just write Ghost then."
            clear_dialog
            "She titters to herself."
            clear_dialog
            talk orb talk "This should be something she makes a big deal out of. Or would be, if she actually bothered filling in any paperwork. This surgery runs entirely on her memory, which functionally doesn't exist."
    clear_dialog
    talk gatekeeper talk "I'm not seeing you on my list... but there's only one appointment booked for today, which I suppose must be you! Perhaps I wrote the wrong name down, apologies Ms Ghost, I'm ever such a ditz!"
    choice:
        talk gatekeeper talk "If you sit in the waiting room the doctor will be with you in just a moment."
        "\\"Thank you.\\" [Await judgement] <span class='prompt'>[[-1 ACTION]]</span>":
            play sound spendAction
            clear_dialog
            add_stat actions -1
            wait 4000
            "A clock ticks... somewhere? Time passes slowly here. Or quickly. It's hard to tell."
            clear_dialog
            if (roll nkvd_clock_orb orb 60):
                talk orb talk "The practice moved the clock out of the view of the patients a few months ago."
                talk orb talk "People are less likely to get up and complain to The Keeper of the Gate if they don't have definitive proof that they've been waiting for half an hour."
                if (roll nkvd_time_orb orb 20):
                    talk orb talk "You've been waiting half an hour already, by the way."
                else:
                    wait 1000
            else:
                wait 1000
    clear_dialog
    wait 4000
    "After an eternity in limbo, The Keeper of the Gate speaks."
    clear_dialog
    talk gatekeeper talk "The doctor will see you now."
    clear_dialog
    "She gestures to a door. It is too big to be a normal sized door, but not so big as to be *too* big. It is just an unnaturally sized door, not fit for mammal use."
    choice:
        "Not for any specific reason, mind, it's just not quite right. It should have been shredded into wood chips the moment it was born, but it wasn't, and now you have to step through it."
        "[Step through the horrible door]":
            clear_dialog
            play sound dooropen
            play music welcomeToEngland-CUNT
            run transition office_doctor
            play sound doorclose
            "The room on the other side is cold. It smells like a war photograph. A trench full of bodies. The smoke of the bulldozer. This place is wrong. You need to leave."
    clear_dialog
    talk orb talk "You can leave after you've gotten hormones. Snap out of it, Ghost."
    if (roll nkvd_name_die_nightmare nightmare 20):
        talk nightmare talk "<span class='nightmare'>You can never leave. You'll be in this room forever, even if it feels like you're allowed into the yard to exercise in the open air once in a while. You were born for this room, you will live your life forever in its walls, and one day you will be killed in it.</span>"
    else:
        wait 1000
    clear_dialog
    if (&& $data.nkvd.atPrivateAppt $data.global.gicAttended):
        play sound nkvd
        choice:
            talk nkvd talk "Purpose of visit."
            "\\"Wait. I've done this before. We've already done this.\\"":
                play sound nkvd
                choice:
                    talk nkvd talk "Purpose of visit."
                    "Am I going insane?":
                        talk orb talk "No. Well, not in this instance at least. This is the same doctor asking the same questions."
                        clear_dialog
                        play sound nkvd
                        talk nkvd talk "Purpose of visit."
                        if (roll nkvd_name_retry_orb orb 20):
                            choice:
                                talk orb talk "Might I suggest changing your answers from last time to increase the chances of us coming out of here with a prescription?"
                                "You mean I should *lie*!?":
                                    talk orb talk "Yes. It is *always* morally sound to lie to these freaks."
                        else:
                            wait 1000
        clear_dialog
        play sound nkvd
        choice:
            talk nkvd talk "Purpose of visit."
            "\\"I'd like some feminising hormones, please.\\" [Sit down homosexually]":
                jump nkvd_hormones
            "\\"I'd like some feminising hormones, please.\\" [Sit down normal style]":
                add data.nkvd.fake 1
                jump nkvd_hormones
    else:
        play sound nkvd
        talk nkvd talk "Purpose of visit."
        choice:
            "It's him. The one for whom you came here. The Gender NKVD."
            "\\"Hello.\\" [Do a gay little wave] \\"I'd like some feminising hormones, please.\\" [Sit down homosexually]":
                jump nkvd_hormones
            "\\"Hello.\\" [Do a normal little wave] \\"I'd like some feminising hormones, please.\\" [Sit down normal style]":
                add data.nkvd.fake 1
                jump nkvd_hormones

nkvd_hormones:
    clear_dialog
    play sound nkvd
    choice:
        talk nkvd talk "Time on hormones thus far."
        "\\"Sorry, was that a question? Where was the question mark?\\""
            talk orb talk "A question mark was deemed too expensive for the health service, but yes, it was a question."
            jump nkvd_hormones 
        "\\"That depends. Does Sissy FM count?\\"" if $data.ghost.sissyFM:
            add data.nkvd.agp 1
            talk nkvd talk "Negative. But deviant sexuality is noted."
            jump nkvd_age
        "\\"I don't know?\\"":
            add data.nkvd.fake 1
            jump nkvd_age
        "\\"Five years, give or take a month.\\"" if $data.nkvd.orb_hormones_fiveyears:
            jump nkvd_age
        "\\"I'm not on hormones yet. I think. Maybe.\\"":
            add data.nkvd.fake 1
            jump nkvd_age
        "\\"Forever, technically. Everyone has hormones. Even *you*!\\" [Point at the search light]" if $data.nkvd.orbHormonesFail:
            add data.nkvd.fake 1
            jump nkvd_age
        roll nkvd_hornmones_hormones_orb orb 40 "Orb, how long have I been on hormones?":
            success "":
                set data.nkvd.orb_hormones_fiveyears true
                talk orb talk "Five years, give or take a month."
                jump nkvd_hormones
            failure "":
                set data.nkvd.orbHormonesFail true
                talk orb talk "Forever, technically. Everyone has hormones. It doesn't really answer the question but your slick medical knowledge might impress him."
                jump nkvd_hormones

nkvd_age:
    clear_dialog
    play sound nkvd
    choice:
        talk nkvd talk "Age."
        "\\"Thirty?\\"":
            add data.nkvd.agp 2
            jump nkvd_time
        "\\"Twenty eight?\\"" if $data.global.orbAgeKnown:
            add data.nkvd.agp 1
            jump nkvd_time
        "\\"Twenty five?\\"":
            add data.nkvd.agp 1
            jump nkvd_time
        "\\"Twenty?\\"":
            jump nkvd_time
        "\\Fifteen millennia.\\"" if $data.nkvd.orbAgeFail:
            add data.nkvd.fake 3
            jump nkvd_time
        "\\"You're not meant to ask a lady that.\\" [Lean in close] \\"Would a non-lady say that? Ey?\\"":
            jump nkvd_age
        roll nkvd_age_age_orb orb 40 "Okay Orb, awkward question I know but how old am I?":
            success "":
                set data.global.orbAgeKnown true
                talk orb talk "You're twenty eight as of five weeks ago. Happy late birthday, Ghost."
                talk lovely talk "Happy birthday Ghost! Wheeee!"
                talk nasty talk "Happy birthday, you fucking milf."
                if (roll nkvd_age_dead_nightmare nightmare 20):
                    talk nightmare talk "<span class='nightmare'>good gods, your practically dead. you should really consider ending it now, before you become too frail and brain wormed and end up trapped in your husk for decades and decades watching the world die through your glassy, cataract clouded eyes.</span>"
                    talk nightmare talk "<span class='nightmare'>happy birthday btw.</span>"
                else:
                    wait 1000
                jump nkvd_age
            failure "":
                set data.nkvd.ageFail true
                talk orb talk "*I'm* fifteen millennia old."
                jump nkvd_age

nkvd_time:
    clear_dialog
    play sound nkvd
    choice:
        talk nkvd talk "Aware of gender incongruence from early age yes or no."
        "\\"What?\\"":
            talk orb talk "He's asking 'if you always knew'."
            jump nkvd_time
        "\\"Yes?\\"":
            jump nkvd_makeup
        "\\"No?\\"":
            add data.nkvd.fake 2
            add data.nkvd.agp 1
            jump nkvd_makeup
        "\\"I don't know?\\"":
            add data.nkvd.fake 1
            jump nkvd_makeup
        "\\"I realised at some point in the last fifteen millennia.\\"" if (&& (== $data.nkvd.orbTimeFail true) (== $data.nkvd.orbAgeFail true)):
            add data.nkvd.fake 2
            jump nkvd_makeup
        "\\"I realised at some point in the an undefined period of time.\\"" if $data.nkvd.orbTimeFail:
            add data.nkvd.fake 1
            jump nkvd_makeup
        roll nkvd_time_time_orb orb 40 "Orb, when did I realise I was transgender?":
            success "":
                set data.nkvd.orb_hormones_fiveyears true
                talk orb talk "You were twenty. Someone pointed out your hair was thinning, ever so slightly, and you almost threw up."
                talk orb talk "It's fine, you thought, whatever. Then, a week later you imagined yourself in twenty years and felt like a stielhandgrante had gone off in your stomach."
                talk orb talk "You realised *way* too late to ever forgive yourself."
                jump nkvd_time
            failure "":
                set data.nkvd.orbTimeFail true
                talk orb talk "A while ago. I think. Kind of vague I know. I don't know if that means yes or no to this question."
                jump nkvd_time

nkvd_makeup:
    if $data.ghost.makeup:
        jump nkvd_crossdressing
    else:
        add data.nkvd.fake 1
        clear_dialog
        play sound nkvd
        choice:
            talk nkvd talk "Subject scruffy. Unkempt. No visible makeup."
            "\\"Sob. Correct sir.\\"":
                run skip
            "\\"That's ok though, isn't it? Not all women wear makeup all the time, do they now. What a silly thought!\\"":
                play sound nkvd
                talk nkvd talk "Negative. They do."
        jump nkvd_crossdressing

nkvd_crossdressing:
    clear_dialog
    play sound nkvd
    choice:
        talk nkvd talk "Parents crossdressers yes or no."
        "\\"Yes?\\"":
            add data.nkvd.agp 1
            jump nkvd_dresses
        "\\"No?\\"":
            jump nkvd_dresses
        "\\"I don't know?\\"":
            add data.nkvd.fake 1
            jump nkvd_dresses
        "\\"Eh, fifty fifty.\\"" if $data.nkvd.orbCrossdressFail: 
            add data.nkvd.agp 1
            jump nkvd_dresses
        roll nkvd_crossdressing_crossdressing_orb orb 60 "Orb did my parents crossdress?":
            success "":
                talk orb talk "No. They didn't. Not that it would matter if they did."
                jump nkvd_crossdressing
            failure "":
                set data.nkvd.orbCrossdressFail true
                talk orb talk "Entirely possible, but equally not."
                jump nkvd_crossdressing

nkvd_dresses:
    clear_dialog
    play sound nkvd
    choice:
        talk nkvd talk "Steal and wear mothers dresses as child yes or no."
        "\\"Yes?\\"":
            jump nkvd_automobile
        "\\"No, I only started wearing dresses when I got older.\\"":
            add data.nkvd.agp 1
            jump nkvd_automobile
        "\\"I don't know?\\"":
            add data.nkvd.fake 1
            jump nkvd_automobile
        "\\"Dresses are such a vague concept... who can say... who can say...\\"" if $data.nkvd.orbDressesFail:
            add data.nkvd.fake 1
            add data.nkvd.agp 1
            jump nkvd_automobile
        roll nkvd_dresses_dresses_orb orb 40 "Orb?????":
            success "":
                talk orb talk "You only started wearing dresses after your started hormones. You couldn't imagine yourself in one before then, let alone look at yourself."
                if (roll nkvd_dresses_head_nightmare nightmare 20):
                    talk nightmare talk "<span class='nightmare'>Too big a head and too broad a shoulders. they look hideous on you. sorry. would have i mean. before you started hormones. lol. you look *very* brave now, when you wear one :-)</span>"
                else:
                    wait 1000
                jump nkvd_dresses
            failure "":
                set data.nkvd.orbDressesFail true
                talk orb talk "Depends what he means by 'dress' really. Is a skirt a dress? What about a kilt? A toga? A kimino?"
                jump nkvd_dresses

nkvd_automobile:
    clear_dialog
    play sound nkvd
    choice:
        talk nkvd talk "Drive automobile yes or no."
        "\\"Is that relevant?\\"":
            talk orb talk "Outside of the brain of this freak? No."
            jump nkvd_automobile
        "\\"Yes? I like to go fast in my automobile.\\"":
            add data.nkvd.fake 1
            jump nkvd_masturbation
        "\\"No? I like to walk / wander about / meander etc\\"":
            jump nkvd_masturbation
        "\\"I don't know?\\"":
            add data.nkvd.fake 1
            jump nkvd_masturbation
        "\\"I think I crashed my car.\\"" if $data.nkvd.orbCarFail:
            jump nkvd_masturbation
        roll nkvd_automobile_automobile_orb orb 40 "Orb do I drive an automobile?":
            success "":
                talk orb talk "Thankfully not, given your eyesight."
                jump nkvd_automobile
            failure "":
                set data.nkvd.orbCarFail true
                talk orb talk "I haven't seen an automobile at your cottage, have you? I suppose you *could* have crashed it somewhere, but I don't have much else to go on I'm afraid."
                jump nkvd_automobile
        
nkvd_masturbation:
    clear_dialog
    play sound nkvd
    choice:
        talk nkvd talk "Masturbate."
        "\\"Was that an order???\\"":
            talk lovely talk "It was a question, I think."
        "\\"Excuse me?\\"":
            talk lovely talk "It was a question, I think."
    clear_dialog
    play sound nkvd
    choice:
        talk nkvd talk "How masturbate. Explain."
        "\\"I don't.\\"":
            jump nkvd_shave
        "\\"The normal way.\\"":
            add data.nkvd.fake 2
            add data.nkvd.agp 1
            jump nkvd_shave
        "\\"The normal way, but girly.\\"":
            add data.nkvd.fake 1
            jump nkvd_shave
        "\\"I usually start by imagining I'm getting inflated with helium, like one of the blimps they used to hang over Lunden during the war, you know? Then someone presses a pin into me and I burst. In the imagination I mean, not real life. Anyway, I'm pulling myself off in real life while I think about this.\\"":
            add data.nkvd.agp 3
            jump nkvd_shave

nkvd_shave:
    clear_dialog
    if (!= $data.ghost.shaved true):
        play sound nkvd
        choice:
            talk nkvd talk "Specimen has not trimmed facial fuzz."
            "\\"Is *that* a question?\\"":
                play sound nkvd
                talk nkvd talk "Negative. Observation."
            "\\"Yes I did.\\" [Lie]":
                play sound nkvd
                talk nkvd talk "Specimen untruthful during assessment. Noted."
            "\\"I forgot.\\"":
                run skip
            "\\"So what some girls have scraggly little faces that's fine.\\"":
                play sound nkvd
                talk nkvd talk "Specimen detached from reality. Noted."
            "\\"Fuck! Shit fuck fuck!\\"":
                run skip
        add data.nkvd.fake 1
    jump nkvd_clean

nkvd_clean:
    clear_dialog
    if (|| (!= $data.ghost.hadBath true) (!= $data.ghost.cleanClothes true)):
        play sound nkvd
        choice:
            talk nkvd talk "Specimen is dirty."
            "[Nod] \\"Yes.\\"":
                run skip
            "\\"Women love girl musk.\\"":
                play sound nkvd
                talk nkvd talk "Incorrect. Women love heterosexual domesticity."
        add data.nkvd.unfit 1
    jump nkvd_dolls

nkvd_dolls:
    clear_dialog
    play sound nkvd
    choice:
        talk nkvd talk "Dolls as child yes or no."
        "\\I used to write stories and play pretend.\\"" if $data.nkvd.orbDollsSuccess:
            jump nkvd_permission
        "\\"I used to pretend I was a slice of cheese in a big sandwich and that a giant was going to eat me.\\"" if $data.nkvd.orbDollsFail:
            add data.nkd.agp 1
            jump nkvd_permission
        "\\"Yes? I played with dolls, if that's what you're asking.\\"":
            jump nkvd_permission
        "\\"No. I played with sticks and rocks. Occasionally chunks of asbestos or used syringes I found in peoples skips, when I was lucky.\\"":
            add data.nkvd.fake 1
            jump nkvd_permission
        "\\"Sometimes I wish I could be a ball jointed doll that sits on a shelf and doesn't have to think too hard, if that's what you mean?\\"":
            add data.nkvd.agp 3
            jump nkvd_permission
        roll nkvd_dolls_orb orb 40 "Orb, did I used to play with dolls as a child?":
            success "":
                set data.nkvd.orbDollsSuccess true
                talk orb talk "Not really no. You wrote a lot of stories and played pretend. Your parents wouldn't have bought you a doll either way. Too expensive."
                jump nkvd_dolls
            failure "":
                set data.nkvd.orbDollsFail true
                talk orb talk "Mostly you played a game where you were in a big sandwich being eaten by a giant."
                jump nkvd_dolls

nkvd_permission:
    clear_dialog
    play sound nkvd
    choice:
        talk nkvd talk "Permission received from partner yes or no."
        "\\"Permission?\\"":
            jump nkvd_permission
        "\\"Yes?\\"":
            jump nkvd_crossdressing_two
        "\\"No?\\"":
            add data.nkvd.fake 10
            jump nkvd_crossdressing_two
        "\\"I don't have a partner, I think.\\"":
            add data.nkvd.unfit 1
            jump nkvd_crossdressing_two

nkvd_crossdressing_two:
    clear_dialog
    play sound nkvd
    choice:
        talk nkvd talk "Parents crossdressers yes or no."
        "\\"Didn't you already ask this?\\"":
            play sound nkvd
            choice:
                talk nkvd talk "Yes or no."
                "\\"Yes?\\"":
                    add data.nkvd.agp 1
                    jump nkvd_fertile_menu
                "\\"No?\\"":
                    jump nkvd_fertile_menu
                "\\"I don't know?\\"":
                    jump nkvd_fertile_menu

nkvd_fertile_menu:
    clear_dialog
    play sound nkvd
    choice:
        talk nkvd talk "Fertility preservation sought out yes or no?"
        "\\"I'm not sure. How does that even work in 1928?\\"":
            choice:
                talk nasty talk "I can hook you up with a snowman if you want to freeze any of your spaff. I have contacts."
                "Thank you, Nasty Girl.":
                    talk nasty talk "No worries."
                    jump nkvd_sex_one

nkvd_sex_one:
    clear_dialog
    play sound nkvd
    choice:
        talk nkvd talk "Sex. Yes or no."
        "\\"I like sex, yes.\\"":
