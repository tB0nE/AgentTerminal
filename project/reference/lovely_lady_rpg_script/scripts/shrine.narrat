shrine:
    play sound click
    if (! (objective_started? dawnsight dawnsight)):
        choice:
            "There is a shrine dedicated to Saint Dawnsight in this clearing. Apparently. It's a little bit hard to find..."
            "[Try religion] <span class='prompt'>[[-1 ACTION]]</span>" if (>= $stats.actions.value 1):
                play sound spendAction
                set data.game_map.inMap false
                add_stat actions -1
                set_button button_shrine false
                run transition_black woods_one
                clear_dialog
            "<span class='prompt'>[[BACK]]</span>":
                jump game_map
        jump shrine_intro
    else:
        choice:
            "Saint Dawnsight has yet to return your calls. Perhaps today will be different?"
            "[Try religion] <span class='prompt'>[[-1 ACTION]]</span>" if (>= $stats.actions.value 1):
                play sound spendAction
                set data.game_map.inMap false
                add_stat actions -1
                set_button button_shrine false
                run transition_black shrine
                clear_dialog
            "<span class='prompt'>[[BACK]]</span>":
                jump game_map
        jump shrine_prayer_repeatable

shrine_intro:
    play ambient amb_clearing 1
    talk lovely talk "Oh me oh my! Aren't the woods simply splendid this time of year! The perfect backdrop for getting in touch with her holiness, m'thinks!"
    clear_dialog
    "It's true, <span class='goldItalic'>golden light</span> shines warmly though the orange leaves. The world is bathed in honey. Caramel. A white feather drifts through the trees ahead, caught in the breeze. A ladybug lands on your nose, skitters about, and then departs."
    clear_dialog
    if $data.cryptids.cryptidsDone:
        if $data.cryptids.scared:
            talk nasty talk "Let's just keep an look out in case that fucking beastie comes for us again, okay girls."
            talk lovely talk "One eye always behind our back, quite right, Nasty Girl! Orb, keep a look out."
            talk orb talk "Sigh."
        else:
            talk nasty talk "Yawn. Boring. The woods were more fun when we were beastie hunting. We should do more beastie hunting."
    else:
        talk nasty talk "Yawn. Boring. Woods are for beastie hunting, not god bothering."
        talk lovely talk "Her holiness always comes first, Nasty Girl. Your beastly beasties can wait."
    jump shrine_menu

shrine_menu:
    clear_dialog
    if (&& $data.shrine.searchedBurrow $data.shrine.searchedGrass $data.shrine.searchedWillpower $data.shrine.searchedClothes $data.shrine.searchedBrambles (! $data.shrine.shrineFound)):
        set data.shrine.shrineFound true
        "Just as all hope seems lost, you spot it. A weird green rock."
    choice:
        "The clearing doesn't live up to its name. It's covered in trees and undergrowth. Some particularly scary looking brambles are eyeing your girly little arms. It's going to take some searching to find this fucking shrine."
        "[Investigate the funny green rock]" if $data.shrine.shrineFound:
            jump shrine_rock
        "[Search inside a burrow]" if (! $data.shrine.searchedBurrow):
            set data.shrine.searchedBurrow true
            choice:
                "The burrow is just about big enough for an especially intrepid woman to poke her head into it. It's dark. There is no evidence of what might be inside..."
                "[Peer into the darkness from a safe distance]":
                    "There's no shrine down there, but there's *something*. A skittering sound echoes from somewhere deep inside the earth."
                "[Poke your nose in and give it a sniff]":
                    play sound punch
                    run transition_pain
                    choice:
                        "It smells of dirt, unsurprisingly, but there are other smells too. Ammonia. Decaying plant life. Spines. It smells quite strongly of spines, actually. You notice you now have a spine embedded in your nose like a new whisker, as you stand back up."
                        "\\"Yowch!\\" My poor nose! Oh me oh my!":
                            talk lovely talk "Goodness, are we under attack? What was that?"
            clear_dialog
            if (roll shrine_menu_burrow_orb orb 40):
                talk orb talk "A hedgehog."
                talk lovely talk "Hodge heg..."
                talk nasty talk "Hedge hogged..."
                if (roll shrine_menu_burrow_nightmare nightmare 60):
                    talk nightmare talk "<span class='nightmare'>you have a hog don't you?</span>"
                else:
                    wait 1000
            else:
                talk nasty talk "POSSIBLE CRYPTID???"
            jump shrine_menu
        "[Search the long grass]" if (! $data.shrine.searchedGrass):
            set data.shrine.searchedGrass true
            play sound rustle
            run transition_pain
            choice:
                "A sudden sharp pain runs up your leg. It doesn't hurt much, but you're quite prissy and notice it immediately."
                "\\"Yowch!\\"":
                    run transition_disease
                    run diseaseCounter
                    choice:
                        talk orb talk "Uh oh, I think that was a tick. You have Lyme disease now, sorry Ghost."
                        "A fate as bitter as the limes themselves... [Shake your head wearily and get back to traipsing through the grass]":
                            talk orb talk "I've been thinking, Ghost."
                            clear_dialog
                            choice:
                                talk orb talk "You and Saint Dawnsight aren't so different from one another, you know?"
                                "We aren't?":
                                    choice:
                                        talk orb talk "No. Two, basically normal women who have been, by the people of your country, transformed into something you are not. Her a saint, and you, a transexual demon on a quest to breakdown society. One who seeks to bring about the end times. The fall of the Impero Italiano."
                                        "Okay, but she's a Queen. That's not that normal.":
                                            talk orb talk "Okay sure. Fine."
                                        "She's a saint and I'm a demon? I feel like I got the raw end of this deal.":
                                            talk orb talk "Were Marigold alive today, she would be broken by the horror of what she has come to embody. The horrors done in her name. She would see herself as a demon."
                                            clear_dialog
                                            talk orb talk "My point is, neither of you deserve the lot you've been handed to you. To be moulded into a caricature to be obsessed over."
                                    clear_dialog
                                    talk lovely talk "A lovely analogy, darling, but not entirely true. Saint Dawnsight *isn't* a normal woman. She is the Divine itself."
                                    talk lovely talk "Her golden hair shields us from the darkness and her warm arms protect us from the cold! She is *nothing* like us, and if you continue your blasphemy I shall have to set you on fire."
                                    talk orb talk "See what I mean?"
            jump shrine_menu
        "[Tense your brain really hard in an attempt to divine the location of the shrine through sheer willpower]" if (! $data.shrine.searchedWillpower):
            set data.shrine.searchedWillpower true
            play sound punch
            run transition_pain
            choice:
                "A sharp stabbing pain hits your brain. A trickle of blood spills from your left nostril."
                "\\"AAGH!\\" I think I just gave myself brain damage!":
                    choice:
                        talk nasty talk "What else is new?"
                        "[Do it again]":
                            play sound punch
                            run transition_pain
                            choice:
                                "The pain repeats, worse this time. A jet of blood sprays from your right nostril and paints a bush red."
                                "\\"AAGH!\\" Why did I do that!?":
                                    talk orb talk "Am I expected to answer that?"
                            jump shrine_menu
                        "[Stop giving yourself brain damage]":
                            jump shrine_menu
        "[Search inside your own clothes, just in case]" if (! $data.shrine.searchedClothes):
            set data.shrine.searchedClothes true
            play sound clothing
            "You strip off your clothes and check inside them. Nope. No shrine, except to musk. No name tags either."
            clear_dialog
            talk nasty talk "Awooo! Don't put them back on! We're in the woods! You're supposed to be naked!"
            talk lovely talk "N- no! Ghost, darling, you can't be naked in the woods!"
            choice:
                talk nasty talk "Yes she can. She is right now, idiot."
                "[Put your clothes back on so Mia doesn't have to draw any additional backgrounds]":
                    play sound clothing
                    talk nasty talk "Cuck. Brain cuck."
            jump shrine_menu
        "[Search the horrible bramble bush]" if (! $data.shrine.searchedBrambles):
            set data.shrine.searchedBrambles true
            play sound rustle
            choice:
                "You search the brambles to no avail. All that hides inside the bush is pain. Pain and bugs."
                "\\"Yowch!\\" The whole world is against me! [Kick the bramble bush]":
                    play sound rustle
                    run transition_pain
                    jump shrine_menu
        roll shrine_rock_orb orb 60 "Orb, I tire of these games. Where's the fucking shrine?":
            success "":
                set data.shrine.shrineFound true
                choice:
                    talk orb talk "It's that funny green rock over there."
                    "I said where's the shrine, not where's the rock! Silly Orb!":
                        talk orb talk "Look, do you want my advice or not?"
                jump shrine_menu
            failure "":
                talk orb talk "Use your eyes, lazy girl."
                talk nasty talk "You don't know, do you, Orb?"
                talk orb talk "Fuck up 🖕"
                jump shrine_menu

shrine_rock:
    run transition shrine
    choice:
        "It's a weird green rock. Moss and lichen cling to it like scabs."
        "[Peel away a little bit of the moss and eat it]":
            set data.ghost.ateMoss true
            run transition_disease
            run diseaseCounter
            talk nasty talk "Nutrients..."
            if (roll shrine_rock_moss_orb orb 20):
                talk orb talk "Sporotrichosis..."
            else:
                wait 1000
        "[Peel away a little bit of the moss and don't do anything weird with it]":
            talk nasty talk "You're missing out on some vital nutrients, babe."
    clear_dialog
    choice:
        "Behind the moss there is stone. It has some kind of marking engraved into it, but it remains mostly obscured."
        "Holy crackers! This *is* more than just a weird green rock! [Peel away the rest of the moss]":
            complete_objective dawnsight shrine
            "Behind its green, fuzzy blanket, hides the shrine. It's inelegant, modest. A small crown carved into it the only thing setting it apart from any other rock."
    if (roll shrine_rock_idol_orb orb 40):
        talk orb talk "It's an older shrine. From before things got too out of hand on the idolatry front."
    else:
        wait 1000
    clear_dialog
    talk lovely talk "What now, Ghost? Might I suggest paying our respects to her holiness oh our golden shield oh our Divine?"
    talk nasty talk "Golden shower."
    talk lovely talk "Uniter of all peoples and strongest of all maidens oh our queen oh our saint?"
    talk nasty talk "Golden shower. Hello? Is no one listening to me?"
    clear_dialog
    choice:
        talk lovely talk "Give it a try, darling, say a little prayer for halcyon days."
        "[Kneel down in front of the shrine and pray]":
            start_objective dawnsight dawnsight
            jump shrine_prayer_repeatable

shrine_prayer_repeatable:
    clear_dialog
    set data.dawnsight.prayedToday true
    if (> $data.dawnsight.prayers 0):
        play ambient amb_clearing 1
        "The old stone shrine has waited patiently for you. A little bit of the moss has regrown."
        clear_dialog
    choice:
        "The moment you kneel your knees start to hurt. Pillow princess trait. You wriggle about until you find a comfortable position, and then make communion."
        "Ring ring. Hello Marigold! How are you doing today?" if $data.dawnsight.sawDawnsight:
            add data.dawnsight.prayers 1
            if (== $data.dawnsight.prayers 1):
                "A shiver runs down your neck. Not fear. Nor a chill. <span class='goldItalic'>Her</span> fingertips through your hair."
            if (== $data.dawnsight.prayers 2):
                "The feeling of a smile to your side. When you turn to look, there is nothing there, save <span class='goldItalic'>sun beams</span>."
            if (< $data.dawnsight.prayers 3):
                "A <span class='goldItalic'>kiss</span> on your cheek. <span class='goldItalic'>She</span> will answer when she is ready. Do not forget <span class='goldItalic'>her</span>."
            if (== $data.dawnsight.prayers 3):
                jump shrine_prayer
        "Saint Dawnsight, your holiness... are you there?":
            wait 4000
            clear_dialog
            "There is no response."
            if (roll shrine_prayer_repeatable_formal_lovely lovely 90):
                set data.dawnsight.sawDawnsight true
                talk lovely talk "Oh Ghost, you silly thing, you're being far too formal. Just say hello like you would anyone else!"
            reset_roll shrine_prayer_repeatable_formal_lovely
            talk nasty talk "Maybe she's asleep."
            choice:
                talk lovely talk "Asleep? Tsk. Never. Try again darling, sometimes the line gets a little fussy."
                "Ring ring. Hello Marigold! How are you doing today?" if $data.dawnsight.sawDawnsight:
                    add data.dawnsight.prayers 1
                    if (== $data.dawnsight.prayers 1):
                        "A shiver runs down your neck. Not fear. Nor a chill. <span class='goldItalic'>Her</span> fingertips through your hair."
                    if (== $data.dawnsight.prayers 2):
                        "The feeling of a smile to your side. When you turn to look, there is nothing there, save <span class='goldItalic'>sun beams</span>."
                    if (< $data.dawnsight.prayers 3):
                        "A <span class='goldItalic'>kiss</span> on your cheek. <span class='goldItalic'>She</span> will answer when she is ready. Do not forget <span class='goldItalic'>her</span>."
                    if (== $data.dawnsight.prayers 3):
                        jump shrine_prayer
                "Saint Dawnsight, oh shine upon me your <span class='goldItalic'>golden light</span>...":
                    wait 4000
                    clear_dialog
                    "Nothing."
                    clear_dialog
                    choice:
                        talk nasty talk "Bored. Can we go now?"
                        "I guess. I really did want to talk to her though...":
                            talk lovely talk "You'll get another chance one day, Ghost. She's always watching over us, you know?"
                            talk orb talk "Clearly."
    if (!= $data.shrine.orbEnding true):
        clear_dialog
        set data.shrine.orbEnding true
        choice:
            talk orb talk "Well. That was a waste of time. Do you feel any more religious, Ghost?"
            "My innards are literally clogged up with faith right now.":
                if (roll shrine_rock_clogged_orb orb 20):
                    talk orb talk "You're just constipated. Which is impressive, given I don't think I've ever seen you eat."
                talk lovely talk "Her <span class='gold'>golden light</span> fills *all* our holes, Ghost."
                clear_dialog
                choice:
                    talk orb talk "Let's go, shall we?"
                    "<span class='prompt'>[[CONTINUE]]</span>":
                        play sound spendAction
                        "<span class='goldItalic'>She</span> misses you already."
            "A bit, yes.":
                choice:
                    talk lovely talk "Hooray! Squeak squeak squeak! Isn't it wonderful, Ghost? Oh don't you feel her <span class='gold'>golden light</span> shine upon you?"
                    "[Shrug] Yeah I guess. <span class='prompt'>[[CONTINUE]]</span>":
                        play sound spendAction
                        talk lovely talk "You don't guess. You *know*."
            "Not really no.":
                choice:
                    talk lovely talk "Pah. Then try harder."
                    "I think I'll be okay, actually... <span class='prompt'>[[CONTINUE]]</span>":
                        play sound spendAction
                        talk lovely talk "Tsk. You'll be okay, but only because of her <span class='gold'>golden light</span> shining for your soul."
            "I've become less religious, actually. I fully intend to find and slay the creator in whatever disgusting form it takes. I spit on your idolatry. There is no god but mammal. Yawnsight more like. [Spit on their idolatry but have the wind blow the saliva right back onto your cheek]":
                choice:
                    talk orb talk "Right. Well. Let's go somewhere else to do it, yes?"
                    "[Kick the stupid shrine as hard as you can, but not break any toes because 'as hard as you can' is not very hard] Fine. <span class='prompt'>[[CONTINUE]]</span>":
                        play sound spendAction
                        complete_quest dawnsight dawnsightFailure
                        play sound punch
                        run transition_pain
                        "The shrine is unharmed."
        stop ambient 1
        jump goToGameMap
    else:
        choice:
            "Another day... perhaps tomorrow?"
            "<span class='prompt'>[[CONTINUE]]</span>":
                play sound spendAction
                stop ambient 1
                jump goToGameMap

shrine_prayer:
    clear_dialog
    add data.dream.womenOptions 1
    stop ambient 1
    play sound warm
    play music mayyourest
    run transition shrine_dawnsight
    set data.dawnsight.spokeToDawnsight true
    talk dawnsightDivine talk "Hello, Ghost."
    choice:
        talk dawnsightDivine talk "Your friend, Lovely Lady, she has told me ever so much about you, my daughter."
        "Holy smokes that prayer actually worked!?":
            talk dawnsightDivine talk "Prayer requires only faith, my daughter. Nothing more."
    clear_dialog
    if (== $data.shrine.searchedGrass true):
        talk dawnsightDivine talk "Your friend, Orb, they were right, Ghost. What you are in their minds is not who you are, my daughter. Only you know what you are. I know what I am, my daughter, and it is not a saint. I am just a little lady. Like you."
    talk dawnsightDivine talk "I have always watched over you. You, and every other lesbian. It is why I linger on. The <span class='gold'>golden light</span> you feel on your neck."
    clear_dialog
    choice:
        talk dawnsightDivine talk "But I am tired, my daughter. I cannot be there for you or for others always. I cannot be the one to make you smile. No, your smile is yours to find, and it may not be upon your face that it appears. Do you understand what it is I tell you?"
        "Kiss girls... make them smile... on it bosslady...":
            set data.shrine.kiss true
            talk dawnsightDivine talk "It is what I did, my daughter. I died for women, but even now they smile because of me. I would die again for them."
            if $data.dawnsight.sawWarrior:
                talk dawnsightWarrior talk "If, somehow, you have the strength for it, it is your heavenly ordained quest to make women happy. To take up the flaming sword."
            if $data.dawnsight.sawCartoon:
                talk dawnsightCartoon talk "WAHEY LEZZERS ON PAGE THREE WITH THEIR KNOCKERS TOUCHING ONLY TWENNY PENCE FOR A QUICK PEEK"
        "I should go out and find some hormones." if (&& (!= (objective_started? hrt usehrt true)) (!= (objective_completed? hrt usehrt) true) (!= (has_item? hrt) true)):
            set data.shrine.hormones true
            set data.dealer.stickers true
            talk dawnsightDivine talk "Yes, my daughter, you should. Seek moonlight. Bring to her the stars (only two Anglian pounds in the shop) themselves, and she shall guide you."
            if $data.dawnsight.sawWarrior:
                talk dawnsightWarrior talk "This is the fight you have been forced into, small or not in the greater scheme, it is your quest."
            if $data.dawnsight.sawCartoon:
                talk dawnsightCartoon talk "FUCK HORMONES. STOP THE FUCKING BOATS. THATS WHATS IMPORTANT. STOP THEM. STOP THEM YOU CUNT. BUY OUR NEWSPAPER. BUY OUR FUCKING NEWSPAPER YOU CUNT ITS ONLY 20 PENCE WHAT MORE DO YOU WANT? A NOVELTY FUCKING MP3 PLAYER? WELL LUCKY YOU, WE HAVE ONE. IS THAT WHAT YOU WANTED? EH? YOU CUNT." 
            if (!= (objective_started? hrt dealer) true):
                start_objective hrt dealer
        "I think so yes. You're saying I should telegram some death threats to the GIC. [Nod]" if (|| (== $data.nkvd.atPrivateAppt true) (== $data.global.gicAttended true)):
            set data.shrine.deaththreats true
            choice:
                talk dawnsightDivine talk "Would that makes you smile?"
                "It probably would, yes.":
                    talk dawnsightDivine talk "To smile in the face of horror takes great strength, my daughter, but it will not save you. Only you can change their wills. Not through mere words. Through actions. Through the spear and through the blood and through the faith."
                "It probably wouldn't, no.":
                    talk dawnsightDivine talk "Then think on what would, my daughter."
            if $data.dawnsight.sawWarrior:
                talk dawnsightWarrior talk "There are times for words, and there are times for deeds. When your head is between the demons' jaws, there is no time for debate. Remember, my child, that the world you seek is not one they would wish to live to see."
            if $data.dawnsight.sawCartoon:
                talk dawnsightCartoon talk "KILL KILL KILL KILL KILL. MORE GATEKEEPING. remember to subscribe to our newspaper to support our hard hitting journalism 10% off if you subscribe to a daily delivery now." 
        "I should pursue further political action with my chosen ideology of 'if you hate trans people kill yourself'.":
            set data.shrine.kys true
            choice:
                talk dawnsightDivine talk "Would that makes you smile?"
                "It probably would, yes.":
                    talk dawnsightDivine talk "To smile in the face of horror takes great strength, my daughter, but it will not save you. Only you can change their wills. Not through mere words. Through actions. Through the spear and through the blood and through the faith."
                "It probably wouldn't, no.":
                    talk dawnsightDivine talk "Then think on what would, my daughter."
            if $data.dawnsight.sawWarrior:
                talk dawnsightWarrior talk "There are times for words, and there are times for deeds. When your head is between the demons' jaws, there is no time for debate. Remember, my child, that the world you seek is not one they would wish to live to see."
            if $data.dawnsight.sawCartoon:
                talk dawnsightCartoon talk "RADICAL TRA THREATENS INNOCENT OPINION HAVER EXTRA EXTRA READ ALL ABOUT IT. remember to subscribe to our newspaper to support our hard hitting journalism 10% off if you subscribe to a daily delivery now." 
        "I'm beautiful the way I am.":
            set data.shrine.beautiful true
            talk dawnsightDivine talk "And yet you are not happy, my daughter."
            if $data.dawnsight.sawWarrior:
                talk dawnsightWarrior talk "The fight never ends. Beauty can always be tarnished. You must tear out their throats, before your bones show and your hair is shaved off."
            if $data.dawnsight.sawCartoon:
                talk dawnsightCartoon talk "NICE RACK ON PAGE 3 TODAY." 
        "Mutual aid, baby! You're telling me I should build communism!":
            set data.shrine.communism true
            talk dawnsightDivine talk "In a sense, yes, my daughter."
            if $data.dawnsight.sawWarrior:
                talk dawnsightWarrior talk "When marching together you are more than you. You are god."
            if $data.dawnsight.sawCartoon:
                talk dawnsightCartoon talk "MUTUAL AID COMMUNISM BAD FUCK COMMUNISTS FUCK SMELLY SOVIET REPUBLIC (except when they joined our side to fight the Imperials, in which case they are displaying virtue and leadership for the first time) FUCK COMMUNISTS FUCK FUCK STINK KILL THE JERRIES AND THE FUCKING MUSKIES." 
        "I should give up...":
            set data.shrine.giveUp true
            talk dawnsightDivine talk "No. Never."
            if $data.dawnsight.sawWarrior:
                talk dawnsightWarrior talk "Never ever. It is our duty to fight for a brighter world. If it kills us then we fall in the pursuit of life. If we kill it, it falls in the pursuit of life. When you understand this, you discover your true self."
            if $data.dawnsight.sawCartoon:
                talk dawnsightCartoon talk "WE WILL FIGHT THEM ON THE BEACHES FUCK THE JERRIES FUCK STUPID IDIOT WARSAWA COWARDS ANGLIA DID ALL THE WORK ANGLIA NEVER GIVE UP FUCK SMELLY WARSAWA AND FUCKIG FROGS CONTINENTAL BASTADS. lawn cutting service CHEAP enquire at the Little Donking garden centre for a free* quote <span class='small'>*eighty Anglian pounds.</span>"
        "I need to leave this horrible world and its horrible feelings behind. I need to find it, o' divine, I need to gaze upon the <span class='magenta'>magenta</span> spires." if (== $quests.sinner.objectives.woods.state "unlocked"):
            set data.shrine.cave true
            talk dawnsightDivine talk "A mile to the north there is a cave. I beseech thee to stay, my daughter, but I will not hold you here as a shepherd with a crook."
            if $data.dawnsight.sawWarrior:
                talk dawnsightWarrior talk "I marched once into oblivion, but to seek <span class='magenta'>magenta</span> is to go beyond that. To not be. To never have been. I would not wish it upon my worst enemy, let alone myself."
            if $data.dawnsight.sawCartoon:
                talk dawnsightCartoon talk "No don't do that... we rely on your subscriptions to keep our journalism afloat... noooooooo..... haha... maybe just donate a cheeky tenner a month 👀?"
            clear_dialog
            talk dawnsightDivine talk "It is a punishment to be sure, but what point has a ladies smile with the sentience to appreciate it."
        "I need to find some words to live by...":
            set data.shrine.boardgame true
            talk dawnsightDivine talk "<span class='boardgame'>'Gehen Sie Getreide oder gehen Sie nach Hause.'</span>"
            if $data.dawnsight.sawWarrior:
                talk dawnsightWarrior talk "Channel those words. They are eternal. The words that will carry you to victory in statehood."
            if $data.dawnsight.sawCartoon:
                talk dawnsightCartoon talk "MAYBE PLAY A PROPER ANGLIAN BOARDGAME LUV. SNAKES AND LADDERS."
    clear_dialog
    "A warm glow in your heart."
    clear_dialog
    choice:
        talk dawnsightDivine talk "My heart breaks for want to talk to you longer, but I cannot. It is not me who must bare your fate. It is you, Ghost."
        "Please don't go...":
            talk dawnsightDivine talk "Go? My daughter, I am never gone. I am always with you. A thousand times you have met me. A handful of times you have loved me."
            talk dawnsightDivine talk "The woman who blushed when she caught your eye on the locomotive. Your first kiss. The one you can still feel holding you, when you want to remember. The one you wrote poems about. The one you wish you could say sorry to."
            clear_dialog
            "In your soul."
            clear_dialog
    talk dawnsightDivine talk "Fare thee well now, my daughter. Know, in your heart, that no matter the horror in the world..."
    clear_dialog
    if $data.ghost.lobsterGirl:
        "Like a hot bath in the arms of a soft woman. Not so hot as to boil you to death though. Just hot enough to soothe your pink carapace. To massage your antenna with swirling currents of hot vapour."
    else:
        "Like a hot bath in the arms of a soft woman."
    clear_dialog
    stop music
    talk marigold talk "That I love you."
    clear_dialog
    play ambient amb_clearing 1
    run transition shrine
    wait 4000
    complete_objective dawnsight dawnsight
    complete_quest dawnsight dawnsightSuccess
    unlock_achievement dawnsight
    choice:
        talk orb talk "Ghost? Are you okay?"
        "I spoke to Saint Dawnsight. Or Marigold. I don't know what she prefers. I should ask her, really.":
            choice:
                talk lovely talk "You did!? Wheeee! I told you she would answer! What did she say, darling!?":
                "I need to go kiss some girls." if $data.shrine.kiss:
                    talk nasty talk "Fucking really? I could have told you that, love. Have done already."
                    talk lovely talk "A quest from the Divine... well, m'thinks there's little choice!"
                "I need some fucking oestrogen." if $data.shrine.hormones:
                    if (roll shrine_prayer_oestrogen_nightmare nightmare 40):
                        talk nightmare talk "<span class='nightmare'>Nah. the bitch is lying. You're good as you are.</spam>"
                    talk orb talk "Yes. I think we already knew this though, didn't we?"
                    talk lovely talk "Hush, Orb. Her holiness has simply reframed Ghost's struggle for oestrogen to more than just a medical issue. Indeed it is a holy war. A jihad."
                "I think she wants me to send death threats to the GIC. How do I send a telegram?" if $data.shrine.deaththreats:
                    talk orb talk "Tempting, but the Anglian Telecommunications Act means you can't just phone up the gender clinic and tell them to kill themselves. You'd be right to do it, but the police would get involved."
                "I think she wants me to tell transphobes to kill themselves." if $data.shrine.kys:
                    talk orb talk "Tempting, but the Anglian Telecommunications Act means you can't just phone up everyone who doesn't like you and tell them to kill themselves. You'd be right to do it, but the police would get involved."
                "[Blush] She called my beautiful. Pretty even." if $data.shrine.beautiful:
                    if (roll shrine_prayer_beautiful_nightmare nightmare 40):
                        talk nightmare talk "<span class='nightmare'>Lying bitch. She's a lying bitch, and you know it.</span>"
                    talk nasty talk "Heyyyyyyy. Nice. Did you get her telegram address? She's probably so down bad in that volcano or whatever."
                    talk lovely talk "Well you *are* beautiful, darling. She is as right as ever."
                "I think she wants me to build communism. I should probably make a start on that as soon as possible if I want to get it all done by the end of this week." if $data.shrine.communism:
                    talk orb talk "She- Okay. Fine."
                    clear_dialog
                    talk lovely talk "Squeel! No! My emeralds! Hissss!"
                "She told me to never give up." if $data.shrine.giveUp:
                    if (roll shrine_prayer_giveup_nightmare nightmare 40):
                        talk nightmare talk "<span class='nightmare'>You *should* give up, actually. she only told you that out of pity. she thinks your disgusting.</span>"
                        clear_dialog
                    talk orb talk "Sage advice. Good to see this country's saint has the same impact on your as a self help-book."
                    talk lovely talk "Tsk! You are ever so annoying, Orb."
                "She told me where to find it. The Seventh. I know it in my heart. I know I know." if $data.shrine.cave:
                    choice:
                        talk orb talk "She did, did she?"
                        "Ahhh... Absolution oh Absolution... Magenta oh yes, <span class='magenta'>magenta.":
                            set data.ghost.foundDeepCave true
                            talk lovely talk "Oh dear, darling. This sounds concerningly pagan... not at all what you were supposed to take away from this meeting... I'm keeping an eye on you, Ghost..."
                "She said something in like, Frankish or some shit. I didn't really get it tbh." if $data.shrine.boardgame:
                    talk orb talk "Great. Glad we came all the way out here just for that."
    clear_dialog
    choice:
        talk orb talk "Either way, you can think about your religious experience some more later. We have stuff to do."
        "<span class='prompt'>[[CONTINUE]]</span>":
            play sound spendAction
            stop ambient 1
            jump goToGameMap