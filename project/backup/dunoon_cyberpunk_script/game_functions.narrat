// GAME FUNCTIONS - Utility functions for Dunoon 2056
// Transitions, time tracking, skill checks, and other mechanics

// ==================== TRANSITION FUNCTIONS ====================

transition_instant newScreen:
    set_screen $newScreen
    play sound static_burst

transition newScreen:
    set_screen clear 1
    set data.transition.sprite (create_sprite img/backgrounds/transition.png 722.5 540)
    set data.transition.sprite.anchor.x 0.5
    set data.transition.sprite.anchor.y 0.5
    set data.transition.sprite.layer 1
    set data.transition.sprite.cssClass "slide-down slide-down-appear"
    play sound static_burst
    wait 10
    set data.transition.sprite.cssClass "slide-down"
    wait 1985
    set_screen $newScreen
    set data.transition.sprite.cssClass "slide-down slide-down-leave"
    wait 1985
    delete_sprite $data.transition.sprite
    empty_layer 1

transition_black newScreen:
    set_screen clear 1
    set_screen generic_black 1 fade 2000
    set_screen $newScreen
    if (== $newScreen "game_map"):
        run game_map_loadButtons
    if (== $newScreen "home_shack"):
        run home_shack_loadButtons
    wait 500
    set_screen clear 1 fade 2000
    empty_layer 1

transition_glitch newScreen:
    set_screen clear 1
    animate #narrat-app narrat-glitch
    play sound glitch_heavy
    set_screen $newScreen
    empty_layer 1

// ==================== TIME MANAGEMENT ====================

// Spend hours on actions
spend_hours amount:
    subtract data.time.hoursRemaining $amount
    add data.time.totalActions 1
    run check_time_warning
    if (<= $data.time.hoursRemaining 0):
        jump game_over

// Check if player should be warned about time
check_time_warning:
    if (== $data.time.hoursRemaining 25):
        talk survivor internal "25 hours left. We're running out of time."
    elseif (== $data.time.hoursRemaining 10):
        talk hacker internal "10 hours. The implant is failing faster. We need to finish this."
    elseif (== $data.time.hoursRemaining 5):
        talk ancestor internal "Five hours. Whatever we're going to do, we must do it now."
    elseif (<= $data.time.hoursRemaining 1):
        "The world is getting dark. Your vision flickers. Time is almost up."

// Display current time remaining
display_time:
    "<span class='timer'>TIME REMAINING: $data.time.hoursRemaining HOURS</span>"

// ==================== SKILL CHECK HELPERS ====================

// Hacker skill check with flavor text
hacker_check difficulty:
    if (roll hacker_check hacker $difficulty):
        return true
    else:
        return false

// Survivor skill check with flavor text  
survivor_check difficulty:
    if (roll survivor_check survivor $difficulty):
        return true
    else:
        return false

// Ancestor skill check with flavor text
ancestor_check difficulty:
    if (roll ancestor_check ancestor $difficulty):
        return true
    else:
        return false

// ==================== WORLD STATE ====================

update_weather:
    // Random weather changes
    set data.world.weather (random "clear" "hot" "windy" "dusty" "rain")
    
get_time_of_day:
    if (>= $data.time.hoursRemaining 75):
        set data.world.timeOfDay "morning"
    elseif (>= $data.time.hoursRemaining 50):
        set data.world.timeOfDay "afternoon"
    elseif (>= $data.time.hoursRemaining 25):
        set data.world.timeOfDay "evening"
    else:
        set data.world.timeOfDay "night"

// ==================== IMPLANT MECHANICS ====================

check_implant_status:
    if (>= $data.time.hoursRemaining 75):
        talk hacker internal "Implant status: Damaged but stable. We have time."
    elseif (>= $data.time.hoursRemaining 50):
        talk hacker internal "Implant status: Degradation accelerating. We need to find answers soon."
    elseif (>= $data.time.hoursRemaining 25):
        talk hacker internal "Implant status: Critical. Memory retrieval becoming difficult."
    else:
        talk hacker internal "Implant status: Terminal. We're living on borrowed time."

// Attempt to recover a memory (costs hours)
recover_memory:
    run spend_hours 5
    set data.player.memoriesRecovered (+ $data.player.memoriesRecovered 1)
    "You dive into your fractured consciousness, searching for fragments of yourself..."
    clear_dialog
    if (roll memory_recovery ancestor 40):
        "A memory surfaces, sharp and clear for a moment before fading..."
        return true
    else:
        "Nothing. Static. The corruption is too deep."
        return false

// ==================== RELATIONSHIP TRACKING ====================

modify_relationship character amount:
    if (== $character "mamaNomi"):
        add data.relationships.mamaNomi $amount
    elseif (== $character "tango"):
        add data.relationships.tango $amount
    elseif (== $character "silas"):
        add data.relationships.silas $amount
    elseif (== $character "netrunnerCollective"):
        add data.relationships.netrunnerCollective $amount

check_relationship character:
    if (== $character "mamaNomi"):
        return $data.relationships.mamaNomi
    elseif (== $character "tango"):
        return $data.relationships.tango
    elseif (== $character "silas"):
        return $data.relationships.silas
    elseif (== $character "netrunnerCollective"):
        return $data.relationships.netrunnerCollective

// ==================== HACKING MECHANICS ====================

// Basic hack attempt
attempt_hack difficulty:
    run spend_hours 2
    "You close your eyes and reach into the Net..."
    clear_dialog
    if (roll hack_attempt hacker $difficulty):
        play sound hack_success
        talk hacker internal "Got it. The code flows like water."
        return true
    else:
        play sound hack_fail
        talk hacker internal "Damn. Security's tighter than I thought."
        return false

// Deep dive (more hours, higher difficulty possible)
deep_dive difficulty:
    run spend_hours 5
    "You plunge deep into the virtual architecture, risking everything..."
    clear_dialog
    animate #narrat-app narrat-glitch
    play sound deep_dive
    if (roll deep_dive_attempt hacker $difficulty):
        play sound hack_success
        "The data opens before you like a flower."
        return true
    else:
        play sound hack_fail
        "ICE tears at your consciousness. You barely escape with your mind intact."
        run spend_hours 3
        return false

// ==================== COMBAT/SURVIVAL ====================

// Street smart check for danger
detect_danger:
    if (roll danger_detection survivor 30):
        talk survivor internal "Something's wrong. Watch your back."
        return true
    else:
        return false

// Attempt to flee
flee_attempt:
    if (roll flee_roll survivor 40):
        "You melt into the shadows, another ghost in the township."
        return true
    else:
        "There's nowhere to run. You'll have to face this."
        return false

// ==================== DIALOGUE HELPERS ====================

// Show all three voices reacting to something
all_voices_react:
    talk hacker internal "Interesting. This changes our calculations."
    talk survivor internal "Doesn't change anything. We still need to survive."
    talk ancestor internal "Everything changes, and nothing changes. We move forward."

// Show two voices arguing
voices_argue voiceOne voiceTwo:
    if (&& (== $voiceOne "hacker") (== $voiceTwo "survivor")):
        talk hacker internal "We need to take risks. The data is everything."
        talk survivor internal "Risk gets you killed. We play it safe."
    elseif (&& (== $voiceOne "hacker") (== $voiceTwo "ancestor")):
        talk hacker internal "Technology is the answer. It always is."
        talk ancestor internal "Technology is a tool. People are the answer."
    elseif (&& (== $voiceOne "survivor") (== $voiceTwo "ancestor")):
        talk survivor internal "Trust no one. Everyone has an angle."
        talk ancestor internal "Trust is how we survive. Not alone, but together."

// ==================== BUTTON MANAGEMENT ====================

hide_all_buttons:
    set_button button_home_shack hidden
    set_button button_mama_nomi hidden
    set_button button_tango hidden
    set_button button_silas hidden
    set_button button_net_cafe hidden
    set_button button_market hidden
    set_button button_clinic hidden
    set_button button_abandoned_lot hidden
    set_button button_wine_farm hidden
    set_button button_beach hidden

show_button buttonName:
    set_button $buttonName true

grey_button buttonName:
    set_button $buttonName greyed

// ==================== MISC UTILITIES ====================

skip:
    set doesNothing true

save_prompt:
    "<span class='prompt'>[Game saved automatically]</span>"

hours_display:
    "<span class='timer'>[$data.time.hoursRemaining HOURS REMAINING]</span>"
