// DUNOON TOWNSHIP - Outside exploration
// Additional locations, NPCs, and side quests

// ==================== MARKET ====================

location_market:
    run transition market_day
    set data.game_map.inMap false
    set data.game_map.currentLocation "market"
    
    clear_dialog
    "Dunoon Market. A chaotic sprawl of stalls, blankets, and improvised shops."
    clear_dialog
    "Here you can buy almost anything—if you have the credits."
    clear_dialog
    
    jump market_main

market_main:
    clear_dialog
    run hours_display
    clear_dialog
    
    choice:
        "The market buzzes with activity. What do you do?"
        
        "[Browse the stalls]":
            jump market_browse
        
        "[Look for information]" if (!= $data.market.lookedForInfo true):
            set data.market.lookedForInfo true
            run spend_hours 1
            jump market_info
        
        "[Find a fence]" if (&& (>= $data.skills.survivor 2) (!= $data.market.foundFence true)):
            set data.market.foundFence true
            jump market_fence
        
        "[Talk to the street kids]" if (!= $data.market.talkedToKids true):
            set data.market.talkedToKids true
            run spend_hours 1
            jump market_kids
        
        "[Leave] <span class='prompt'>[[BACK TO MAP]]</span>":
            jump game_map

market_browse:
    clear_dialog
    "You wander through the market, looking at what's available."
    clear_dialog
    
    choice:
        "What catches your eye?"
        
        "[Food stall] - Hot meal (5 credits)" if (>= $data.inventory.credits 5):
            set data.inventory.credits (- $data.inventory.credits 5)
            "You buy a bowl of stew and some bread. It's not fancy, but it fills your stomach."
            clear_dialog
            if (roll market_food survivor 30):
                talk survivor internal "Good choice. Keep your strength up."
        
        "[Tech dealer] - Various electronics":
            jump market_tech
        
        "[Clothes vendor] - Practical clothing":
            jump market_clothes
        
        "[Herbalist] - Traditional medicines":
            jump market_herbalist
        
        "[Back]":
            jump market_main

market_tech:
    clear_dialog
    "A stall piled high with scavenged electronics. Old phones, broken screens, tangled cables."
    clear_dialog
    "The dealer eyes you with suspicion."
    clear_dialog
    
    choice:
        "What do you want to buy?"
        
        "[Basic toolkit] - 15 credits" if (&& (!= (has_item? toolkit) true) (>= $data.inventory.credits 15)):
            set data.inventory.credits (- $data.inventory.credits 15)
            add_item toolkit 1
            "A basic set of tools. Useful for repairs."
            add_level hacker 1
        
        "[Signal booster] - 25 credits" if (&& (!= (has_item? signal_booster) true) (>= $data.inventory.credits 25)):
            set data.inventory.credits (- $data.inventory.credits 25)
            add_item signal_booster 1
            "Boosts your neural deck's range. Helpful for hacking at a distance."
        
        "[Used credchip] - 10 credits" if (>= $data.inventory.credits 10):
            set data.inventory.credits (- $data.inventory.credits 10)
            "You buy a used credchip. It has 20 credits on it."
            add data.inventory.credits 20
            if (roll credchip_bonus survivor 40):
                "Wait—there's more. Hidden files. You'll need to crack them later."
                add_item credchip_files 1
        
        "[Ask about neural implants]" if (!= $data.market.askedAboutImplants true):
            set data.market.askedAboutImplants true
            talk tech_dealer talk "Neural implants? You're better off going to Tango. He's the only one in Dunoon who really understands that tech."
            talk tech_dealer talk "Though... there was someone else. A doctor. Used to come through here buying medical supplies. Haven't seen her in weeks."
            talk hacker internal "A doctor. Someone who might know about implants. Worth investigating."
            set data.quests.knowAboutDoctor true
        
        "[Back]":
            jump market_browse

market_clothes:
    clear_dialog
    "Battered clothing hangs from lines. Everything is second-hand, third-hand, tenth-hand."
    clear_dialog
    
    choice:
        "What do you want to buy?"
        
        "[Armored jacket] - 30 credits" if (&& (!= (has_item? armored_jacket) true) (>= $data.inventory.credits 30)):
            set data.inventory.credits (- $data.inventory.credits 30)
            add_item armored_jacket 1
            "A jacket with hidden reinforcement. Won't stop a bullet, but might help in a fight."
            add_level survivor 1
        
        "[Dark clothes] - 10 credits" if (&& (!= (has_item? dark_clothes) true) (>= $data.inventory.credits 10)):
            set data.inventory.credits (- $data.inventory.credits 10)
            add_item dark_clothes 1
            "Dark, nondescript clothing. Good for blending in."
        
        "[Work boots] - 15 credits" if (&& (!= (has_item? work_boots) true) (>= $data.inventory.credits 15)):
            set data.inventory.credits (- $data.inventory.credits 15)
            add_item work_boots 1
            "Sturdy boots. Your feet will thank you."
        
        "[Back]":
            jump market_browse

market_herbalist:
    clear_dialog
    "An old woman sits behind a table covered in jars, pouches, and dried plants."
    clear_dialog
    talk herbalist talk "You look sick. Inside. Something wrong with your head, yes?"
    clear_dialog
    
    choice:
        "What do you say?"
        
        "Can you help me?":
            talk herbalist talk "I can give you something for the pain. Something to help you sleep. Something to strengthen your spirit."
            talk herbalist talk "But what's wrong with you—that's not something herbs can fix. You need a different kind of healing."
            talk ancestor internal "She speaks true. The body can be healed. The mind... that requires different medicine."
        
        "What do you recommend?":
            jump market_herbalist_buy
        
        "I'm fine.":
            talk herbalist talk "Mm. We all say that. Doesn't make it true."
    
    jump market_browse

market_herbalist_buy:
    choice:
        "What do you want to buy?"
        
        "[Pain medicine] - 5 credits" if (>= $data.inventory.credits 5):
            set data.inventory.credits (- $data.inventory.credits 5)
            add_item pain_meds 1
            "A pouch of herbs that help with headaches."
        
        "[Sleep aid] - 5 credits" if (>= $data.inventory.credits 5):
            set data.inventory.credits (- $data.inventory.credits 5)
            add_item sleep_aid 1
            "A tea that promotes restful sleep."
        
        "[Spirit tonic] - 15 credits" if (>= $data.inventory.credits 15):
            set data.inventory.credits (- $data.inventory.credits 15)
            add_item spirit_tonic 1
            "A bitter liquid that "clears the mind and strengthens the soul.""
            add_level ancestor 1
        
        "[Back]":
            jump market_herbalist

market_info:
    clear_dialog
    "You ask around about neural implants, about the wine farms, about anything that might help you understand what happened."
    clear_dialog
    
    if (roll market_rumors survivor 40):
        "A vendor leans in close."
        clear_dialog
        talk vendor talk "You want to know about the farms? Bad things happening there. Workers going missing. Strange lights at night."
        talk vendor talk "They say the corps are experimenting on people. Turning them into... something else."
        talk survivor internal "Experiments. That tracks with what was done to us."
        set data.quests.knowAboutExperiments true
    else:
        "People are wary of strangers asking questions. You'll need to build more trust before they'll talk."
    
    if (roll market_info_hacker hacker 30):
        "You overhear a conversation between two techies:"
        clear_dialog
        "\"Did you hear? Someone cracked the Aries Corp firewall last week. Stole a bunch of files.\""
        "\"Yeah? Who?\""
        "\"Dunno. But they're probably dead by now. Aries doesn't forgive.\""
        talk hacker internal "Aries Corp. That name... it's in the encrypted partition. We need to remember why."
        set data.quests.knowAboutAries true
    
    jump market_main

market_fence:
    clear_dialog
    "You find a man selling things that probably don't belong to him."
    clear_dialog
    talk fence talk "You look like someone who appreciates... alternative commerce."
    clear_dialog
    
    choice:
        "What are you looking for?"
        
        "[Sell items]":
            if (has_item? shiv):
                "Sell shiv for 10 credits?"
                choice:
                    "Yes":
                        remove_item shiv 1
                        add data.inventory.credits 10
                    "No":
                        jump market_fence
            else:
                "You have nothing to sell."
        
        "[Buy illegal goods]":
            jump market_fence_buy
        
        "[Ask about the underground]":
            talk fence talk "The underground? You mean the resistance? The Netrunners?"
            talk fence talk "I don't know nothing about that. And if I did, I wouldn't tell a stranger."
            talk survivor internal "He knows something. But he's not going to talk without a reason."
        
        "[Back]":
            jump market_main

market_fence_buy:
    choice:
        "What do you want?"
        
        "[Fake ID] - 40 credits" if (&& (!= (has_item? fake_id) true) (>= $data.inventory.credits 40)):
            set data.inventory.credits (- $data.inventory.credits 40)
            add_item fake_id 1
            "A decent fake. Might get you past basic security."
        
        "[Lockpicks] - 20 credits" if (&& (!= (has_item? lockpicks) true) (>= $data.inventory.credits 20)):
            set data.inventory.credits (- $data.inventory.credits 20)
            add_item lockpicks 1
            "A set of lockpicks. Useful for physical security."
        
        "[Stolen access codes] - 30 credits" if (&& (!= (has_item? access_codes) true) (>= $data.inventory.credits 30)):
            set data.inventory.credits (- $data.inventory.credits 30)
            add_item access_codes 1
            "Codes to a corporate building downtown. Might be useful, might be expired."
        
        "[Back]":
            jump market_fence

market_kids:
    clear_dialog
    "A group of street kids watches you. The oldest can't be more than twelve."
    clear_dialog
    
    choice:
        "How do you approach them?"
        
        "[Give them food]" if (>= $data.inventory.credits 5):
            set data.inventory.credits (- $data.inventory.credits 5)
            "You buy some food and hand it out. They look at you with something like respect."
            clear_dialog
            talk street_kid talk "You're not like the others. You're from here."
            talk street_kid talk "We seen people looking for you. Bad people. Corporate types."
            talk survivor internal "They're tracking us. We need to be more careful."
            set data.quests.corpsTracking true
        
        "[Ask them questions]":
            "They're suspicious at first, but you speak to them in the right way. Street to street."
            clear_dialog
            talk street_kid talk "You want to know about the farms? We sneak up there sometimes. Steal fruit."
            talk street_kid talk "But lately there's more guards. And we seen them taking people in. Never seen them come out."
            talk survivor internal "People going in but not coming out. That's a death camp. Or worse."
        
        "[Offer them credits for information]" if (>= $data.inventory.credits 10):
            set data.inventory.credits (- $data.inventory.credits 10)
            "Credits change hands. Information follows."
            clear_dialog
            talk street_kid talk "There's a man. Silas. He lives in the abandoned lot. Helps people like us."
            talk street_kid talk "He knew you. Before. He might know what happened."
            set data.quests.silasKnows true
            set data.quests.knowAboutSilas true
    
    jump market_main

// ==================== NET CAFE ====================

location_net_cafe:
    run transition net_cafe
    set data.game_map.inMap false
    set data.game_map.currentLocation "net_cafe"
    
    clear_dialog
    "The Net Cafe. A cramped room full of old terminals and desperate people."
    clear_dialog
    "The smell of sweat and burnt circuits. The glow of screens."
    clear_dialog
    
    jump net_cafe_main

net_cafe_main:
    clear_dialog
    run hours_display
    clear_dialog
    
    choice:
        "What do you do?"
        
        "[Use a terminal] - Cost: 1 hour" if (>= $data.time.hoursRemaining 3):
            run spend_hours 1
            jump net_cafe_terminal
        
        "[Talk to the owner]" if (!= $data.netCafe.talkedToOwner true):
            set data.netCafe.talkedToOwner true
            jump net_cafe_owner
        
        "[Look for other hackers]" if (>= $data.skills.hacker 2):
            jump net_cafe_hackers
        
        "[Access the deep Net]" if (&& (has_item? neural_deck) (>= $data.skills.hacker 3)):
            run spend_hours 3
            jump net_cafe_deep
        
        "[Leave] <span class='prompt'>[[BACK TO MAP]]</span>":
            jump game_map

net_cafe_terminal:
    clear_dialog
    "You sit at a terminal and start searching."
    clear_dialog
    
    set data.netCafe.searchResult (random 1 4)
    
    if (== $data.netCafe.searchResult 1):
        "You find news reports about increased corporate activity in the wine region."
        clear_dialog
        talk hacker internal "Something's happening out there. Something big."
    
    elseif (== $data.netCafe.searchResult 2):
        "You find a forum for neural implant users. A thread about memory recovery catches your eye."
        clear_dialog
        "\"The key is not to force it. Let the memories come naturally. Strong emotions can trigger recall.\""
        talk ancestor internal "Wise. The harder we grasp, the more slips through our fingers."
    
    elseif (== $data.netCafe.searchResult 3):
        "You find a help wanted ad: <span class='writtenText'>\"Test subjects needed for medical research. Good pay. No questions asked.\"</span>"
        clear_dialog
        talk survivor internal "That's how they get you. How they got us, maybe."
    
    else:
        "You find nothing useful. Just noise and distraction."
    
    jump net_cafe_main

net_cafe_owner:
    clear_dialog
    "The owner is a middle-aged woman with tired eyes and calloused fingers."
    clear_dialog
    talk net_cafe_owner talk "You're the one Mama Nomi found. The amnesiac."
    clear_dialog
    talk net_cafe_owner talk "I've seen your type before. Running from something. Running toward something."
    clear_dialog
    talk net_cafe_owner talk "The Net remembers everything. If you want to know who you are, start there."
    clear_dialog
    
    choice:
        "What do you ask?"
        
        "How do I search for my past?":
            talk net_cafe_owner talk "Start with what you know. Names. Places. Dates. Even fragments can lead somewhere."
            talk net_cafe_owner talk "And be careful. The Net has eyes everywhere."
        
        "Do you know anything about me?":
            talk net_cafe_owner talk "I know you came in here before. Maybe a month ago. Used the terminals for hours."
            talk net_cafe_owner talk "You were searching for something. I don't know what. But you looked scared when you left."
            set data.netCafe.wasHereBefore true
        
        "What's the deep Net?":
            talk net_cafe_owner talk "The deep Net is where the real information lives. And the real danger."
            talk net_cafe_owner talk "Corporate secrets. Government black sites. Things they don't want us to know."
            talk net_cafe_owner talk "If you want to go there, you need better equipment than these terminals."
    
    jump net_cafe_main

net_cafe_hackers:
    clear_dialog
    "You spot them in the corner—heads together, speaking in low voices. The body language of people who know things."
    clear_dialog
    
    if (roll hacker_recognize hacker 40):
        "One of them looks up. His eyes widen."
        clear_dialog
        talk hacker_npc talk "Kundai? Is that you? We thought you were dead."
        clear_dialog
        "They know you."
        clear_dialog
        jump net_cafe_collective_meeting
    else:
        "They look at you, assess you, decide you're not a threat. Or not worth their time."
        clear_dialog
        "You'll need to prove yourself before they'll talk."
    
    jump net_cafe_main

net_cafe_collective_meeting:
    clear_dialog
    "The hackers invite you to sit. They explain."
    clear_dialog
    talk hacker_npc talk "You were one of us. The Netrunner Collective. We fight the corps, expose their secrets."
    talk hacker_npc talk "You were working on something big. Something about the wine farms. Then you disappeared."
    clear_dialog
    talk hacker_npc talk "We found your safehouse. The shack. But you were gone."
    clear_dialog
    "A collective memory surfaces. These are your people. Your comrades."
    clear_dialog
    
    set data.player.memoriesRecovered (+ $data.player.memoriesRecovered 1)
    set data.quests.metCollective true
    run modify_relationship "netrunnerCollective" 3
    
    choice:
        "What do you ask?"
        
        "What was I working on?":
            talk hacker_npc talk "Project Lazarus. A black-site experiment program. The corps are using people as test subjects."
            talk hacker_npc talk "You were trying to get evidence. Proof. Something to blow the whole thing open."
            set data.quests.knowAboutLazarus true
        
        "Who did this to me?":
            talk hacker_npc talk "We don't know for sure. But there are rumors. Aries Corp security. Or maybe someone on the inside."
            talk hacker_npc talk "You were paranoid at the end. Said you couldn't trust anyone."
        
        "Can you help me?":
            talk hacker_npc talk "We can try. But you're not the same person. The implant damage... it's changed you."
            talk hacker_npc talk "We'll share information. Help you remember. But you'll have to do the heavy lifting yourself."
            add_level hacker 1
    
    jump net_cafe_main

net_cafe_deep:
    clear_dialog
    "You jack into the deep Net. The world dissolves into light and code."
    clear_dialog
    "Here, you're not a body in a shack. You're pure information. Pure potential."
    clear_dialog
    
    if (roll deep_net_explore hacker 50):
        "You navigate the data streams with instinctive grace. Your old self knew this place well."
        clear_dialog
        
        // Random discovery
        set data.deepNet.finding (random 1 3)
        
        if (== $data.deepNet.finding 1):
            "You find a hidden file server. Inside: partial records of Project Lazarus."
            clear_dialog
            "Subject names. Experiment parameters. And a location: the old winery on the hill."
            set data.quests.foundWineryLocation true
            set data.player.memoriesRecovered (+ $data.player.memoriesRecovered 1)
        
        elseif (== $data.deepNet.finding 2):
            "You find a message, addressed to you, left in a dead drop."
            clear_dialog
            "\"Kundai, if you're reading this, I'm sorry. They got to me. The evidence is hidden at Mama Nomi's. In the back room. Trust no one. - S\""
            set data.quests.foundMessage true
        
        else:
            "You find traces of your own digital footprint. Posts, messages, searches."
            clear_dialog
            "You were searching for someone. A family member. Your mother, maybe."
            talk ancestor internal "We were looking for our roots. Even before we lost our memory."
    
    else:
        "The deep Net fights back. ICE attacks your consciousness. You barely escape."
        clear_dialog
        run spend_hours 2
        talk survivor internal "Too risky. We need to be more careful."
    
    jump net_cafe_main

// ==================== CLINIC ====================

location_clinic:
    run transition clinic
    set data.game_map.inMap false
    set data.game_map.currentLocation "clinic"
    
    clear_dialog
    "The Dunoon Community Clinic. Underfunded. Overcrowded. Essential."
    clear_dialog
    "The smell of antiseptic and despair. People waiting on benches, hoping for help that might not come."
    clear_dialog
    
    jump clinic_main

clinic_main:
    clear_dialog
    run hours_display
    clear_dialog
    
    choice:
        "What do you do?"
        
        "[See a doctor] - Cost: 3 hours" if (>= $data.time.hoursRemaining 5):
            run spend_hours 3
            jump clinic_doctor
        
        "[Talk to patients]" if (!= $data.clinic.talkedToPatients true):
            set data.clinic.talkedToPatients true
            run spend_hours 1
            jump clinic_patients
        
        "[Look for medical records]" if (>= $data.skills.hacker 2):
            jump clinic_records
        
        "[Leave] <span class='prompt'>[[BACK TO MAP]]</span>":
            jump game_map

clinic_doctor:
    clear_dialog
    "A tired doctor sees you. Her eyes are kind but haunted."
    clear_dialog
    talk doctor talk "Neural implant damage. I can see it in your eyes. The flicker."
    clear_dialog
    talk doctor talk "I can't fix it. But I can give you something for the symptoms. Slow the degradation."
    clear_dialog
    
    choice:
        "What do you say?"
        
        "Please. I need more time.":
            talk doctor talk "I can give you stimulants. Keep you going. But it's borrowing from tomorrow."
            add_item medical_stims 1
            add data.time.hoursRemaining 5
            "You feel a brief surge of clarity. The countdown has slowed, for now."
        
        "Do you know what caused this?":
            talk doctor talk "I've seen this before. Neural burnout. Usually from... forced extraction."
            talk doctor talk "Someone tried to pull information from your implant. Roughly. Without proper protocols."
            talk hacker internal "Interrogation. They were trying to get something from us."
        
        "Have you seen others like me?":
            talk doctor talk "...Yes. A few. They didn't last long. The damage was too severe."
            talk doctor talk "You're the first one who's been able to walk in here."
            talk survivor internal "We're stronger than the others. Or luckier."
    
    jump clinic_main

clinic_patients:
    clear_dialog
    "You talk to the people waiting. They have stories."
    clear_dialog
    
    "A man with a cybernetic arm that's malfunctioning:"
    talk patient talk "The corps promise us augmentations. Better lives. Then they abandon us when things go wrong."
    
    "A woman with a persistent cough:"
    talk patient talk "The dust from the mines. Gets in your lungs. No one cares about us poor folk."
    
    "A young man with vacant eyes:"
    talk patient talk "He was normal a month ago. Then he took a job at the farms. Came back like this."
    talk survivor internal "Another victim. Whatever they're doing out there, it's destroying people."
    
    jump clinic_main

clinic_records:
    clear_dialog
    "You sneak toward the back, looking for the records room."
    clear_dialog
    
    if (roll clinic_sneak survivor 40):
        "You find a terminal. Quick hacking while no one's looking."
        clear_dialog
        
        if (roll clinic_hack hacker 50):
            "Medical records flash past. You find something: your name. Admitted three weeks ago. Neural trauma. Discharged AMA."
            clear_dialog
            "Signed by: Dr. A. Okonkwo. And a note: <span class='writtenText'>\"Patient claims memory tampering. Recommend psych evaluation.\"</span>"
            set data.clinic.foundRecord true
            set data.quests.knowAboutOkonkwo true
            talk hacker internal "Dr. Okonkwo. Either they didn't believe us, or they were paid not to."
        else:
            "The terminal is locked down. You can't get in without alerting someone."
    else:
        "A nurse spots you."
        talk nurse talk "Can I help you with something?"
        "You back off, muttering an excuse."
    
    jump clinic_main

// ==================== ABANDONED LOT ====================

location_abandoned_lot:
    run transition abandoned_lot
    set data.game_map.inMap false
    set data.game_map.currentLocation "abandoned_lot"
    
    clear_dialog
    "An abandoned lot on the edge of Dunoon. Shacks in progress. Trash. Graffiti."
    clear_dialog
    "And a man sitting on a crate, watching you."
    clear_dialog
    
    jump lot_main

lot_main:
    clear_dialog
    
    if (!= $data.lot.metSilas true):
        jump lot_meet_silas
    
    run hours_display
    clear_dialog
    
    choice:
        "What do you do?"
        
        "[Talk to Silas]":
            jump lot_talk_silas
        
        "[Ask about the Collective]" if $data.quests.metCollective:
            jump lot_collective_info
        
        "[Ask about Project Lazarus]" if $data.quests.knowAboutLazarus:
            jump lot_lazarus_info
        
        "[Rest here] - Cost: 1 hour" if (>= $data.time.hoursRemaining 3):
            run spend_hours 1
            "You sit in silence. Silas respects your need for quiet."
            jump lot_main
        
        "[Leave] <span class='prompt'>[[BACK TO MAP]]</span>":
            jump game_map

lot_meet_silas:
    set data.lot.metSilas true
    clear_dialog
    talk silas talk "Kundai. You're alive."
    clear_dialog
    "He doesn't sound happy. Or sad. Just... resigned."
    clear_dialog
    talk silas talk "I heard what happened. The implant. The memory loss."
    clear_dialog
    talk silas talk "You probably don't remember me. But I remember you. We were friends once. Comrades."
    clear_dialog
    
    choice:
        "How do you respond?"
        
        "Tell me who I was.":
            jump silas_backstory
        
        "What happened to me?":
            jump silas_explanation
        
        "I don't trust you.":
            talk silas talk "Good. Trust no one. That's what you taught me."
            talk silas talk "But if you want answers, I'm one of the few who has them."
    
    run modify_relationship "silas" 1
    jump lot_main

silas_backstory:
    clear_dialog
    talk silas talk "You came to Dunoon two years ago. Running from something—you never said what."
    talk silas talk "You had skills. Hacking. Tech. You used them to help people. Exposed a landlord who was poisoning his tenants."
    talk silas talk "That's when the Collective noticed you. They recruited you. You became one of their best."
    clear_dialog
    talk silas talk "Then you found out about Project Lazarus. You became obsessed. Said you were going to bring the whole thing down."
    talk silas talk "And then you disappeared."
    clear_dialog
    set data.player.memoriesRecovered (+ $data.player.memoriesRecovered 1)
    jump lot_main

silas_explanation:
    clear_dialog
    talk silas talk "I don't know everything. But I know you were captured. Held somewhere."
    talk silas talk "When you got back, you were different. Couldn't remember anything. Kept asking who you were."
    talk silas talk "Mama Nomi found you wandering the streets. Brought you to your old shack. Said you'd wake up or you wouldn't."
    clear_dialog
    talk silas talk "The fact that you're standing here... you're stronger than most."
    clear_dialog
    jump lot_main

lot_talk_silas:
    clear_dialog
    talk silas talk "What do you need?"
    clear_dialog
    
    choice:
        "What do you ask?"
        
        "Tell me about the Collective.":
            talk silas talk "We're fighters. Hackers. Activists. We believe the corps are destroying our world."
            talk silas talk "We fight back the only way we can—with information. With the truth."
            talk silas talk "You believed in that. Once."
        
        "Do you know who did this to me?":
            talk silas talk "I have my suspicions. Aries Corp. Their security division."
            talk silas talk "They're the ones running Project Lazarus. You got too close. They decided to make an example."
            set data.quests.knowAboutAries true
        
        "Can you help me remember?":
            talk silas talk "I can tell you what I know. But memory... that's something you have to find yourself."
            talk silas talk "Go to the places that meant something to you. Talk to the people who knew you."
            talk silas talk "The implant is dying. But before it goes, it might give up its secrets."
        
        "I should go.":
            jump lot_main
    
    jump lot_talk_silas

lot_collective_info:
    clear_dialog
    talk silas talk "You want to know about the Collective? You helped build it."
    talk silas talk "We operate in cells. Small groups, each with a piece of the puzzle. No one knows everything."
    talk silas talk "Your cell was focused on Aries Corp. You were getting close to something big."
    clear_dialog
    talk silas talk "There are others. Tango. Mama Nomi. Even me. We all play our part."
    clear_dialog
    jump lot_main

lot_lazarus_info:
    clear_dialog
    talk silas talk "Project Lazarus. The worst thing the corps have ever done."
    talk silas talk "They're experimenting on people. Neural implants. Memory manipulation. Personality reconstruction."
    talk silas talk "They're trying to create the perfect workers. The perfect soldiers. People who don't know they're being controlled."
    clear_dialog
    talk silas talk "You found evidence. Proof. But they got to you before you could release it."
    talk silas talk "The evidence is still out there. Hidden. You were always paranoid. Always had backup plans."
    clear_dialog
    set data.quests.knowLazarusDetails true
    jump lot_main

// ==================== WINE FARM ====================

location_wine_farm:
    run transition wine_farm_exterior
    set data.game_map.inMap false
    set data.game_map.currentLocation "wine_farm"
    
    clear_dialog
    "The wine farm sprawls before you—endless rows of vines, a main building in the distance, and the sense of something very wrong beneath the beauty."
    clear_dialog
    "Security cameras. Patrols. This is no ordinary farm."
    clear_dialog
    
    jump wine_farm_main

wine_farm_main:
    clear_dialog
    run hours_display
    clear_dialog
    
    // Danger check
    if (roll wine_farm_danger survivor 30):
        talk survivor internal "We shouldn't be here. Too exposed."
    
    choice:
        "How do you approach?"
        
        "[Sneak in]" if (>= $data.skills.survivor 2):
            run spend_hours 3
            jump wine_farm_sneak
        
        "[Hack the security]" if (&& (has_item? neural_deck) (>= $data.skills.hacker 3)):
            run spend_hours 4
            jump wine_farm_hack
        
        "[Front door] - Pretend to be a worker":
            run spend_hours 2
            jump wine_farm_front
        
        "[Leave] <span class='prompt'>[[BACK TO MAP]]</span>":
            jump game_map

wine_farm_sneak:
    clear_dialog
    "You move through the vines, keeping low, using the rows as cover."
    clear_dialog
    
    if (roll sneak_success survivor 50):
        "You reach the main building. Through a window, you see:"
        clear_dialog
        "A laboratory. People in white coats. And on tables, unconscious figures with neural implants visible at the base of their skulls."
        clear_dialog
        talk survivor internal "Project Lazarus. This is where they do it."
        set data.quests.foundLab true
        set data.player.memoriesRecovered (+ $data.player.memoriesRecovered 1)
    else:
        "A patrol spots you. You have to run."
        clear_dialog
        run spend_hours 2
        "You escape, but barely. They've seen your face now."
        set data.quests.wineFarmAlerted true
    
    jump wine_farm_main

wine_farm_hack:
    clear_dialog
    "You find a secluded spot and jack into their local network."
    clear_dialog
    
    if (roll hack_security hacker 60):
        "The ICE is tough, but you're tougher. You're through."
        clear_dialog
        "Files. Thousands of files. Experiment data. Subject lists. Financial records."
        clear_dialog
        "You download everything you can. Evidence. Proof. Enough to blow Project Lazarus wide open."
        clear_dialog
        add_item lazarus_files 1
        set data.quests.hasEvidence true
        talk hacker internal "This is it. What we were looking for. Now we just need to get it out."
    else:
        "The security is military-grade. You hit a trap program and barely escape."
        clear_dialog
        run spend_hours 3
        "They know someone tried to breach them. Security will be tighter now."
        set data.quests.wineFarmAlerted true
    
    jump wine_farm_main

wine_farm_front:
    clear_dialog
    "You approach the main gate, trying to look like you belong."
    clear_dialog
    
    if (roll bluff_guard survivor 40):
        "The guard waves you through. You're in."
        clear_dialog
        "Inside, you see workers—real workers—tending the vines. But there's a second layer here. Security. Too much security for a farm."
        clear_dialog
        "You find a chance to slip away from the others. Explore."
        clear_dialog
        jump wine_farm_explore
    else:
        "The guard looks at you suspiciously."
        clear_dialog
        talk guard talk "You're not on my list. Who are you?"
        clear_dialog
        "You have to think fast."
        clear_dialog
        
        choice:
            "What do you say?"
            "I'm new. Started today.":
                if (roll bluff_new survivor 30):
                    "The guard shrugs. \"Go on.\""
                    jump wine_farm_explore
                else:
                    "The guard reaches for his radio. You run."
                    run spend_hours 2
                    set data.quests.wineFarmAlerted true
            "Wrong farm. My mistake.":
                "You back away slowly. The guard watches you go."
            "[Run]":
                "You bolt. Shots fired, but you make it to cover."
                run spend_hours 2
                set data.quests.wineFarmAlerted true
    
    jump wine_farm_main

wine_farm_explore:
    clear_dialog
    "You're inside. Time is limited. Where do you look?"
    clear_dialog
    
    choice:
        "What do you investigate?"
        
        "[The main building]":
            "You slip inside. Offices. Meeting rooms. And behind a locked door:"
            clear_dialog
            "A room full of servers. The central hub for Project Lazarus."
            clear_dialog
            if (has_item? neural_deck):
                "You can try to download the data, but it will take time."
                choice:
                    "[Download] - Cost: 3 hours":
                        run spend_hours 3
                        add_item lazarus_files 1
                        set data.quests.hasEvidence true
                        "You get everything. Now you need to get out."
            else:
                "Without a neural deck, you can't access the data. You'll have to come back prepared."
        
        "[The outbuildings]":
            "Behind the main building, a row of sheds. One of them has a heavy lock."
            clear_dialog
            if (has_item? lockpicks):
                "Your lockpicks make short work of it."
                clear_dialog
                "Inside: holding cells. Empty now, but recently used. Scratches on the walls. Messages."
                clear_dialog
                "One message, scratched deep: <span class='writtenText'>\"KUNDAI WAS HERE\"</span>"
                clear_dialog
                talk survivor internal "They held us here. Before they did this to our mind."
                set data.player.memoriesRecovered (+ $data.player.memoriesRecovered 1)
            else:
                "The lock is too heavy. You'd need tools."
        
        "[The workers]":
            "You talk to some of the workers. They're wary, but one older woman opens up."
            clear_dialog
            talk worker talk "You want to know what happens here? Bad things. People disappear."
            talk worker talk "They take the ones who won't be missed. Migrants. Homeless. Anyone without papers."
            talk worker talk "They say they're giving them work. But they never come back."
    
    jump wine_farm_main