// GAME MAP - Dunoon Township and Surroundings
// Location system with time-based events and quest triggers

game_map:
    clear_dialog
    run display_time
    run get_time_of_day
    
    if (!= $data.time.hoursRemaining 0):
        play music dunoon_ambient
    else:
        stop music
    
    if (!= $data.game_map.inMap true):
        set data.game_map.inMap true
        run hide_all_buttons
        run transition_black game_map_screen
    
    run game_map_loadButtons
    run game_prompts

game_map_loadButtons:
    // HOME SHACK - Always available
    if (!= $data.game_map.inPrompts true):
        set_button button_home_shack true
    
    // MAMA NOMI'S PLACE - Available after intro
    if (&& $data.player.knowsIdentity (!= $data.game_map.inPrompts true)):
        set_button button_mama_nomi true
    
    // TANGO'S REPAIR SHOP - Available after meeting Mama Nomi
    if (&& (>= $data.relationships.mamaNomi 1) (!= $data.game_map.inPrompts true)):
        set_button button_tango true
    
    // SILAS AT THE ABANDONED LOT - Available after learning about past
    if (&& $data.quests.knowAboutSilas (!= $data.game_map.inPrompts true)):
        set_button button_abandoned_lot true
    
    // NET CAFE - Available after intro
    if (&& $data.player.knowsIdentity (!= $data.game_map.inPrompts true)):
        set_button button_net_cafe true
    
    // MARKET - Available during certain hours
    if (&& (>= $data.time.hoursRemaining 30) (!= $data.game_map.inPrompts true)):
        set_button button_market true
    
    // CLINIC - Available after learning about implant
    if (&& $data.quests.knowAboutImplant (!= $data.game_map.inPrompts true)):
        set_button button_clinic true
    
    // WINE FARM - Available after certain story progress
    if (&& (>= $data.player.memoriesRecovered 2) (!= $data.game_map.inPrompts true)):
        set_button button_wine_farm true
    
    // BEACH - Available in final hours
    if (&& (<= $data.time.hoursRemaining 25) (!= $data.game_map.inPrompts true)):
        set_button button_beach true

game_prompts:
    // Main story prompts
    if (objective_started? main_story find_mama_nomi):
        if (!= $data.game_map.inPrompts true):
            "<span class='prompt'>[Find Mama Nomi's place - she might know who you are]</span>"
    
    if (objective_started? main_story fix_implant):
        if (!= $data.game_map.inPrompts true):
            "<span class='prompt'>[Find someone who can help with your damaged implant]</span>"
    
    if (objective_started? main_story recover_memories):
        if (!= $data.game_map.inPrompts true):
            "<span class='prompt'>[Recover more memories before time runs out]</span>"
    
    // Time warnings
    if (<= $data.time.hoursRemaining 25):
        if (!= $data.game_map.inPrompts true):
            "<span class='warning'>[WARNING: Time is running out]</span>"

// ==================== LOCATION: HOME SHACK ====================

location_home_shack:
    run transition shack_interior
    set data.game_map.inMap false
    set data.game_map.currentLocation "home"
    clear_dialog
    "Your shack. Small, cramped, but it's shelter. Home, for now."
    clear_dialog
    jump home_shack_menu

home_shack_menu:
    clear_dialog
    choice:
        "What do you do?"
        "[Rest] - Rest for a few hours (costs 3 hours)" if (>= $data.time.hoursRemaining 5):
            run spend_hours 3
            "You close your eyes and let exhaustion take you. Dreamless. Brief. Necessary."
            clear_dialog
            if (roll rest_recovery survivor 30):
                talk survivor internal "Better. Not fully rested, but better."
            jump home_shack_menu
        
        "[Check your neural deck]" if (has_item? neural_deck):
            jump home_shack_deck
        
        "[Examine the photograph on the wall]" if (!= $data.home.examinedPhoto true):
            set data.home.examinedPhoto true
            "You pick up the faded photograph. The woman stares back at you—kind eyes, weathered face, the bright patterns of West African cloth."
            clear_dialog
            if (roll photo_memory ancestor 40):
                "A memory surfaces: this woman, younger, holding your hand. Walking through a market. Teaching you words in a language you've forgotten."
                talk ancestor internal "Your mother. Or someone who was like a mother. She is why you are still alive."
                add_level ancestor 1
            else:
                "Nothing. Her face means nothing to you. But you keep looking anyway."
            jump home_shack_menu
        
        "[Search for useful items]" if (!= $data.home.searched true):
            set data.home.searched true
            jump home_shack_search
        
        "[Try to access the implant directly]" if (&& (>= $data.skills.hacker 2) (!= $data.home.implantAttempt true)):
            set data.home.implantAttempt true
            jump home_shack_implant
        
        "[Leave] <span class='prompt'>[[BACK TO MAP]]</span>":
            jump game_map

home_shack_deck:
    clear_dialog
    "The neural deck is old but functional. A hacker's lifeline. Your lifeline."
    clear_dialog
    choice:
        "What do you do with it?"
        "[Run diagnostics on your implant]" if (!= $data.home.deckDiag true):
            set data.home.deckDiag true
            run spend_hours 1
            "You jack in. The connection is rough—static, noise, fragments of corrupted data."
            clear_dialog
            talk hacker internal "The diagnostic confirms what we feared. The implant's memory banks are degrading. We have maybe 100 hours before total cascade failure."
            talk hacker internal "But there's something else... a hidden partition. Encrypted. Someone wanted to hide something in our head."
            start_objective main_story hidden_partition
        
        "[Browse the local Net]" if (!= $data.home.browsedNet true):
            set data.home.browsedNet true
            run spend_hours 1
            "You skim through the local mesh. News, gossip, advertisements for things you can't afford."
            clear_dialog
            "A headline catches your eye: <span class='news'>"MYSTERIOUS DEATHS IN WINE COUNTRY - AUTHORITIES INVESTIGATE"</span>"
            talk survivor internal "Wine country. The farms. That's close to Dunoon. Could be connected to us."
        
        "[Practice hacking techniques]":
            run spend_hours 2
            if (roll deck_practice hacker 40):
                "You run through old exercises, muscle memory guiding your fingers. You're better than you thought."
                add_level hacker 1
            else:
                "The practice is frustrating. Your mind isn't what it was. But you keep trying."
        
        "[Put the deck away]":
            jump home_shack_menu
    jump home_shack_menu

home_shack_search:
    clear_dialog
    "You dig through the shack's meager contents."
    clear_dialog
    if (roll home_search survivor 40):
        "Hidden under the floorboards, a small cache: a credchip with a few credits, a shiv wrapped in cloth, and a data chip."
        add_item credchip 1
        set data.inventory.credits 15
        add_item shiv 1
        add_item data_chip 1
        talk survivor internal "Someone—we—were hiding things. Preparing for something. This isn't just a home. It's a safehouse."
    else:
        "You find nothing useful. Either there was nothing to find, or someone got here first."
    jump home_shack_menu

home_shack_implant:
    clear_dialog
    run spend_hours 3
    "You close your eyes and reach inward, trying to access the implant's architecture directly."
    clear_dialog
    "It's like trying to read a book while someone sets it on fire."
    clear_dialog
    if (roll direct_access hacker 50):
        "For a moment, you break through. Images flash: a laboratory. People in white coats. A woman with your mother's face. A man with a gun. Then nothing."
        set data.player.memoriesRecovered (+ $data.player.memoriesRecovered 1)
        talk hacker internal "We got something. Not much, but it's a start. The implant has layers. We need to peel them back carefully."
    else:
        "The implant rejects you. Pain lances through your skull. You see only static."
        run spend_hours 1
        talk survivor internal "Don't do that again. It's killing us faster."
    jump home_shack_menu

// ==================== LOCATION: MAMA NOMI'S PLACE ====================

location_mama_nomi:
    run transition mama_nomi_exterior
    set data.game_map.inMap false
    set data.game_map.currentLocation "mama_nomi"
    clear_dialog
    "Mama Nomi's Place. The sign is hand-painted, faded, but the smell of cooking food drifts through the door."
    clear_dialog
    if (!= $data.mamaNomi.met true):
        jump mama_nomi_first_meeting
    else:
        jump mama_nomi_menu

mama_nomi_first_meeting:
    set data.mamaNomi.met true
    complete_objective main_story find_mama_nomi
    "You push through the door. Inside, it's dim and warm. A long counter. A few plastic tables. Cables running along the ceiling to a bank of old terminals in the corner."
    clear_dialog
    "Behind the counter, a large woman looks up at you. Her face creases into a smile—or maybe a grimace. Hard to tell."
    clear_dialog
    talk mama_nomi talk "Ah. You're awake. Good. I was starting to worry."
    clear_dialog
    "She knows you."
    clear_dialog
    choice:
        "She knows you."
        "You know me? Who am I?":
            jump mama_nomi_explanation
        "What happened to me?":
            jump mama_nomi_explanation

mama_nomi_explanation:
    talk mama_nomi talk "Sit down. Eat first. You look like death warmed over."
    "She sets a plate of pap and stew in front of you. The first real food you can remember tasting."
    clear_dialog
    talk mama_nomi talk "You came to me three days ago. Stumbling. Bleeding from your eyes and nose. Said someone did something to your implant."
    clear_dialog
    talk mama_nomi talk "I did what I could. Patched you up. But I'm not a tech. You need someone who understands neural architecture."
    clear_dialog
    talk mama_nomi talk "Your name... you told me your name is Kundai. Or maybe that's what you call yourself now."
    clear_dialog
    "Kundai. The name feels right. Or at least, it feels like a name you've worn for a while."
    clear_dialog
    set data.player.name "Kundai"
    talk mama_nomi talk "As for who you really are... that's your story to remember. I can only tell you what I saw."
    clear_dialog
    run modify_relationship "mamaNomi" 2
    start_objective main_story fix_implant
    jump mama_nomi_menu

mama_nomi_menu:
    clear_dialog
    choice:
        "What do you do?"
        "[Order food] - Cost: 2 hours, restores energy":
            run spend_hours 2
            "You eat. The food is simple but filling. For a moment, you feel almost normal."
            if (roll food_heal survivor 50):
                "Your headache eases slightly."
        
        "[Talk to Mama Nomi]" if (!= $data.mamaNomi.talked true):
            set data.mamaNomi.talked true
            jump mama_nomi_talk
        
        "[Use the network terminals] - Cost: 1 hour" if (!= $data.mamaNomi.usedTerminal true):
            set data.mamaNomi.usedTerminal true
            run spend_hours 1
            "The terminals are old but functional. You search for information about yourself, about neural implants, about anything that might help."
            clear_dialog
            if (roll terminal_search hacker 40):
                "You find a forum post: <span class='writtenText'>"Has anyone heard of black-site neural experiments in the Cape Town area? My cousin went missing after taking a tech job in the wine country."</span>"
                talk hacker internal "Wine country again. There's something there. Something they don't want found."
        
        "[Ask about Tango]" if (&& (>= $data.relationships.mamaNomi 1) (!= $data.mamaNomi.askedAboutTango true)):
            set data.mamaNomi.askedAboutTango true
            talk mama_nomi talk "Tango? He's a fixer. A repairman. Works out of a shack near the market. If anyone can look at that implant, it's him."
            talk mama_nomi talk "But he's... particular. Doesn't like strangers. You'll need to convince him you're worth his time."
            set data.quests.knowAboutTango true
        
        "[Leave] <span class='prompt'>[[BACK TO MAP]]</span>":
            jump game_map
    jump mama_nomi_menu

mama_nomi_talk:
    clear_dialog
    talk mama_nomi talk "You want to know more? About yourself? About Dunoon?"
    clear_dialog
    choice:
        "What do you ask about?"
        "Tell me about Dunoon.":
            talk mama_nomi talk "Dunoon is what happens when people are forgotten. When the rich build walls and the poor build homes from scraps."
            talk mama_nomi talk "We survive. We help each other. That's all anyone can do."
            talk ancestor internal "Listen to her. She understands. Survival is collective."
        
        "Tell me about the wine farms.":
            talk mama_nomi talk "The wine farms? Beautiful. Old. Built on blood. The owners live like kings while we beg for water."
            talk mama_nomi talk "Lately there have been... problems. Workers disappearing. Security tightening. Something is wrong out there."
            talk survivor internal "Something is always wrong where the rich live. But this sounds different."
        
        "Do you know who did this to me?":
            talk mama_nomi talk "No. But I know you were scared when you came here. Running from something."
            talk mama_nomi talk "Whatever it is, it's dangerous. And it won't stop looking for you."
            run modify_relationship "mamaNomi" 1
        
        "I should go.":
            jump mama_nomi_menu
    jump mama_nomi_talk

// ==================== LOCATION: TANGO'S REPAIR SHOP ====================

location_tango:
    run transition tango_exterior
    set data.game_map.inMap false
    set data.game_map.currentLocation "tango"
    clear_dialog
    "Tango's Repair Shop. A larger shack, cluttered with electronic debris. Old servers, broken screens, cables everywhere."
    clear_dialog
    if (!= $data.tango.met true):
        jump tango_first_meeting
    else:
        jump tango_menu

tango_first_meeting:
    set data.tango.met true
    "Inside, a young man hunches over a workbench, his hands moving with impossible precision. He doesn't look up."
    clear_dialog
    talk tango talk "You're the one Mama Nomi sent. The amnesiac with the fried implant."
    clear_dialog
    talk tango talk "I'm Tango. I fix things. Sometimes people."
    clear_dialog
    "He finally looks at you. His eyes are augmented—you can see the faint glow of optical implants."
    clear_dialog
    talk tango talk "Let me see what we're working with. Sit."
    jump tango_examine_implant

tango_examine_implant:
    clear_dialog
    run spend_hours 2
    "Tango's fingers probe the implant port at the base of your skull. His eyes flicker—running diagnostics you can't see."
    clear_dialog
    talk tango talk "Interesting. Someone did a number on this. Military-grade scramble, but sloppy. Amateur hour with professional tools."
    clear_dialog
    talk tango talk "The implant is dying. Taking your memories with it. I can slow it down, but I can't stop it."
    clear_dialog
    choice:
        "Can you help me?"
        "What do I need to do?":
            talk tango talk "You need to find the people who did this. They have the encryption keys. Without them, your memories are gone forever."
            talk tango talk "I can give you a month's worth of time. Maybe two. After that... your brain becomes mush."
            complete_objective main_story fix_implant
            start_objective main_story find_culprits
        
        "Who would do this?":
            talk tango talk "Someone with resources. Someone who wanted information from you, or wanted to put information in."
            talk tango talk "Neural implants don't just scramble themselves. This was deliberate."
    run modify_relationship "tango" 1
    jump tango_menu

tango_menu:
    clear_dialog
    choice:
        "What do you do?"
        "[Ask Tango to stabilize the implant] - Cost: 5 hours" if (!= $data.tango.stabilized true):
            set data.tango.stabilized true
            run spend_hours 5
            "Tango works on your implant for hours. The pain is intense, but when he's done, the constant buzz in your skull has quieted."
            clear_dialog
            talk tango talk "That should buy you some time. Don't waste it."
            add data.time.hoursRemaining 20
            "<span class='success'>[+20 hours gained]</span>"
        
        "[Buy equipment]":
            jump tango_shop
        
        "[Ask about the Netrunner Collective]" if (!= $data.tango.askedAboutCollective true):
            set data.tango.askedAboutCollective true
            talk tango talk "The Collective? They're a group of hackers. Activists. They fight against the corps, the government, anyone who hurts the people."
            talk tango talk "Rumor has it you used to run with them. Before whatever happened to you."
            talk hacker internal "The Collective. That name... it means something. Something important."
            set data.quests.knowAboutCollective true
        
        "[Leave] <span class='prompt'>[[BACK TO MAP]]</span>":
            jump game_map
    jump tango_menu

tango_shop:
    clear_dialog
    "Tango's available equipment:"
    clear_dialog
    choice:
        "What do you want to buy?"
        "Neural Deck (better hacking) - 50 credits" if (&& (!= (has_item? neural_deck) true) (>= $data.inventory.credits 50)):
            add_item neural_deck 1
            set data.inventory.credits (- $data.inventory.credits 50)
            "You now have a neural deck."
        
        "ICE Breaker software - 30 credits" if (&& (!= (has_item? ice_breaker) true) (>= $data.inventory.credits 30)):
            add_item ice_breaker 1
            set data.inventory.credits (- $data.inventory.credits 30)
            add_level hacker 1
            "You install the ICE Breaker. Hacking just got easier."
        
        "Stim patches (healing) - 10 credits" if (&& (!= (has_item? stims) true) (>= $data.inventory.credits 10)):
            add_item stims 1
            set data.inventory.credits (- $data.inventory.credits 10)
            "Emergency medical supplies. Always useful."
        
        "[Back]":
            jump tango_menu
    jump tango_shop

// ==================== LOCATION: BEACH (ENDGAME) ====================

location_beach:
    run transition beach_sunset
    set data.game_map.inMap false
    set data.game_map.currentLocation "beach"
    clear_dialog
    "The beach. Where the township meets the endless expanse of ocean."
    clear_dialog
    "The water is polluted, the sand is gray, but somehow it's still beautiful. The wealthy suburbs glitter on the distant shore."
    clear_dialog
    "Here, at the edge of everything, you can almost forget that you're dying."
    clear_dialog
    jump beach_menu

beach_menu:
    clear_dialog
    choice:
        "The waves lap at the shore. Time is running out."
        "[Sit and watch the ocean] - Cost: 2 hours":
            run spend_hours 2
            "You sit on the sand and watch the endless motion of the water. For a moment, peace."
            clear_dialog
            talk ancestor internal "The ocean does not care about our struggles. It was here before us. It will be here after."
            "Somehow, that's comforting."
        
        "[Try to remember something] - Cost: 3 hours":
            run spend_hours 3
            "You stare at the horizon and reach for your past..."
            clear_dialog
            if (roll beach_memory ancestor 50):
                "A memory surfaces: standing on this same beach, hand in hand with someone. A promise made. A future imagined."
                set data.player.memoriesRecovered (+ $data.player.memoriesRecovered 1)
                "The memory fades, but the feeling remains. You were loved. You mattered to someone."
            else:
                "Nothing. The past is a locked door, and you've lost the key."
        
        "[Make a decision about your final hours]" if (<= $data.time.hoursRemaining 10):
            jump final_choice
        
        "[Leave] <span class='prompt'>[[BACK TO MAP]]</span>":
            jump game_map
    jump beach_menu

// ==================== FINAL CHOICE ====================

final_choice:
    clear_dialog
    "You have less than 10 hours left. The implant is failing. Your memories are slipping away."
    clear_dialog
    "You need to decide how this ends."
    clear_dialog
    choice:
        "What do you do with your remaining time?"
        "[SACRIFICE] - Upload everything you know to the Net, exposing those who did this.":
            jump ending_sacrifice
        
        "[REVOLUTION] - Find the Netrunner Collective and join their fight.":
            jump ending_revolution
        
        "[ESCAPE] - Try to flee Cape Town, start a new life with whatever time you have left.":
            jump ending_escape
        
        "[TRANSCENDENCE] - Try to upload your consciousness before the implant fails.":
            jump ending_transcendence
        
        "[ACCEPTANCE] - Find a quiet place and let go.":
            jump ending_acceptance