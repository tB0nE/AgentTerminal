// HOME SHACK - Player's home location
// Detailed interactions, memories, and personal discovery

home_shack_entry:
    run transition shack_interior
    set data.game_map.inMap false
    set data.game_map.currentLocation "home"
    
    // Ambient description based on time
    if (>= $data.time.hoursRemaining 75):
        "Morning light filters through the cracks in your shack's walls. The air is cool, almost pleasant."
    elseif (>= $data.time.hoursRemaining 50):
        "The afternoon heat is building. Your shack is stifling."
    elseif (>= $data.time.hoursRemaining 25):
        "Evening shadows stretch across your shack. The light is golden, almost beautiful."
    else:
        "Night has fallen. Your shack is dark, lit only by the faint glow of your dying implant."
    
    clear_dialog
    jump home_shack_main

home_shack_main:
    clear_dialog
    run hours_display
    clear_dialog
    
    choice:
        "Your shack. Your refuge. What do you do?"
        
        // REST OPTIONS
        "[Rest] - Sleep for a few hours (Cost: 3 hours)" if (>= $data.time.hoursRemaining 5):
            run spend_hours 3
            jump home_shack_rest
        
        "[Deep rest] - Sleep through the night (Cost: 8 hours)" if (>= $data.time.hoursRemaining 12):
            run spend_hours 8
            jump home_shack_deep_rest
        
        // MEMORY RECOVERY
        "[Meditate] - Try to recover memories (Cost: 5 hours)" if (>= $data.time.hoursRemaining 8):
            run spend_hours 5
            jump home_shack_meditate
        
        // INVENTORY/ITEMS
        "[Check your belongings]":
            jump home_shack_inventory
        
        "[Examine the neural deck]" if (has_item? neural_deck):
            jump home_shack_deck
        
        "[Look at the photograph]" if (!= $data.home.examinedPhoto true):
            jump home_shack_photo
        
        // ENVIRONMENT
        "[Search the shack thoroughly]" if (!= $data.home.thoroughlySearched true):
            jump home_shack_thorough_search
        
        "[Check the hidden compartment]" if (&& $data.home.foundCompartment (!= $data.home.checkedCompartment true)):
            jump home_shack_compartment
        
        // IMPLANT INTERACTION
        "[Focus on your implant]" if (>= $data.skills.hacker 2):
            jump home_shack_implant_focus
        
        // VOICE CONVERSATIONS
        "[Talk to the voices in your head]" if (!= $data.home.talkedToVoices true):
            jump home_shack_voices
        
        "[Leave] <span class='prompt'>[[BACK TO MAP]]</span>":
            jump game_map

// ==================== REST SEQUENCES ====================

home_shack_rest:
    clear_dialog
    "You lie down on the thin mattress. Your body aches. Your mind races. But exhaustion wins."
    clear_dialog
    play sound sleep
    wait 2000
    "..."
    clear_dialog
    "You dream of falling. Of code scrolling endlessly. Of a woman's voice calling your name."
    clear_dialog
    "You wake with a start. The dream fades, but the feeling remains."
    clear_dialog
    
    if (roll rest_dream ancestor 30):
        talk ancestor internal "Dreams are messages from the deeper self. Remember the falling. Remember the code. They mean something."
        set data.player.dreamsHad (+ $data.player.dreamsRecovered 1)
    
    jump home_shack_main

home_shack_deep_rest:
    clear_dialog
    "You need proper sleep. Real rest. You settle in for the night."
    clear_dialog
    play sound sleep
    wait 3000
    "The darkness takes you."
    clear_dialog
    "..."
    clear_dialog
    
    // Deeper dream sequence
    "You stand in a room of white. Sterile. Clinical. People in lab coats move around you."
    clear_dialog
    "One of them turns. You see your own face, but older. Scarred."
    clear_dialog
    "\"You did this to yourself,\" the face says. \"Remember that.\""
    clear_dialog
    "You wake gasping. The shack is dark. Your implant throbs."
    clear_dialog
    
    set data.player.memoriesRecovered (+ $data.player.memoriesRecovered 1)
    talk hacker internal "A laboratory. Experiments. And someone who looks like us. This is important."
    talk survivor internal "This is dangerous. Someone's been in our head. Literally."
    
    jump home_shack_main

// ==================== MEDITATION/MEMORY ====================

home_shack_meditate:
    clear_dialog
    "You sit in the center of the shack, close your eyes, and turn inward."
    clear_dialog
    "The implant's damaged architecture looms in your mind's eye—a labyrinth of corrupted data and locked memories."
    clear_dialog
    
    if (roll memory_meditation ancestor 40):
        "You find a crack in the walls. A fragment of memory..."
        clear_dialog
        
        // Random memory fragment
        set data.meditation.memoryType (random 1 3)
        
        if (== $data.meditation.memoryType 1):
            "You see a young man's face. Dark skin, bright eyes, a smile that makes your heart ache. He says something you can't hear. Then he's gone."
            talk ancestor internal "Love. You loved someone. Remember that feeling. It will guide you back to yourself."
            set data.home.rememberedLove true
        
        elseif (== $data.meditation.memoryType 2):
            "You see lines of code. Elegant. Beautiful. Your fingers moving across a keyboard, building something important. A message? A weapon? You can't tell."
            talk hacker internal "We created something. Something powerful. We need to find out what."
            set data.home.rememberedCreation true
        
        else:
            "You see a building. Glass and steel rising above the township. A corporate logo you almost recognize. You're running toward it. Or away from it."
            talk survivor internal "The corps. The enemy. We were fighting them. We need to find out why."
            set data.home.rememberedEnemy true
        
        set data.player.memoriesRecovered (+ $data.player.memoriesRecovered 1)
    
    else:
        "The walls are too thick. The corruption too deep. You surface with nothing but a headache."
        talk survivor internal "Don't push too hard. You'll burn out what's left of your mind."
    
    jump home_shack_main

// ==================== INVENTORY ====================

home_shack_inventory:
    clear_dialog
    "You take stock of what you have:"
    clear_dialog
    
    if (has_item? neural_deck):
        "- A neural deck (essential for hacking)"
    
    if (has_item? credchip):
        "- A credchip with $data.inventory.credits credits"
    
    if (has_item? shiv):
        "- A shiv (better than nothing in a fight)"
    
    if (has_item? data_chip):
        "- A mysterious data chip (contents unknown)"
    
    if (has_item? ice_breaker):
        "- ICE Breaker software (hacking bonus)"
    
    if (has_item? stims):
        "- Stim patches (emergency healing)"
    
    if (&& (!= (has_item? neural_deck) true) (!= $data.home.deckFound true)):
        "You notice something under the mattress..."
        choice:
            "[Investigate]":
                jump home_shack_find_deck
            "[Ignore it for now]":
                jump home_shack_main
    
    jump home_shack_main

home_shack_find_deck:
    set data.home.deckFound true
    add_item neural_deck 1
    "You pull out a battered neural deck. Old model, but functional. Your fingers know its weight."
    clear_dialog
    talk hacker internal "Yes. This is ours. This is how we fight back."
    jump home_shack_main

// ==================== PHOTOGRAPH ====================

home_shack_photo:
    set data.home.examinedPhoto true
    clear_dialog
    "You take down the photograph and study it carefully."
    clear_dialog
    "The woman is beautiful in the way that mothers are beautiful—worn, resilient, full of love she hasn't been paid for."
    clear_dialog
    "Her clothes mark her as West African. Nigerian, maybe, or Ghanaian. The bright patterns contrast with the gray walls of your shack."
    clear_dialog
    "On the back, someone has written in faded ink: <span class='writtenText'>"My Amina. Forever in my heart."</span>
    clear_dialog
    "Amina. The name echoes in your mind."
    clear_dialog
    
    choice:
        "What do you feel?"
        "[Love] - This woman loved you. You loved her.":
            if (roll photo_love ancestor 50):
                "A memory surfaces: Amina's hands braiding your hair. Her voice singing a lullaby in a language you don't speak. The smell of her perfume."
                talk ancestor internal "Your mother. Or the woman who raised you. Her love is still with you, even if she isn't."
                add_level ancestor 1
                set data.home.knowMother true
            else:
                "You feel the shape of the love, but not its substance. Like a book you once read but can't remember."
        
        "[Loss] - She's gone. Someone took her from you.":
            if (roll photo_loss survivor 50):
                "A flash of grief so sharp it doubles you over. A funeral. A coffin. A face you hate but can't place."
                talk survivor internal "Someone hurt her. Someone hurt you. We need to find out who. Make them pay."
                set data.home.knowLoss true
            else:
                "The loss is there, but its source is hidden. Locked away with everything else."
        
        "[Nothing] - The photograph means nothing to you.":
            talk hacker internal "The connection is there. The data is just corrupted. We need more time."
    
    jump home_shack_main

// ==================== THOROUGH SEARCH ====================

home_shack_thorough_search:
    set data.home.thoroughlySearched true
    clear_dialog
    run spend_hours 1
    "You tear the shack apart, looking for anything that might tell you who you are."
    clear_dialog
    
    // Hidden compartment discovery
    if (roll search_hidden survivor 40):
        "Your fingers find a loose floorboard. Underneath, a hidden compartment."
        set data.home.foundCompartment true
        talk survivor internal "Smart. We were hiding things. Preparing for something."
    
    // Random discoveries
    if (roll search_items survivor 50):
        "In a crack in the wall, you find a credchip with 25 credits."
        add data.inventory.credits 25
    
    if (roll search_notes hacker 40):
        "Scrawled on a scrap of paper, barely legible: <span class='writtenText'>"SILAS KNOWS. FIND HIM."</span>"
        set data.quests.knowAboutSilas true
        talk hacker internal "Silas. Someone who has answers. We need to find him."
    
    if (roll search_map survivor 30):
        "A hand-drawn map of the wine farms, with one building circled in red."
        add_item wine_farm_map 1
        talk survivor internal "Something happened at those farms. Something important enough to map out."
    
    "You've searched thoroughly. There's nothing else to find."
    jump home_shack_main

// ==================== HIDDEN COMPARTMENT ====================

home_shack_compartment:
    set data.home.checkedCompartment true
    clear_dialog
    "You lift the floorboard and reveal a small cache hidden beneath."
    clear_dialog
    
    // Contents based on what's been discovered
    "Inside you find:"
    clear_dialog
    
    "- A credchip with 50 credits"
    add data.inventory.credits 50
    
    "- A shiv, sharp and well-maintained"
    add_item shiv 1
    
    "- A data chip, label worn away"
    add_item data_chip 1
    
    "- A photograph, different from the one on the wall"
    add_item secret_photo 1
    
    "The photograph shows you—you recognize your own face—standing with three other people. A young woman with cybernetic arms. An older man with graying hair. A teenager with a nervous smile."
    clear_dialog
    "On the back: <span class='writtenText'>"The Collective. We fight together."</span>"
    clear_dialog
    
    talk hacker internal "The Netrunner Collective. These were our people. Our team. We need to find them."
    talk survivor internal "If they're still alive. If they haven't been captured or killed."
    talk ancestor internal "Family isn't always blood. These people chose to fight alongside us. Remember that."
    
    set data.quests.foundCollectivePhoto true
    jump home_shack_main

// ==================== IMPLANT FOCUS ====================

home_shack_implant_focus:
    clear_dialog
    "You close your eyes and sink into the architecture of your own mind."
    clear_dialog
    "The implant is a city of corrupted data—buildings crumbling, streets blocked, files scattered like debris after a storm."
    clear_dialog
    
    choice:
        "Where do you focus?"
        "[The core] - Try to access the central memory banks":
            run spend_hours 2
            if (roll implant_core hacker 50):
                "You push through the corruption and find a single intact file. A video."
                clear_dialog
                "You see yourself, speaking to a camera. Younger. Unafraid."
                clear_dialog
                "\"If you're watching this, I'm dead or worse. The project is real. The experiments are happening. The Collective has the evidence. Find them. Finish what we started.\""
                clear_dialog
                set data.player.memoriesRecovered (+ $data.player.memoriesRecovered 1)
                set data.quests.knowAboutProject true
                talk hacker internal "A project. Experiments. We were trying to expose something. That's why they did this to us."
            else:
                "The core is too damaged. Every time you get close, the corruption pushes you back."
                run spend_hours 1
                talk survivor internal "We're not ready. We need more skills, more knowledge. Come back when we're stronger."
        
        "[The edges] - Look for fragments in the peripheral systems":
            run spend_hours 1
            if (roll implant_edges hacker 40):
                "You find scattered fragments—a name here, a date there, coordinates that might mean something."
                set data.player.memoriesRecovered (+ $data.player.memoriesRecovered 1)
                talk hacker internal "Useful data. We're piecing together a picture. Slowly."
            else:
                "The edges are worse than the core—nothing but static and noise."
        
        "[The hidden partition] - Try to crack the encrypted section" if $data.home.deckDiag:
            run spend_hours 3
            if (roll implant_hidden hacker 60):
                "The encryption is military-grade, but you've seen it before. In another life. Your fingers know the patterns."
                clear_dialog
                "The partition opens. Inside: names, dates, locations. A list of people who were experimented on. You're on the list."
                clear_dialog
                "At the bottom: <span class='writtenText'>"PROJECT LAZARUS - PHASE 2 COMMENCING - CAPE TOWN SECTOR"</span>"
                clear_dialog
                set data.player.memoriesRecovered (+ $data.player.memoriesRecovered 2)
                set data.quests.knowAboutLazarus true
                talk hacker internal "Project Lazarus. That's what they called it. We were part of it. Or fighting against it."
            else:
                "The encryption is too strong. You'd need better equipment, or more time you don't have."
        
        "[Retreat] - This is too dangerous right now":
            "You pull back. The implant settles, but the sense of untapped knowledge remains."
    
    jump home_shack_main

// ==================== VOICE CONVERSATIONS ====================

home_shack_voices:
    set data.home.talkedToVoices true
    clear_dialog
    "You sit in silence and address the presences in your mind."
    clear_dialog
    
    choice:
        "Who do you want to speak to?"
        "[The Hacker] - Ask about your technical skills":
            clear_dialog
            talk hacker internal "You want to know what I know? Fine."
            talk hacker internal "I know code. I know the Net. I know how to break into systems and extract information."
            talk hacker internal "I don't know who taught us, or why. But I know we're good. Very good. Good enough to scare someone."
            talk hacker internal "Whatever happened to us, we were a threat. That's why they scrambled our brain."
            add_level hacker 1
        
        "[The Survivor] - Ask about your instincts":
            clear_dialog
            talk survivor internal "You want to know what I know? Here it is."
            talk survivor internal "I know how to read people. How to spot a threat. How to disappear when needed."
            talk survivor internal "I know hunger. Cold. Fear. I know how to keep going when everything tells you to stop."
            talk survivor internal "Whatever happened to us, we've been through worse. We can handle this."
            add_level survivor 1
        
        "[The Ancestor] - Ask about your wisdom":
            clear_dialog
            talk ancestor internal "You want to know what I carry? Listen."
            talk ancestor internal "I carry the voices of those who came before. The ones who survived slavery. Apartheid. Poverty."
            talk ancestor internal "I carry their strength, their faith, their knowledge that survival is a collective act."
            talk ancestor internal "Whatever happened to us, we are not alone. We have never been alone."
            add_level ancestor 1
        
        "[All three] - Ask them to work together":
            clear_dialog
            talk hacker internal "We've been fighting each other since you woke up. That needs to stop."
            talk survivor internal "Agreed. We're stronger together. Each of us sees something the others miss."
            talk ancestor internal "Then let us make peace. We are not three voices. We are one mind, fragmented. Time to become whole."
            "You feel a shift in your consciousness. The voices don't disappear, but they harmonize. Working together instead of arguing."
            add_level hacker 1
            add_level survivor 1
            add_level ancestor 1
            set data.home.voicesHarmonized true
    
    jump home_shack_main

// ==================== NEURAL DECK ====================

home_shack_deck:
    clear_dialog
    "You pick up the neural deck. It's old but reliable. Your fingers find the controls without thinking."
    clear_dialog
    
    choice:
        "What do you do with it?"
        "[Run diagnostics on your implant]":
            run spend_hours 1
            "You jack in. The connection is rough—static, noise, fragments of corrupted data."
            clear_dialog
            
            if (!= $data.home.deckDiag true):
                set data.home.deckDiag true
                talk hacker internal "Diagnostic complete. The implant's memory banks are degrading. We have about $data.time.hoursRemaining hours before total failure."
                talk hacker internal "But there's something else... a hidden partition. Encrypted. Someone wanted to hide something in our head."
                start_objective main_story hidden_partition
            else:
                talk hacker internal "Nothing new. The degradation continues. We need to find answers before it's too late."
        
        "[Access the local Net]":
            run spend_hours 1
            "You connect to the local mesh. It's limited—the township doesn't have great infrastructure—but it's something."
            clear_dialog
            
            // Random news/events
            set data.deck.netEvent (random 1 4)
            
            if (== $data.deck.netEvent 1):
                "A headline catches your eye: <span class='news'>"MYSTERIOUS DEATHS IN WINE COUNTRY - AUTHORITIES INVESTIGATE"</span>"
                talk survivor internal "Wine country. The farms. That's close to Dunoon. Could be connected to us."
            
            elseif (== $data.deck.netEvent 2):
                "A forum post: <span class='news'>"Anyone else seen increased corp security in Dunoon? They're looking for someone."</span>"
                talk survivor internal "They're looking for us. We need to be careful."
            
            elseif (== $data.deck.netEvent 3):
                "A help wanted ad: <span class='news'>"NETRUNNERS WANTED - HIGH RISK, HIGH PAY - CONTACT SILAS AT THE ABANDONED LOT"</span>"
                talk hacker internal "Silas again. This person keeps coming up. We need to find them."
                set data.quests.knowAboutSilas true
            
            else:
                "Nothing useful. Just the usual noise of people trying to survive."
        
        "[Practice hacking]":
            run spend_hours 2
            "You run through old exercises, muscle memory guiding your fingers."
            clear_dialog
            
            if (roll deck_practice hacker 40):
                "You're better than you thought. The skills are still there, buried under the damage."
                add_level hacker 1
            else:
                "The practice is frustrating. Your mind isn't what it was. But you keep trying."
        
        "[Examine the data chip]" if (has_item? data_chip):
            run spend_hours 1
            "You slot the data chip into the deck."
            clear_dialog
            
            if (roll chip_decode hacker 50):
                "The data is encrypted, but you crack it. Inside: a list of names, dates, and medical codes."
                clear_dialog
                "Your name is on the list. So are twenty others."
                clear_dialog
                talk hacker internal "More victims of whatever was done to us. If we can find them, we might find answers."
                set data.quests.foundVictimList true
            else:
                "The encryption is too complex. You'd need better software or more time."
        
        "[Put the deck away]":
            jump home_shack_main
    
    jump home_shack_main